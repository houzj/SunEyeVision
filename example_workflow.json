{
  "Id": "workflow-20260311-001",
  "Name": "视觉检测流程",
  "Description": "图像阈值处理和边缘检测的简单工作流",
  "Nodes": [
    {
      "Id": "node-001",
      "Name": "图像输入",
      "Type": 0,
      "AlgorithmType": "ImageInput",
      "ParametersTypeName": null,
      "IsEnabled": true,
      "Parameters": {
        "Version": "1.0",
        "Properties": {
          "FilePath": "C:\\Images\\test.jpg",
          "ImageSource": "File"
        }
      },
      "ParameterBindings": {}
    },
    {
      "Id": "node-002",
      "Name": "阈值处理",
      "Type": 0,
      "AlgorithmType": "SunEyeVision.ThresholdTool.ThresholdTool",
      "ParametersTypeName": "SunEyeVision.ThresholdTool.ThresholdParameters, ThresholdToolPlugin, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null",
      "IsEnabled": true,
      "Parameters": {
        "Version": "1.0",
        "Properties": {
          "Threshold": 128,
          "MaxValue": 255,
          "ThresholdType": 1,
          "OtsuThreshold": false,
          "AdaptiveThresholdMethod": 0,
          "BlockSize": 11,
          "C": 2
        }
      },
      "ParameterBindings": {}
    },
    {
      "Id": "node-003",
      "Name": "边缘检测",
      "Type": 0,
      "AlgorithmType": "SunEyeVision.EdgeDetectorTool.EdgeDetectorTool",
      "ParametersTypeName": "SunEyeVision.EdgeDetectorTool.EdgeDetectorParameters, EdgeDetectorPlugin, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null",
      "IsEnabled": true,
      "Parameters": {
        "Version": "1.0",
        "Properties": {
          "Threshold1": 50,
          "Threshold2": 150,
          "ApertureSize": 3,
          "L2Gradient": false
        }
      },
      "ParameterBindings": {
        "InputImage": {
          "SourceNodeId": "node-002",
          "SourcePort": "OutputImage",
          "MappingType": "Direct"
        }
      }
    },
    {
      "Id": "node-004",
      "Name": "图像输出",
      "Type": 0,
      "AlgorithmType": "ImageOutput",
      "ParametersTypeName": null,
      "IsEnabled": true,
      "Parameters": {
        "Version": "1.0",
        "Properties": {
          "FilePath": "C:\\Images\\output.jpg",
          "OutputFormat": "Jpeg",
          "Quality": 90
        }
      },
      "ParameterBindings": {
        "InputImage": {
          "SourceNodeId": "node-003",
          "SourcePort": "OutputImage",
          "MappingType": "Direct"
        }
      }
    },
    {
      "Id": "node-005",
      "Name": "条件判断",
      "Type": 1,
      "AlgorithmType": "ConditionTool",
      "ParametersTypeName": "SunEyeVision.ConditionTool.ConditionParameters, ConditionPlugin, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null",
      "IsEnabled": true,
      "Parameters": {
        "Version": "1.0",
        "Properties": {
          "Expression": "node-002.OutputImage.Width > 500",
          "TrueNodeId": "node-003",
          "FalseNodeId": "node-004"
        }
      },
      "ParameterBindings": {}
    }
  ],
  "Connections": {
    "node-001": ["node-002"],
    "node-002": ["node-003"],
    "node-003": ["node-004"],
    "node-005": ["node-003", "node-004"]
  },
  "PortConnections": [
    {
      "SourceNodeId": "node-001",
      "SourcePort": "output",
      "TargetNodeId": "node-002",
      "TargetPort": "input"
    },
    {
      "SourceNodeId": "node-002",
      "SourcePort": "output",
      "TargetNodeId": "node-003",
      "TargetPort": "input"
    },
    {
      "SourceNodeId": "node-003",
      "SourcePort": "output",
      "TargetNodeId": "node-004",
      "TargetPort": "input"
    },
    {
      "SourceNodeId": "node-002",
      "SourcePort": "output",
      "TargetNodeId": "node-005",
      "TargetPort": "condition"
    }
  ]
}
