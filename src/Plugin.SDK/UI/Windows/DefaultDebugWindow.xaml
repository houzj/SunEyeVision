<Window x:Class="SunEyeVision.Plugin.SDK.UI.Windows.DefaultDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:commands="clr-namespace:SunEyeVision.Plugin.SDK.Commands"
        Title="工具调试窗口"
        Width="450"
        Height="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <!-- 窗口命令绑定 -->
    <Window.CommandBindings>
        <CommandBinding Command="commands:ToolCommands.Execute"
                        Executed="OnExecuteCommand"
                        CanExecute="CanExecuteCommand"/>
        <CommandBinding Command="commands:ToolCommands.Confirm"
                        Executed="OnConfirmCommand"/>
        <CommandBinding Command="commands:ToolCommands.ContinuousExecute"
                        Executed="OnContinuousExecuteCommand"
                        CanExecute="CanExecuteCommand"/>
    </Window.CommandBindings>

    <!-- 外层容器：白色背景 + 阴影 -->
    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="0"
            BorderBrush="#CCCCCC"
            BorderThickness="1">
        
        <Border.Effect>
            <DropShadowEffect Color="Black"
                             Opacity="0.2"
                             ShadowDepth="2"
                             BlurRadius="8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 标题栏 -->
                <RowDefinition Height="*"/>     <!-- 内容区 -->
                <RowDefinition Height="40"/>    <!-- 底部按钮栏 -->
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    Background="#1E1E1E"
                    Height="32"
                    Padding="12,0,8,0"
                    MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 标题文字 -->
                    <TextBlock Grid.Column="0"
                              x:Name="TitleTextBlock"
                              Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                              Foreground="White"
                              VerticalAlignment="Center"
                              FontSize="13"/>

                    <!-- 关闭按钮 -->
                    <Button Grid.Column="1"
                            Content="✕"
                            Width="32"
                            Height="32"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="14"
                            Cursor="Hand"
                            Click="OnCloseButtonClick">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E81123"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- 内容区域 -->
            <ContentControl Grid.Row="1"
                           x:Name="ContentHost"
                           Focusable="False"/>

            <!-- 底部按钮栏 -->
            <Border Grid.Row="2"
                    Background="#2D2D2D"
                    BorderBrush="#404040"
                    BorderThickness="0,1,0,0"
                    Padding="16,6,16,6">

                <StackPanel Orientation="Horizontal"
                           HorizontalAlignment="Right">

                    <!-- 连续执行按钮 -->
                    <Button x:Name="ContinuousRunButton"
                            Content="连续执行"
                            Width="100"
                            Height="28"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Background="#3A3A3A"
                            Foreground="White"
                            BorderBrush="#505050"
                            BorderThickness="1"
                            Command="commands:ToolCommands.ContinuousExecute"/>

                    <!-- 执行按钮 -->
                    <Button x:Name="RunButton"
                            Content="执行"
                            Width="100"
                            Height="28"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Background="#3A3A3A"
                            Foreground="White"
                            BorderBrush="#505050"
                            BorderThickness="1"
                            Command="commands:ToolCommands.Execute"/>

                    <!-- 确定按钮 -->
                    <Button x:Name="ConfirmButton"
                            Content="确定"
                            Width="100"
                            Height="28"
                            Cursor="Hand"
                            Background="#3A3A3A"
                            Foreground="White"
                            BorderBrush="#505050"
                            BorderThickness="1"
                            Command="commands:ToolCommands.Confirm"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
