<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:constants="clr-namespace:SunEyeVision.Plugin.SDK.UI.Constants;assembly=SunEyeVision.Plugin.SDK">

    <!-- 
    样式资源字典 - 单一来源
    
    所有样式引用常量资源（Colors.xaml、Fonts.xaml、Layout.xaml）。
    修改样式时，请优先修改常量值。
    
    禁止在此文件中硬编码颜色、字体、布局值！
    -->

    <!-- ========== 基础样式 ========== -->
    
    <!-- 基础输入控件样式 -->
    <Style x:Key="BaseInputStyle" TargetType="Control">
        <Setter Property="Height" Value="{DynamicResource ControlHeightLarge}"/>
        <Setter Property="Padding" Value="{DynamicResource PaddingStandard}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThicknessThin}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ========== 标签样式 ========== -->
    
    <!-- 标签样式 -->
    <Style x:Key="LabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="{DynamicResource MarginRightSmall}"/>
    </Style>

    <!-- 次要标签样式 -->
    <Style x:Key="LabelSecondaryStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="{DynamicResource MarginTopXSmall}"/>
    </Style>

    <!-- ========== 按钮样式 ========== -->
    
    <!-- 主按钮样式 -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="{DynamicResource ControlHeightLarge}"/>
        <Setter Property="Padding" Value="{DynamicResource ButtonPadding}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- 次要按钮样式 -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="{DynamicResource ControlHeightLarge}"/>
        <Setter Property="Padding" Value="{DynamicResource ButtonPadding}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThicknessThin}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- ========== 文本框样式 ========== -->
    
    <!-- 标准文本框样式 -->
    <Style x:Key="StandardTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource BaseInputStyle}">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <!-- ========== 下拉框样式 ========== -->
    
    <!-- 标准下拉框样式 -->
    <Style x:Key="StandardComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource BaseInputStyle}">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <!-- ========== 复选框样式 ========== -->
    
    <!-- 标准复选框样式 -->
    <Style x:Key="StandardCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,{DynamicResource SpacingXSmall}"/>
    </Style>

    <!-- ========== 单选按钮样式 ========== -->
    
    <!-- 标准单选按钮样式 -->
    <Style x:Key="StandardRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,{DynamicResource SpacingXSmall}"/>
    </Style>

    <!-- ========== 容器样式 ========== -->
    
    <!-- 卡片容器样式 -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThicknessThin}"/>
        <Setter Property="Padding" Value="{DynamicResource PaddingLoose}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMedium}"/>
        <Setter Property="Margin" Value="0,0,0,{DynamicResource SpacingSmall}"/>
    </Style>

    <!-- 分组容器样式 -->
    <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
        <Setter Property="Padding" Value="{DynamicResource PaddingLoose}"/>
        <Setter Property="Margin" Value="0,0,0,{DynamicResource SpacingMedium}"/>
    </Style>

</ResourceDictionary>
