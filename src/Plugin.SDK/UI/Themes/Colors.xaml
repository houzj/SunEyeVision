<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:constants="clr-namespace:SunEyeVision.Plugin.SDK.UI.Constants">

    <!-- 
    颜色资源字典 - 单一来源
    
    所有颜色值来自 ColorConstants.cs，通过 x:Static 引用。
    修改颜色时，只需修改 ColorConstants.cs 即可。
    
    禁止在此文件中硬编码颜色值！
    -->

    <!-- ========== 主色调系统 ========== -->
    
    <!-- 主色调 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{x:Static constants:ColorConstants.Primary}"/>
    
    <!-- 主色调悬停 -->
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{x:Static constants:ColorConstants.PrimaryHover}"/>
    
    <!-- 主色调按下 -->
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{x:Static constants:ColorConstants.PrimaryPressed}"/>

    <!-- ========== 功能色系统 ========== -->
    
    <!-- 次要色 -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="{x:Static constants:ColorConstants.Secondary}"/>
    
    <!-- 警告色 -->
    <SolidColorBrush x:Key="WarningBrush" Color="{x:Static constants:ColorConstants.Warning}"/>
    
    <!-- 错误色 -->
    <SolidColorBrush x:Key="ErrorBrush" Color="{x:Static constants:ColorConstants.Error}"/>
    
    <!-- 成功色 -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{x:Static constants:ColorConstants.Success}"/>
    
    <!-- 信息色 -->
    <SolidColorBrush x:Key="InfoBrush" Color="{x:Static constants:ColorConstants.Info}"/>

    <!-- ========== 强调色系统 ========== -->
    
    <!-- 强调色 -->
    <SolidColorBrush x:Key="AccentBrush" Color="{x:Static constants:ColorConstants.Accent}"/>

    <!-- ========== 中性色系统 ========== -->
    
    <!-- 文本主色 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{x:Static constants:ColorConstants.TextPrimary}"/>
    
    <!-- 文本次要色 -->
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{x:Static constants:ColorConstants.TextSecondary}"/>
    
    <!-- 文本禁用色 -->
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{x:Static constants:ColorConstants.TextDisabled}"/>
    
    <!-- 边框色 -->
    <SolidColorBrush x:Key="BorderBrush" Color="{x:Static constants:ColorConstants.Border}"/>
    
    <!-- 边框浅色 -->
    <SolidColorBrush x:Key="BorderLightBrush" Color="{x:Static constants:ColorConstants.BorderLight}"/>
    
    <!-- 背景色 -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{x:Static constants:ColorConstants.Background}"/>
    
    <!-- 背景灰色 -->
    <SolidColorBrush x:Key="BackgroundGrayBrush" Color="{x:Static constants:ColorConstants.BackgroundGray}"/>
    
    <!-- 背景深灰色 -->
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{x:Static constants:ColorConstants.BackgroundDark}"/>
    
    <!-- 背景悬停色 -->
    <SolidColorBrush x:Key="BackgroundHoverBrush" Color="{x:Static constants:ColorConstants.BackgroundHover}"/>
    
    <!-- 背景选中色 -->
    <SolidColorBrush x:Key="BackgroundSelectedBrush" Color="{x:Static constants:ColorConstants.BackgroundSelected}"/>
    
    <!-- 背景悬停浅蓝色 -->
    <SolidColorBrush x:Key="BackgroundHoverSelectedBrush" Color="{x:Static constants:ColorConstants.BackgroundHoverSelected}"/>
    
    <!-- 轨道背景色 -->
    <SolidColorBrush x:Key="TrackBackgroundBrush" Color="{x:Static constants:ColorConstants.TrackBackground}"/>
    
    <!-- 深色主题控件背景 -->
    <SolidColorBrush x:Key="DarkThemeControlBackgroundBrush" Color="{x:Static constants:ColorConstants.DarkThemeControlBackground}"/>
    
    <!-- 开关橙色 -->
    <SolidColorBrush x:Key="SwitchOnBackgroundBrush" Color="{x:Static constants:ColorConstants.SwitchOnBackground}"/>

</ResourceDictionary>
