<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:constants="clr-namespace:SunEyeVision.Plugin.SDK.UI.Constants;assembly=SunEyeVision.Plugin.SDK">

    <!-- 
    字体资源字典 - 单一来源
    
    所有字体值来自 FontConstants.cs，通过 x:Static 引用。
    修改字体时，只需修改 FontConstants.cs 即可。
    
    禁止在此文件中硬编码字体值！
    -->

    <!-- ========== 字体大小系统 ========== -->
    
    <!-- 标题字体大小 -->
    <sys:Double x:Key="FontSizeTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:FontConstants.SizeTitle}</sys:Double>
    
    <!-- 副标题字体大小 -->
    <sys:Double x:Key="FontSizeHeading" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:FontConstants.SizeHeading}</sys:Double>
    
    <!-- 正文字体大小 -->
    <sys:Double x:Key="FontSizeBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:FontConstants.SizeBody}</sys:Double>
    
    <!-- 说明文字字体大小 -->
    <sys:Double x:Key="FontSizeCaption" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:FontConstants.SizeCaption}</sys:Double>
    
    <!-- 小号文字字体大小 -->
    <sys:Double x:Key="FontSizeSmall" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:FontConstants.SizeSmall}</sys:Double>
    
    <!-- 微小文字字体大小 -->
    <sys:Double x:Key="FontSizeMicro" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:FontConstants.SizeMicro}</sys:Double>

    <!-- 极小文字字体大小 -->
    <sys:Double x:Key="FontSizeTiny" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:FontConstants.SizeTiny}</sys:Double>

    <!-- ========== 字体族系统 ========== -->
    
    <!-- 默认字体族 -->
    <FontFamily x:Key="FontFamilyDefault">{x:Static constants:FontConstants.FamilyDefault}</FontFamily>
    
    <!-- 等宽字体族 -->
    <FontFamily x:Key="FontFamilyMono">{x:Static constants:FontConstants.FamilyMono}</FontFamily>
    
    <!-- 数字字体族 -->
    <FontFamily x:Key="FontFamilyNumeric">{x:Static constants:FontConstants.FamilyNumeric}</FontFamily>

    <!-- ========== 字重系统 ========== -->
    
    <!-- 正常字重 -->
    <FontWeight x:Key="FontWeightNormal">{x:Static constants:FontConstants.WeightNormal}</FontWeight>
    
    <!-- 中等字重 -->
    <FontWeight x:Key="FontWeightMedium">{x:Static constants:FontConstants.WeightMedium}</FontWeight>
    
    <!-- 粗体字重 -->
    <FontWeight x:Key="FontWeightBold">{x:Static constants:FontConstants.WeightBold}</FontWeight>
    
    <!-- 轻字重 -->
    <FontWeight x:Key="FontWeightLight">{x:Static constants:FontConstants.WeightLight}</FontWeight>

</ResourceDictionary>
