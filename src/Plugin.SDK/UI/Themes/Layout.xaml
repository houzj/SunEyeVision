<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:constants="clr-namespace:SunEyeVision.Plugin.SDK.UI.Constants;assembly=SunEyeVision.Plugin.SDK">

    <!-- 
    布局资源字典 - 单一来源
    
    所有布局值来自 LayoutConstants.cs，通过 x:Static 引用。
    修改布局时，只需修改 LayoutConstants.cs 即可。
    
    禁止在此文件中硬编码布局值！
    -->

    <!-- ========== 控件高度系统 ========== -->
    
    <!-- 控件高度 - 小号 -->
    <sys:Double x:Key="ControlHeightSmall" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ControlHeightSmall}</sys:Double>
    
    <!-- 控件高度 - 中号 -->
    <sys:Double x:Key="ControlHeightMedium" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ControlHeightMedium}</sys:Double>
    
    <!-- 控件高度 - 大号 -->
    <sys:Double x:Key="ControlHeightLarge" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ControlHeightLarge}</sys:Double>
    
    <!-- 控件高度 - 超大号 -->
    <sys:Double x:Key="ControlHeightXLarge" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ControlHeightXLarge}</sys:Double>

    <!-- ========== 控件宽度系统 ========== -->
    
    <!-- 控件最小宽度 - 小号 -->
    <sys:Double x:Key="ControlMinWidthSmall" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ControlMinWidthSmall}</sys:Double>
    
    <!-- 控件最小宽度 - 中号 -->
    <sys:Double x:Key="ControlMinWidthMedium" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ControlMinWidthMedium}</sys:Double>
    
    <!-- 控件最小宽度 - 大号 -->
    <sys:Double x:Key="ControlMinWidthLarge" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ControlMinWidthLarge}</sys:Double>
    
    <!-- 控件最小宽度 - 超大号 -->
    <sys:Double x:Key="ControlMinWidthXLarge" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ControlMinWidthXLarge}</sys:Double>

    <!-- ========== 间距系统 ========== -->
    
    <!-- 间距 - 超小 -->
    <sys:Double x:Key="SpacingXSmall" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.SpacingXSmall}</sys:Double>

    <!-- 间距 - 极小 -->
    <sys:Double x:Key="SpacingXXSmall" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.SpacingXXSmall}</sys:Double>
    
    <!-- 间距 - 小 -->
    <sys:Double x:Key="SpacingSmall" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.SpacingSmall}</sys:Double>
    
    <!-- 间距 - 中 -->
    <sys:Double x:Key="SpacingMedium" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.SpacingMedium}</sys:Double>
    
    <!-- 间距 - 大 -->
    <sys:Double x:Key="SpacingLarge" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.SpacingLarge}</sys:Double>
    
    <!-- 间距 - 超大 -->
    <sys:Double x:Key="SpacingXLarge" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.SpacingXLarge}</sys:Double>

    <!-- ========== 内边距系统 ========== -->
    
    <!-- 内边距 - 紧凑 -->
    <sys:Double x:Key="PaddingCompact" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.PaddingCompact}</sys:Double>
    
    <!-- 内边距 - 标准 -->
    <sys:Double x:Key="PaddingStandard" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.PaddingStandard}</sys:Double>
    
    <!-- 内边距 - 宽松 -->
    <sys:Double x:Key="PaddingLoose" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.PaddingLoose}</sys:Double>
    
    <!-- 内边距 - 超宽松 -->
    <sys:Double x:Key="PaddingXLoose" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.PaddingXLoose}</sys:Double>
    
    <!-- 按钮内边距 - 水平12px，垂直4px -->
    <Thickness x:Key="ButtonPadding">{x:Static constants:LayoutConstants.ButtonPadding}</Thickness>
    
    <!-- 卡片内边距 - 水平8px，垂直4px -->
    <Thickness x:Key="CardPadding">{x:Static constants:LayoutConstants.CardPadding}</Thickness>
    
    <!-- 左边距 - 极小（2px） -->
    <Thickness x:Key="MarginLeftXXSmall">{x:Static constants:LayoutConstants.MarginLeftXXSmall}</Thickness>
    
    <!-- 上边距 - 极小（2px） -->
    <Thickness x:Key="MarginTopXXSmall">{x:Static constants:LayoutConstants.MarginTopXXSmall}</Thickness>
    
    <!-- 垂直内边距 - 极小（上下各2px） -->
    <Thickness x:Key="PaddingVerticalXXSmall">{x:Static constants:LayoutConstants.PaddingVerticalXXSmall}</Thickness>

    <!-- ========== 边距系统（Thickness） ========== -->

    <!-- 左边距 - 小（4px） -->
    <Thickness x:Key="MarginLeftXSmall">{x:Static constants:LayoutConstants.MarginLeftXSmall}</Thickness>

    <!-- 左边距 - 标准（8px） -->
    <Thickness x:Key="MarginLeftSmall">{x:Static constants:LayoutConstants.MarginLeftSmall}</Thickness>

    <!-- 右边距 - 标准（8px） -->
    <Thickness x:Key="MarginRightSmall">{x:Static constants:LayoutConstants.MarginRightSmall}</Thickness>

    <!-- 右边距 - 中（12px） -->
    <Thickness x:Key="MarginRightMedium">{x:Static constants:LayoutConstants.MarginRightMedium}</Thickness>

    <!-- 上边距 - 小（4px） -->
    <Thickness x:Key="MarginTopXSmall">{x:Static constants:LayoutConstants.MarginTopXSmall}</Thickness>

    <!-- 上边距 - 中（12px） -->
    <Thickness x:Key="MarginTopMedium">{x:Static constants:LayoutConstants.MarginTopMedium}</Thickness>

    <!-- 下边距 - 标准（8px） -->
    <Thickness x:Key="MarginBottomSmall">{x:Static constants:LayoutConstants.MarginBottomSmall}</Thickness>

    <!-- ========== 内边距系统（Thickness） ========== -->

    <!-- 水平内边距 - 标准（左右各8px） -->
    <Thickness x:Key="PaddingHorizontalStandard">{x:Static constants:LayoutConstants.PaddingHorizontalStandard}</Thickness>

    <!-- 水平内边距 - 小（左右各8px） -->
    <Thickness x:Key="PaddingHorizontalSmall">{x:Static constants:LayoutConstants.PaddingHorizontalSmall}</Thickness>

    <!-- 标题内边距 - 水平12px，垂直4px -->
    <Thickness x:Key="TitlePadding">{x:Static constants:LayoutConstants.TitlePadding}</Thickness>

    <!-- 分组内边距 - 水平16px，垂直4px -->
    <Thickness x:Key="GroupPadding">{x:Static constants:LayoutConstants.GroupPadding}</Thickness>

    <!-- 列表项内边距 - 水平8px，垂直4px -->
    <Thickness x:Key="ListItemPadding">{x:Static constants:LayoutConstants.ListItemPadding}</Thickness>

    <!-- 内容区域内边距 - 左右12px，上4px，下12px -->
    <Thickness x:Key="ContentAreaPadding">{x:Static constants:LayoutConstants.ContentAreaPadding}</Thickness>

    <!-- ========== 特殊边框系统 ========== -->

    <!-- 边框厚度 - 左右下有边框 -->
    <Thickness x:Key="BorderLeftRightBottom">{x:Static constants:LayoutConstants.BorderLeftRightBottom}</Thickness>

    <!-- 边框厚度 - 仅下边框 -->
    <Thickness x:Key="BorderBottomOnly">{x:Static constants:LayoutConstants.BorderBottomOnly}</Thickness>

    <!-- ========== 特殊圆角系统 ========== -->

    <!-- 圆角 - 右侧圆角 -->
    <CornerRadius x:Key="CornerRadiusRight">{x:Static constants:LayoutConstants.CornerRadiusRight}</CornerRadius>

    <!-- ========== 圆角系统 ========== -->
    
    <!-- 圆角 - 小 -->
    <CornerRadius x:Key="CornerRadiusSmall">{x:Static constants:LayoutConstants.CornerRadiusSmall}</CornerRadius>
    
    <!-- 圆角 - 中 -->
    <CornerRadius x:Key="CornerRadiusMedium">{x:Static constants:LayoutConstants.CornerRadiusMedium}</CornerRadius>
    
    <!-- 圆角 - 大 -->
    <CornerRadius x:Key="CornerRadiusLarge">{x:Static constants:LayoutConstants.CornerRadiusLarge}</CornerRadius>

    <!-- ========== 边框宽度系统 ========== -->
    
    <!-- 边框宽度 - 细 -->
    <sys:Double x:Key="BorderThicknessThin" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.BorderThicknessThin}</sys:Double>
    
    <!-- 边框宽度 - 标准 -->
    <sys:Double x:Key="BorderThicknessStandard" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.BorderThicknessStandard}</sys:Double>
    
    <!-- 边框宽度 - 粗 -->
    <sys:Double x:Key="BorderThicknessThick" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.BorderThicknessThick}</sys:Double>

    <!-- ========== 图标尺寸系统 ========== -->
    
    <!-- 图标尺寸 - 小 -->
    <sys:Double x:Key="IconSizeSmall" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.IconSizeSmall}</sys:Double>
    
    <!-- 图标尺寸 - 中 -->
    <sys:Double x:Key="IconSizeMedium" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.IconSizeMedium}</sys:Double>
    
    <!-- 图标尺寸 - 大 -->
    <sys:Double x:Key="IconSizeLarge" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.IconSizeLarge}</sys:Double>
    
    <!-- 图标尺寸 - 超大 -->
    <sys:Double x:Key="IconSizeXLarge" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.IconSizeXLarge}</sys:Double>

    <!-- ========== 按钮图标尺寸系统 ========== -->

    <!-- 按钮图标尺寸 -->
    <sys:Double x:Key="ButtonIconSize" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ButtonIconSize}</sys:Double>

    <!-- 按钮图标尺寸 - 小 -->
    <sys:Double x:Key="ButtonIconSizeSmall" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ButtonIconSizeSmall}</sys:Double>

    <!-- ========== 缩略图尺寸系统 ========== -->

    <!-- 缩略图宽度 - 大 -->
    <sys:Double x:Key="ThumbnailWidthLarge" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ThumbnailWidthLarge}</sys:Double>

    <!-- 缩略图高度 - 中 -->
    <sys:Double x:Key="ThumbnailHeightMedium" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ThumbnailHeightMedium}</sys:Double>

    <!-- ========== 弹出面板尺寸系统 ========== -->

    <!-- 弹出面板最大高度 -->
    <sys:Double x:Key="PopupMaxHeight" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.PopupMaxHeight}</sys:Double>

    <!-- 列表最大高度 -->
    <sys:Double x:Key="ListMaxHeight" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                >{x:Static constants:LayoutConstants.ListMaxHeight}</sys:Double>

</ResourceDictionary>
