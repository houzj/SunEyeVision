<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls"
                    xmlns:converters="clr-namespace:SunEyeVision.Plugin.SDK.UI.Converters"
                    xmlns:metadata="clr-namespace:SunEyeVision.Plugin.SDK.Metadata"
                    xmlns:themes="clr-namespace:SunEyeVision.Plugin.SDK.UI.Themes">

    <!-- 转换器 -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    <converters:BindingTypeToBoolConverter x:Key="BindingTypeToBoolConverter"/>
    <converters:BindingTypeToVisibilityConverter x:Key="BindingTypeToVisibilityConverter"/>
    <converters:DataTypeToVisibilityConverter x:Key="DataTypeToVisibilityConverter"/>
    <converters:UIntToColorConverter x:Key="UIntToColorConverter"/>
    <converters:ColorToRgbStringConverter x:Key="ColorToRgbStringConverter"/>
    <converters:UIntToBrushConverter x:Key="UIntToBrushConverter"/>

    <!-- 效果定义 -->
    <DropShadowEffect x:Key="PopupShadowEffect" Color="Black" BlurRadius="6" ShadowDepth="2" Direction="270" Opacity="0.15"/>

    <!-- 颜色定义 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#1890FF"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#40A9FF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#D9D9D9"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PanelHoverBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="LabelBrush" Color="#333333"/>
    <SolidColorBrush x:Key="LabelSecondaryBrush" Color="#666666"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF4D4F"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#52C41A"/>

    <!-- 展开图标 Path -->
    <PathGeometry x:Key="TreeExpanderPath"
                  Figures="M 0 0 L 6 4 L 0 8 Z"/>

    <!-- 基础样式：输入控件 -->
    <Style x:Key="BaseInputStyle" TargetType="Control">
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- 标签样式 -->
    <Style x:Key="LabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource LabelBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <!-- 次要标签样式 -->
    <Style x:Key="LabelSecondaryStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource LabelSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,4,0,4"/>
    </Style>

    <!-- ParamComboBox 样式 - 水平布局 -->
    <Style TargetType="{x:Type controls:ParamComboBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ParamComboBox}">
                    <Border Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,6"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 标签 -->
                            <TextBlock Grid.Column="0"
                                       Text="{TemplateBinding Label}"
                                       Style="{StaticResource LabelStyle}"
                                       MinWidth="60"
                                       Margin="0,0,12,0"/>
                            
                            <!-- 下拉框 -->
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{TemplateBinding ItemsSource}"
                                      SelectedItem="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      SelectedIndex="{Binding SelectedIndex, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      SelectedValue="{Binding SelectedValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      SelectedValuePath="{TemplateBinding SelectedValuePath}"
                                      DisplayMemberPath="{TemplateBinding DisplayMemberPath}"
                                      IsEditable="{TemplateBinding IsEditable}"
                                      Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Height="28"
                                      VerticalContentAlignment="Center"
                                      HorizontalAlignment="Stretch"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ParamTextBox 样式 -->
    <Style TargetType="{x:Type controls:ParamTextBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ParamTextBox}">
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{TemplateBinding Label}" 
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="{TemplateBinding MaxLength}"
                                 AcceptsReturn="{TemplateBinding AcceptsReturn}"
                                 TextWrapping="{TemplateBinding TextWrapping}"
                                 VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                 HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"
                                 IsReadOnly="{TemplateBinding IsReadOnly}"
                                 Style="{StaticResource BaseInputStyle}"
                                 Height="{TemplateBinding Height}"
                                 MinHeight="32"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- LabeledControl 样式 -->
    <Style TargetType="{x:Type controls:LabeledControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:LabeledControl}">
                    <Grid Margin="0,0,0,12">
                        <!-- 水平布局（默认） -->
                        <Grid x:Name="HorizontalLayout">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding LabelWidth, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 标签 -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                                <TextBlock Text="{TemplateBinding Label}"
                                           VerticalAlignment="{Binding LabelVerticalAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                           Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="*" Foreground="{StaticResource ErrorBrush}"
                                           Visibility="Visible"
                                           Margin="2,0,0,0"
                                           VerticalAlignment="{Binding LabelVerticalAlignment, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </StackPanel>
                            
                            <!-- 内容 -->
                            <ContentPresenter Grid.Column="1" 
                                              VerticalAlignment="{Binding ContentVerticalAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                              HorizontalAlignment="{Binding ContentHorizontalAlignment, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Grid>
                        
                        <!-- 垂直布局 -->
                        <StackPanel x:Name="VerticalLayout" Visibility="Collapsed">
                            <!-- 标签行 -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{TemplateBinding Label}"
                                           VerticalAlignment="{Binding LabelVerticalAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                           Style="{StaticResource LabelStyle}"/>
                                <TextBlock Grid.Column="1" Text="*" Foreground="{StaticResource ErrorBrush}"
                                           Visibility="Visible"
                                           Margin="2,0,0,0"
                                           VerticalAlignment="{Binding LabelVerticalAlignment, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Grid>
                            
                            <!-- 内容 -->
                            <ContentPresenter VerticalAlignment="{Binding ContentVerticalAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                              HorizontalAlignment="{Binding ContentHorizontalAlignment, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </StackPanel>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter TargetName="HorizontalLayout" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="VerticalLayout" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

        <!-- ConfigSetting 样式 - 组合模式：嵌入ParamBinding -->
    <Style TargetType="{x:Type controls:ConfigSetting}">
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ConfigSetting}">
                    <!-- 常量模式和绑定模式切换 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="60"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 常量模式编辑器 - 根据数据类型显示不同编辑器 -->
                        <Grid Grid.Column="0">
                            <!-- 数值编辑器（Int/Double 共用） -->
                            <controls:NumericUpDown x:Name="PART_NumericEditor"
                                                    Value="{Binding InternalNumericValue, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                                    Minimum="{Binding InternalNumericMinimum, RelativeSource={RelativeSource TemplatedParent}}"
                                                    Maximum="{Binding InternalNumericMaximum, RelativeSource={RelativeSource TemplatedParent}}"
                                                    SmallChange="{TemplateBinding SmallChange}"
                                                    LargeChange="{TemplateBinding LargeChange}"
                                                    DecimalPlaces="{TemplateBinding DecimalPlaces}"
                                                    ShowSlider="{TemplateBinding ShowSlider}"
                                                    ShowUpDownButtons="True"
                                                    Height="28"
                                                    Visibility="{Binding NumericEditorVisibility, RelativeSource={RelativeSource TemplatedParent}}"/>

                            <!-- String 编辑器 -->
                            <TextBox x:Name="PART_StringTextBox"
                                     Style="{StaticResource BaseInputStyle}"
                                     TextAlignment="Left"
                                     Height="28"
                                     Visibility="{Binding StringTextBoxVisibility, RelativeSource={RelativeSource TemplatedParent}}"/>

                            <!-- Bool 编辑器 -->
                            <CheckBox x:Name="PART_BoolCheckBox"
                                      VerticalAlignment="Center"
                                      Height="28"
                                      Visibility="{Binding BoolCheckBoxVisibility, RelativeSource={RelativeSource TemplatedParent}}"/>

                            <!-- 绑定模式 - 嵌入ParamBinding控件 -->
                            <controls:ParamBinding x:Name="PART_ParamBinding"
                                                AvailableDataSources="{Binding AvailableDataSources, RelativeSource={RelativeSource TemplatedParent}}"
                                                DataType="{Binding DataType, RelativeSource={RelativeSource TemplatedParent}}"
                                                HorizontalAlignment="Stretch"
                                                Visibility="{Binding ParamBindingVisibility, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Grid>

                        <!-- 模式切换按钮 -->
                        <Button x:Name="PART_BindingModeButton"
                                Grid.Column="1"
                                Content="⚡"
                                Width="28" Height="28"
                                FontSize="14"
                                Background="{StaticResource BackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Cursor="Hand"
                                ToolTip="点击切换到绑定模式"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

<!-- ImageSourceSelector 样式 - 水平布局 -->
    <Style TargetType="{x:Type controls:ImageSourceSelector}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ImageSourceSelector}">
                    <!-- 核心功能：按钮 + Popup下拉列表 -->
                    <Grid>
                        <!-- 选择器按钮 -->
                        <Button x:Name="PART_SelectorButton"
                                Width="{TemplateBinding SelectorWidth}"
                                Height="28"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Background="White"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding SelectedDataSource.FullTreeName, RelativeSource={RelativeSource TemplatedParent}}"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource LabelBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedDataSource, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                        <Setter Property="Text" Value="{Binding PlaceholderText, RelativeSource={RelativeSource TemplatedParent}}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource LabelSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1"
                                               Text="▼"
                                               FontSize="10"
                                               Foreground="{StaticResource LabelSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </Button>

                            <!-- 下拉弹出面板 -->
                            <Popup x:Name="PART_Popup"
                                   PlacementTarget="{Binding ElementName=PART_SelectorButton}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   Width="{Binding ActualWidth, ElementName=PART_SelectorButton}"
                                   MaxHeight="300"
                                   AllowsTransparency="True">
                                <Border Background="White"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,2,0,0"
                                        Padding="0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 标题栏 -->
                                        <Border Grid.Row="0"
                                                Background="{StaticResource BackgroundBrush}"
                                                Padding="12,8">
                                            <TextBlock Text="选择图像源"
                                                       FontWeight="Medium"
                                                       FontSize="12"
                                                       Foreground="{StaticResource LabelBrush}"/>
                                        </Border>

                                        <!-- 图像源列表 -->
                                        <ListBox x:Name="PART_ImageSourceList"
                                                 Grid.Row="1"
                                                 ItemsSource="{Binding AvailableDataSources, RelativeSource={RelativeSource TemplatedParent}}"
                                                 SelectedItem="{Binding SelectedDataSource, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWayToSource}"
                                                 BorderThickness="0"
                                                 MaxHeight="250"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DropdownDisplayText}"
                                                               Margin="8,6"
                                                               FontWeight="Medium"
                                                               FontSize="13"
                                                               Foreground="{StaticResource LabelBrush}"
                                                               VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <!-- 默认隐藏所有项 -->
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <!-- 图像类型的数据源显示 -->
                                                        <DataTrigger Binding="{Binding PropertyType.Name}" Value="Mat">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F0F7FF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#E6F7FF"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ParamGroup 样式 -->
    <Style TargetType="{x:Type controls:ParamGroup}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ParamGroup}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="0">
                        <Expander IsExpanded="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                  BorderThickness="0">
                            <Expander.Header>
                                <TextBlock Text="{TemplateBinding Header}"
                                           FontWeight="Medium"
                                           FontSize="13"/>
                            </Expander.Header>
                            <ContentPresenter Margin="12,8,12,12"/>
                        </Expander>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tab样式 -->
    <Style TargetType="TabControl">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid>
                        <Border Name="Border"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="Transparent"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                Margin="0">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="Border" Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False">
                            <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource LabelSecondaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#F5F5F5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NumericUpDown 样式 - Popup优化版 -->
    <!-- Slider统一样式（用于NumericUpDown的滑块） -->
    <Style x:Key="SliderStyle" TargetType="{x:Type Slider}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider}">
                    <Grid Height="22" VerticalAlignment="Center">
                        <Border x:Name="TrackBackground" Height="4" Background="#E0E0E0" CornerRadius="2" VerticalAlignment="Center"/>
                        <Border x:Name="TrackSelection" Height="4" Background="{StaticResource PrimaryBrush}" CornerRadius="2" VerticalAlignment="Center"/>
                        <Track x:Name="PART_Track" VerticalAlignment="Center">
                            <Track.Thumb>
                                <Thumb Width="14" Height="20" Background="White" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2" Cursor="Hand">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NumericUpDown}">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NumericUpDown}">
                    <Grid>
                        <!-- 文本框 + 上下按钮（高度固定，不再变化） -->
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 文本框 -->
                                <TextBox x:Name="PART_TextBox"
                                         Grid.Column="0"
                                         BorderThickness="0"
                                         Padding="8,0"
                                         FontSize="{TemplateBinding FontSize}"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         TextAlignment="Right"
                                         IsReadOnly="{TemplateBinding IsReadOnly}"
                                         Background="Transparent"/>

                                <!-- 上下按钮 -->
                                <Border Grid.Column="1"
                                        Background="{StaticResource BackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1,0,1,1"
                                        CornerRadius="0,4,4,0"
                                        Visibility="{TemplateBinding ShowUpDownButtons, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Orientation="Vertical">
                                        <RepeatButton x:Name="PART_IncreaseButton"
                                                      Content="▲"
                                                      Width="18" Height="13"
                                                      FontSize="8"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Padding="0"
                                                      Cursor="Hand"/>
                                        <RepeatButton x:Name="PART_DecreaseButton"
                                                      Content="▼"
                                                      Width="18" Height="13"
                                                      FontSize="8"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Padding="0"
                                                      Cursor="Hand"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                        
                        <!-- Popup滑块（独立悬浮层，不影响布局） -->
                        <Popup x:Name="PART_SliderPopup"
                               Placement="Bottom"
                               StaysOpen="True"
                               AllowsTransparency="True"
                               PopupAnimation="Slide">
                            <Border Background="White"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,2,0,0">
                                <Slider x:Name="PART_Slider"
                                        Style="{StaticResource SliderStyle}"
                                        Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                        Minimum="{TemplateBinding Minimum}"
                                        Maximum="{TemplateBinding Maximum}"
                                        SmallChange="{TemplateBinding SmallChange}"
                                        LargeChange="{TemplateBinding LargeChange}"
                                        Width="220"/>
                            </Border>
                        </Popup>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ToggleSwitch 样式 - 简洁专业版 -->
    <Style TargetType="{x:Type controls:ToggleSwitch}">
        <Setter Property="SwitchWidth" Value="42"/>
        <Setter Property="SwitchHeight" Value="22"/>
        <Setter Property="CornerRadius" Value="11"/>
        <Setter Property="OnBackground" Value="#FF7F00"/>
        <Setter Property="OffBackground" Value="#D9D9D9"/>
        <Setter Property="ThumbColor" Value="White"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToggleSwitch}">
                    <Border x:Name="SwitchBorder"
                            Background="{TemplateBinding OffBackground}"
                            BorderBrush="{TemplateBinding OffBackground}"
                            BorderThickness="1"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Width="{TemplateBinding SwitchWidth}"
                            Height="{TemplateBinding SwitchHeight}">
                        <Grid>
                            <!-- 滑块 -->
                            <Border x:Name="ThumbBorder"
                                    Background="{TemplateBinding ThumbColor}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Width="{Binding SwitchHeight, RelativeSource={RelativeSource TemplatedParent}}"
                                    Height="{Binding SwitchHeight, RelativeSource={RelativeSource TemplatedParent}}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="1,0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- 开启状态 -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SwitchBorder" Property="Background" 
                                    Value="{Binding OnBackground, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="SwitchBorder" Property="BorderBrush" 
                                    Value="{Binding OnBackground, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="ThumbBorder" Property="HorizontalAlignment" Value="Right"/>
                        </Trigger>
                        <!-- 禁用状态 -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="SwitchBorder" Property="Opacity" Value="0.5"/>
                        </Trigger>
                        <!-- 深色主题 - 关闭状态 -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsDarkTheme" Value="True"/>
                                <Condition Property="IsChecked" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SwitchBorder" Property="Background" Value="#555555"/>
                            <Setter TargetName="SwitchBorder" Property="BorderBrush" Value="#555555"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- RangeSlider 样式 -->
    <Style TargetType="{x:Type controls:RangeSlider}">
        <Setter Property="Height" Value="22"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RangeSlider}">
                    <!-- 使用 Canvas 支持滑块绝对定位 -->
                    <Canvas x:Name="PART_Canvas"
                            Height="22"
                            VerticalAlignment="Center">
                        
                        <!-- 轨道 -->
                        <Border x:Name="PART_Track"
                                Canvas.Top="9"
                                Height="4"
                                Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                Background="#E0E0E0"
                                CornerRadius="2"/>

                        <!-- 选中范围填充 -->
                        <Border x:Name="PART_RangeFill"
                                Canvas.Top="9"
                                Height="4"
                                Background="{StaticResource PrimaryBrush}"
                                CornerRadius="2"/>

                        <!-- 最小值滑块 -->
                        <Thumb x:Name="PART_MinThumb"
                               Canvas.Top="1"
                               Width="14"
                               Height="20"
                               Background="White"
                               BorderBrush="{StaticResource PrimaryBrush}"
                               BorderThickness="2"
                               Cursor="Hand">
                            <Thumb.Style>
                                <Style TargetType="Thumb">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Thumb.Style>
                        </Thumb>

                        <!-- 最大值滑块 -->
                        <Thumb x:Name="PART_MaxThumb"
                               Canvas.Top="1"
                               Width="14"
                               Height="20"
                               Background="White"
                               BorderBrush="{StaticResource PrimaryBrush}"
                               BorderThickness="2"
                               Cursor="Hand">
                            <Thumb.Style>
                                <Style TargetType="Thumb">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Thumb.Style>
                        </Thumb>
                    </Canvas>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- RangeInputControl 样式 - Popup优化版 -->
    <Style TargetType="{x:Type controls:RangeInputControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RangeInputControl}">
                    <Grid>
                        <!-- 数值输入行（高度固定，不再变化） -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 最小值输入 -->
                            <controls:NumericUpDown x:Name="PART_MinNumeric"
                                                    Grid.Column="0"
                                                    Width="{TemplateBinding NumericWidth}"
                                                    Value="{Binding MinValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                    Minimum="{TemplateBinding Minimum}"
                                                    Maximum="{TemplateBinding Maximum}"
                                                    SmallChange="{TemplateBinding SmallChange}"
                                                    LargeChange="{TemplateBinding LargeChange}"
                                                    DecimalPlaces="{TemplateBinding DecimalPlaces}"
                                                    ShowSlider="False"
                                                    ShowUpDownButtons="True"/>

                            <!-- 分隔符 -->
                            <TextBlock Grid.Column="1"
                                       Text="-"
                                       Margin="4,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource LabelSecondaryBrush}"/>

                            <!-- 最大值输入 -->
                            <controls:NumericUpDown x:Name="PART_MaxNumeric"
                                                    Grid.Column="2"
                                                    Width="{TemplateBinding NumericWidth}"
                                                    Value="{Binding MaxValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                    Minimum="{TemplateBinding Minimum}"
                                                    Maximum="{TemplateBinding Maximum}"
                                                    SmallChange="{TemplateBinding SmallChange}"
                                                    LargeChange="{TemplateBinding LargeChange}"
                                                    DecimalPlaces="{TemplateBinding DecimalPlaces}"
                                                    ShowSlider="False"
                                                    ShowUpDownButtons="True"/>

                            <!-- 单位 -->
                            <TextBlock Grid.Column="3"
                                       Text="{TemplateBinding Unit}"
                                       Margin="4,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource LabelSecondaryBrush}"
                                       Visibility="Visible"/>
                        </Grid>
                        
                        <!-- Popup范围滑块（独立悬浮层，不影响布局） -->
                        <Popup x:Name="PART_SliderPopup"
                               Placement="Bottom"
                               StaysOpen="True"
                               AllowsTransparency="True"
                               PopupAnimation="Slide">
                            <Border Background="White"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,2,0,0">
                                <controls:RangeSlider x:Name="PART_RangeSlider"
                                                      Minimum="{TemplateBinding Minimum}"
                                                      Maximum="{TemplateBinding Maximum}"
                                                      MinValue="{Binding MinValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                      MaxValue="{Binding MaxValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                      SmallChange="{TemplateBinding SmallChange}"
                                                      LargeChange="{TemplateBinding LargeChange}"
                                                      MinGap="{TemplateBinding MinGap}"
                                                      Width="220"/>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ColorPicker 专用的 TabControl 紧凑样式 -->
    <Style x:Key="ColorPickerTabControlStyle" TargetType="TabControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Tab 标题区域 -->
                        <TabPanel Grid.Row="0" 
                                  IsItemsHost="True"
                                  Margin="0,0,0,0"
                                  Background="Transparent"/>
                        
                        <!-- Tab 内容区域 -->
                        <ContentPresenter Grid.Row="1"
                                          ContentSource="SelectedContent"
                                          Margin="0,6,0,0"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ColorPicker 专用的 TabItem 紧凑样式 -->
    <Style x:Key="ColorPickerTabItemStyle" TargetType="TabItem">
        <Setter Property="Padding" Value="12,4,12,4"/>
        <Setter Property="Margin" Value="0,0,2,0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid>
                        <Border x:Name="Border"
                                Background="{StaticResource PanelBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2,2,0,0">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush"
                                    Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background"
                                    Value="{StaticResource PanelHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ColorPicker 内部的颜色按钮样式 - 蓝色边框悬浮效果 -->
    <Style x:Key="ColorPickerButtonStyle" TargetType="Button">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Padding="{TemplateBinding Padding}"
                            Margin="{TemplateBinding Margin}"
                            SnapsToDevicePixels="True"/>
                    <ControlTemplate.Triggers>
                        <!-- 悬浮时显示明显的蓝色边框 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="Border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Direction="315" Opacity="0.3"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="Focusable" Value="False"/>
    </Style>

    <!-- ColorPicker 样式 -->
    <Style TargetType="{x:Type controls:ColorPicker}">
        <Setter Property="Width" Value="220"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ColorPicker}">
                    <Border Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="0">
                        <Grid>
                            <!-- 选项卡 -->
                            <TabControl x:Name="PART_TabControl">
                                <!-- 默认选项卡 -->
                                <TabItem Header="默认">
                                    <StackPanel Margin="10,12,10,0" HorizontalAlignment="Center">
                                        <!-- 主题颜色 -->
                                        <TextBlock Text="主题颜色"
                                                   FontSize="12"
                                                   Foreground="{StaticResource LabelSecondaryBrush}"
                                                   Margin="0,0,0,8"
                                                   TextAlignment="Center"
                                                   Width="198"/>
                                        <UniformGrid x:Name="PART_ThemeColorsPanel"
                                                     Columns="10"
                                                     Rows="6"
                                                     Width="198"
                                                     Height="112"/>
                                        
                                        <!-- 标准颜色 -->
                                        <TextBlock Text="标准颜色"
                                                   FontSize="12"
                                                   Foreground="{StaticResource LabelSecondaryBrush}"
                                                   Margin="0,12,0,8"
                                                   TextAlignment="Center"
                                                   Width="198"/>
                                        <UniformGrid x:Name="PART_StandardColorsPanel"
                                                     Columns="10"
                                                     Rows="1"
                                                     Width="198"
                                                     Height="18"/>
                                    </StackPanel>
                                </TabItem>

                                <!-- 更多选项卡 -->
                                <TabItem Header="更多">
                                    <Grid Margin="10,12,10,0" HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 左侧：HSV 颜色选择面板 -->
                                        <Canvas x:Name="PART_HsvCanvas"
                                                Grid.Column="0"
                                                Width="140"
                                                Height="140"
                                                Cursor="Cross"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Top">
                                            <!-- 色相渐变背景（水平） -->
                                            <Canvas.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="Red" Offset="0.0"/>
                                                    <GradientStop Color="Yellow" Offset="0.166"/>
                                                    <GradientStop Color="Lime" Offset="0.333"/>
                                                    <GradientStop Color="Cyan" Offset="0.5"/>
                                                    <GradientStop Color="Blue" Offset="0.666"/>
                                                    <GradientStop Color="Magenta" Offset="0.833"/>
                                                    <GradientStop Color="Red" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Canvas.Background>
                                            
                                            <!-- 明度渐变覆盖层（垂直） -->
                                            <Rectangle Width="140" Height="140">
                                                <Rectangle.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="White" Offset="0.0"/>
                                                        <GradientStop Color="Transparent" Offset="0.5"/>
                                                        <GradientStop Color="Black" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>
                                            
                                            <!-- 圆形选择器 -->
                                            <Ellipse x:Name="PART_HsvSelector"
                                                     Width="14"
                                                     Height="14"
                                                     Stroke="White"
                                                     StrokeThickness="2"
                                                     Fill="Transparent"/>
                                        </Canvas>
                                        
                                        <!-- 右侧：垂直亮度滑块 -->
                                        <Grid Grid.Column="1"
                                              Width="36"
                                              Height="140"
                                              VerticalAlignment="Top">
                                            <Slider x:Name="PART_ValueSlider"
                                                    Orientation="Vertical"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    Value="1"
                                                    SmallChange="0.01"
                                                    LargeChange="0.1"
                                                    HorizontalAlignment="Center"/>
                                            
                                            <!-- 亮度值显示 -->
                                            <TextBlock x:Name="PART_ValueText"
                                                       Text="1.00"
                                                       FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"
                                                       VerticalAlignment="Bottom"/>
                                        </Grid>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ColorSelector 样式 -->
    <Style TargetType="{x:Type controls:ColorSelector}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ColorSelector}">
                    <!-- 移除外层Border和Label，只保留核心功能 -->
                    <Grid>
                        <!-- 触发器 Border（可获取焦点） -->
                        <Border x:Name="PART_SelectorBorder"
                                Height="28"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Focusable="True"
                                    Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- 颜色预览方块 -->
                                    <Border x:Name="PART_ColorPreview"
                                            Grid.Column="0"
                                            Width="24" Height="24"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Margin="4,0,8,0"/>
                                    
                                    <!-- RGB 文本显示 -->
                                    <TextBlock x:Name="PART_RgbText"
                                               Grid.Column="1"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               Foreground="{StaticResource LabelBrush}"
                                               Padding="0,0,4,0"/>
                                </Grid>
                            </Border>

                            <!-- 颜色选择器弹出 -->
                            <Popup x:Name="PART_ColorPickerPopup"
                                   PlacementTarget="{Binding ElementName=PART_SelectorBorder}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="White"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,6,0,0"
                                        Padding="0"
                                        Effect="{StaticResource PopupShadowEffect}">
                                    <controls:ColorPicker x:Name="PART_ColorPicker"
                                                          SelectedColor="{Binding SelectedColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
                                </Border>
                            </Popup>
                    </Grid>

                    <!-- 视觉反馈触发器 -->
                    <ControlTemplate.Triggers>
                        <!-- 鼠标悬停 -->
                        <Trigger SourceName="PART_SelectorBorder" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_SelectorBorder" Property="BorderBrush"
                                    Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                        
                        <!-- 焦点状态 -->
                        <Trigger SourceName="PART_SelectorBorder" Property="IsFocused" Value="True">
                            <Setter TargetName="PART_SelectorBorder" Property="BorderBrush"
                                    Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="PART_SelectorBorder" Property="BorderThickness"
                                    Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DispItemColorControl 样式 -->
    <Style TargetType="{x:Type controls:DispItemColorControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:DispItemColorControl}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="{Binding ContentHorizontalAlignment, RelativeSource={RelativeSource TemplatedParent}}">
                        <!-- 小眼睛按钮（可见性控制） -->
                        <Button x:Name="PART_VisibilityButton"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="切换显示/隐藏"
                                Margin="0,0,4,0"
                                Tag="{Binding Config.IsVisible, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=True}">
                            <Viewbox Width="18" Height="18" Stretch="Uniform">
                                <Path x:Name="PART_VisibilityIcon"
                                      Stroke="Black"
                                      StrokeThickness="1.2"
                                      Fill="Transparent"
                                      Data="M2 10C4 6 7 4 10 4C13 4 16 6 18 10C16 14 13 16 10 16C7 16 4 14 2 10ZM10 13C11.7 13 13 11.7 13 10C13 8.3 11.7 7 10 7C8.3 7 7 8.3 7 10C7 11.7 8.3 13 10 13Z"/>
                            </Viewbox>
                        </Button>

                        <!-- 画笔按钮（样式设置） -->
                        <Button x:Name="PART_StyleSettingsButton"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="样式设置"
                                Margin="0">
                            <TextBlock Text="🖌️" 
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>

                        <!-- 样式设置Popup -->
                        <Popup x:Name="PART_StyleSettingsPopup"
                               PlacementTarget="{Binding ElementName=PART_StyleSettingsButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="White"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="16"
                                    Margin="0,2,0,0"
                                    Width="260">
                                <StackPanel>
                                    <!-- OK颜色 -->
                                    <TextBlock Text="OK颜色"
                                               Style="{StaticResource LabelStyle}"
                                               Margin="0,0,0,6"/>
                                    <controls:ColorSelector 
                                        Width="224"
                                        Height="28"
                                        SelectedColor="{Binding Config.OkColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                        Margin="0,0,0,12"/>

                                    <!-- NG颜色 -->
                                    <TextBlock Text="NG颜色"
                                               Style="{StaticResource LabelStyle}"
                                               Margin="0,0,0,6"/>
                                    <controls:ColorSelector 
                                        Width="224"
                                        Height="28"
                                        SelectedColor="{Binding Config.NgColor, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                        Margin="0,0,0,12"/>

                                    <!-- 透明度 -->
                                    <TextBlock Text="透明度"
                                               Style="{StaticResource LabelStyle}"
                                               Margin="0,0,0,6"/>
                                    <controls:NumericUpDown 
                                        Width="224"
                                        Value="{Binding Config.Opacity, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                        Minimum="0"
                                        Maximum="1"
                                        DecimalPlaces="2"
                                        ShowSlider="True"
                                        Margin="0,0,0,12"/>

                                    <!-- 线条粗细 -->
                                    <TextBlock Text="线条粗细"
                                               Style="{StaticResource LabelStyle}"
                                               Margin="0,0,0,6"/>
                                    <controls:NumericUpDown 
                                        Width="224"
                                        Value="{Binding Config.Thickness, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                        Minimum="0.5"
                                        Maximum="10"
                                        DecimalPlaces="1"
                                        ShowSlider="True"
                                        Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <!-- 根据IsVisible状态切换眼睛图标 -->
                        <DataTrigger Binding="{Binding Tag, ElementName=PART_VisibilityButton}" Value="True">
                            <Setter TargetName="PART_VisibilityIcon" Property="Data"
                                    Value="M2 10C4 6 7 4 10 4C13 4 16 6 18 10C16 14 13 16 10 16C7 16 4 14 2 10ZM10 13C11.7 13 13 11.7 13 10C13 8.3 11.7 7 10 7C8.3 7 7 8.3 7 10C7 11.7 8.3 13 10 13Z"/>
                            <Setter TargetName="PART_VisibilityIcon" Property="Opacity" Value="1.0"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Tag, ElementName=PART_VisibilityButton}" Value="False">
                            <Setter TargetName="PART_VisibilityIcon" Property="Data"
                                    Value="M2 10C4 6 7 4 10 4C13 4 16 6 18 10C16 14 13 16 10 16C7 16 4 14 2 10ZM10 13C11.7 13 13 11.7 13 10C13 8.3 11.7 7 10 7C8.3 7 7 8.3 7 10C7 11.7 8.3 13 10 13ZM3 17L17 3"/>
                            <Setter TargetName="PART_VisibilityIcon" Property="Opacity" Value="0.5"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ParamBinding 样式 - 树形结构绑定选择 -->
    <Style TargetType="{x:Type controls:ParamBinding}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ParamBinding}">
                    <!-- 外层 Border -->
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Height="{TemplateBinding Height}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="60"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 绑定路径显示 -->
                            <Grid Grid.Column="0">
                                <TextBlock x:Name="PART_BindingDisplay"
                                           Padding="8,0"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Text="{Binding FriendlyBindingSource, RelativeSource={RelativeSource TemplatedParent}}"
                                           Foreground="{StaticResource LabelSecondaryBrush}"
                                           Visibility="Visible"/>
                            </Grid>

                            <!-- 绑定图标按钮 -->
                            <Button x:Name="PART_BindingButton"
                                    Grid.Column="1"
                                    Width="28" Height="28"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="ToolTip" Value="切到绑定模式"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBound, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                <Setter Property="ToolTip" Value="切到常量模式"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="{Binding IconSymbol, RelativeSource={RelativeSource TemplatedParent}}" 
                                           FontSize="14" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center"/>
                            </Button>

                            <!-- 绑定源选择 Popup - 树形结构 -->
                            <Popup x:Name="PART_BindingPopup"
                                   PlacementTarget="{Binding ElementName=PART_BindingButton}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   Width="300"
                                   MaxHeight="400"
                                   AllowsTransparency="True">
                                <Border Background="White"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,2,0,0"
                                        Padding="0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 标题栏 -->
                                        <Border Grid.Row="0"
                                                Background="{StaticResource BackgroundBrush}"
                                                Padding="12,8">
                                            <TextBlock Text="选择绑定源"
                                                       FontWeight="Medium"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource LabelBrush}"/>
                                        </Border>

                                        <!-- TreeView - 使用与ConfigSetting相同的树形结构 -->
                                        <TreeView x:Name="PART_BindingTreeView"
                                                  Grid.Row="1"
                                                  ItemsSource="{Binding TreeNodes, RelativeSource={RelativeSource TemplatedParent}}"
                                                  BorderThickness="0"
                                                  MaxHeight="350"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  Padding="8,4">
                                            <TreeView.ItemTemplate>
                                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                    <TextBlock Text="{Binding Text}"
                                                               FontSize="12"
                                                               Padding="2,4">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelectable}" Value="False">
                                                                        <Setter Property="FontWeight" Value="Medium"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource LabelBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSelectable}" Value="True">
                                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource LabelSecondaryBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </HierarchicalDataTemplate>
                                            </TreeView.ItemTemplate>
                                            <TreeView.ItemContainerStyle>
                                                <Style TargetType="TreeViewItem">
                                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                                    <Setter Property="Padding" Value="2,2,4,2"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="TreeViewItem">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition x:Name="ItemsHostRow" Height="*"/>
                                                                    </Grid.RowDefinitions>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                
                                                                    <!-- 展开/折叠按钮 -->
                                                                    <ToggleButton x:Name="Expander"
                                                                                  Grid.Row="0"
                                                                                  Grid.Column="0"
                                                                                  Width="20"
                                                                                  Height="20"
                                                                                  Margin="-2,0,2,0"
                                                                                  IsChecked="{Binding Path=IsExpanded, Mode=TwoWay}"
                                                                                  Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                                  IsHitTestVisible="True">
                                                                        <ToggleButton.Template>
                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                <Grid Width="20" Height="20" Background="Transparent">
                                                                                    <Path x:Name="ExpanderPath"
                                                                                          Width="10"
                                                                                          Height="10"
                                                                                          Data="M 0 0 L 8 5 L 0 10 Z"
                                                                                          Fill="{StaticResource LabelSecondaryBrush}"
                                                                                          RenderTransformOrigin="0.5,0.5"
                                                                                          HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center"
                                                                                          IsHitTestVisible="True">
                                                                                        <Path.RenderTransform>
                                                                                            <RotateTransform x:Name="ExpanderRotate" Angle="0"/>
                                                                                        </Path.RenderTransform>
                                                                                    </Path>
                                                                                </Grid>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsChecked" Value="True">
                                                                                        <Trigger.EnterActions>
                                                                                            <BeginStoryboard>
                                                                                                <Storyboard>
                                                                                                    <DoubleAnimation Storyboard.TargetName="ExpanderRotate"
                                                                                                                     Storyboard.TargetProperty="Angle"
                                                                                                                     To="90" Duration="0:0:0.15"/>
                                                                                                </Storyboard>
                                                                                            </BeginStoryboard>
                                                                                        </Trigger.EnterActions>
                                                                                        <Trigger.ExitActions>
                                                                                            <BeginStoryboard>
                                                                                                <Storyboard>
                                                                                                    <DoubleAnimation Storyboard.TargetName="ExpanderRotate"
                                                                                                                     Storyboard.TargetProperty="Angle"
                                                                                                                     To="0" Duration="0:0:0.15"/>
                                                                                                </Storyboard>
                                                                                            </BeginStoryboard>
                                                                                        </Trigger.ExitActions>
                                                                                    </Trigger>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="ExpanderPath" Property="Fill" 
                                                                                                Value="{StaticResource PrimaryBrush}"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </ToggleButton.Template>
                                                                    </ToggleButton>
                                                                
                                                                    <!-- 内容区域 -->
                                                                    <Border x:Name="ContentBorder"
                                                                            Grid.Row="0"
                                                                            Grid.Column="1"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            Padding="{TemplateBinding Padding}"
                                                                            CornerRadius="2">
                                                                        <ContentPresenter x:Name="PART_Header"
                                                                                      ContentSource="Header"
                                                                                      ContentTemplate="{TemplateBinding ItemTemplate}"/>
                                                                    </Border>
                                                                
                                                                    <!-- 子节点容器 -->
                                                                    <ItemsPresenter x:Name="ItemsHost" 
                                                                                Grid.Row="1"
                                                                                Grid.Column="0"
                                                                                Grid.ColumnSpan="2"
                                                                                Margin="20,0,0,0"/>
                                                            </Grid>
                                                            
                                                            <ControlTemplate.Triggers>
                                                                <!-- 折叠时隐藏子节点 -->
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                                    <Setter TargetName="ItemsHostRow" Property="Height" Value="0"/>
                                                                </DataTrigger>
                                                                <!-- 展开时显示子节点 -->
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                                                    <Setter TargetName="ItemsHostRow" Property="Height" Value="*"/>
                                                                </DataTrigger>
                                                                
                                                                <!-- 不可选中的节点（分组节点）禁用选择 -->
                                                                <DataTrigger Binding="{Binding IsSelectable}" Value="False">
                                                                    <Setter Property="Focusable" Value="False"/>
                                                                    <Setter Property="IsSelected" Value="False"/>
                                                                </DataTrigger>
                                                                
                                                                <!-- 鼠标悬停效果 -->
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ContentBorder" Property="Background" 
                                                                            Value="{StaticResource PanelHoverBrush}"/>
                                                                </Trigger>
                                                                
                                                                <!-- 选中效果 -->
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="ContentBorder" Property="Background" 
                                                                            Value="#191890FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TreeView.ItemContainerStyle>
                                        </TreeView>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>

                    <!-- 触发器 -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
