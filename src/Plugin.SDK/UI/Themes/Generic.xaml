<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls"
                    xmlns:converters="clr-namespace:SunEyeVision.Plugin.SDK.UI.Converters"
                    xmlns:metadata="clr-namespace:SunEyeVision.Plugin.SDK.Metadata">

    <!-- 转换器 -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <converters:BindingTypeToBoolConverter x:Key="BindingTypeToBoolConverter"/>
    <converters:BindingTypeToVisibilityConverter x:Key="BindingTypeToVisibilityConverter"/>
    <converters:DataTypeToVisibilityConverter x:Key="DataTypeToVisibilityConverter"/>

    <!-- 颜色定义 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#1890FF"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#40A9FF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#D9D9D9"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="LabelBrush" Color="#333333"/>
    <SolidColorBrush x:Key="LabelSecondaryBrush" Color="#666666"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF4D4F"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#52C41A"/>

    <!-- 基础样式：输入控件 -->
    <Style x:Key="BaseInputStyle" TargetType="Control">
        <Setter Property="Height" Value="32"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- 标签样式 -->
    <Style x:Key="LabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource LabelBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <!-- 次要标签样式 -->
    <Style x:Key="LabelSecondaryStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource LabelSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,4,0,4"/>
    </Style>

    <!-- ParamSlider 样式 -->
    <Style TargetType="{x:Type controls:ParamSlider}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ParamSlider}">
                    <StackPanel Margin="0,0,0,12">
                        <!-- 标签行 -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{TemplateBinding Label}" 
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="2" 
                                       Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:F0}}"
                                       Style="{StaticResource LabelSecondaryStyle}"
                                       FontWeight="Medium"/>
                        </Grid>
                        
                        <!-- 滑块行 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" MinWidth="60"/>
                            </Grid.ColumnDefinitions>
                            
                            <Slider Grid.Column="0"
                                    Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                    Minimum="{TemplateBinding Minimum}"
                                    Maximum="{TemplateBinding Maximum}"
                                    SmallChange="{TemplateBinding SmallChange}"
                                    LargeChange="{TemplateBinding LargeChange}"
                                    TickFrequency="{TemplateBinding TickFrequency}"
                                    IsSnapToTickEnabled="{TemplateBinding IsSnapToTickEnabled}"
                                    VerticalAlignment="Center"/>
                            
                            <TextBox Grid.Column="1"
                                     Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource BaseInputStyle}"
                                     TextAlignment="Center"
                                     Margin="8,0,0,0"
                                     Visibility="{TemplateBinding ShowTextBox, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ParamComboBox 样式 - 水平布局 -->
    <Style TargetType="{x:Type controls:ParamComboBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ParamComboBox}">
                    <Border Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,6"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 标签 -->
                            <TextBlock Grid.Column="0"
                                       Text="{TemplateBinding Label}"
                                       Style="{StaticResource LabelStyle}"
                                       MinWidth="60"
                                       Margin="0,0,12,0"/>
                            
                            <!-- 下拉框 -->
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{TemplateBinding ItemsSource}"
                                      SelectedItem="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      SelectedIndex="{Binding SelectedIndex, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      SelectedValue="{Binding SelectedValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      SelectedValuePath="{TemplateBinding SelectedValuePath}"
                                      DisplayMemberPath="{TemplateBinding DisplayMemberPath}"
                                      IsEditable="{TemplateBinding IsEditable}"
                                      Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Height="28"
                                      VerticalContentAlignment="Center"
                                      HorizontalAlignment="Stretch"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ParamTextBox 样式 -->
    <Style TargetType="{x:Type controls:ParamTextBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ParamTextBox}">
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{TemplateBinding Label}" 
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="{TemplateBinding MaxLength}"
                                 AcceptsReturn="{TemplateBinding AcceptsReturn}"
                                 TextWrapping="{TemplateBinding TextWrapping}"
                                 VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                 HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"
                                 IsReadOnly="{TemplateBinding IsReadOnly}"
                                 Style="{StaticResource BaseInputStyle}"
                                 Height="{TemplateBinding Height}"
                                 MinHeight="32"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- LabeledControl 样式 -->
    <Style TargetType="{x:Type controls:LabeledControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:LabeledControl}">
                    <StackPanel Margin="0,0,0,12">
                        <!-- 标签行 -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{TemplateBinding Label}"
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" Text="*" Foreground="{StaticResource ErrorBrush}"
                                       Visibility="{Binding Required, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Margin="2,0,0,0"/>
                        </Grid>
                        
                        <!-- 内容 -->
                        <ContentPresenter/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BindableParameter 样式 - 支持多数据类型 -->
    <Style TargetType="{x:Type controls:BindableParameter}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:BindableParameter}">
                    <Border Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,6"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="60"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 标签 -->
                            <TextBlock Grid.Column="0"
                                       Text="{TemplateBinding Label}"
                                       Style="{StaticResource LabelStyle}"
                                       MinWidth="80"
                                       ToolTip="{TemplateBinding Description}"/>

                            <!-- 数值编辑器（Int/Double 共用） - 使用 NumericUpDown -->
                            <controls:NumericUpDown x:Name="PART_NumericEditor"
                                                    Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    Value="{Binding DoubleValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                    IntValue="{Binding IntValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                    Minimum="{Binding DoubleMinimum, RelativeSource={RelativeSource TemplatedParent}}"
                                                    Maximum="{Binding DoubleMaximum, RelativeSource={RelativeSource TemplatedParent}}"
                                                    SmallChange="{TemplateBinding SmallChange}"
                                                    LargeChange="{TemplateBinding LargeChange}"
                                                    DecimalPlaces="{TemplateBinding DecimalPlaces}"
                                                    ShowSlider="{TemplateBinding ShowSlider}"
                                                    IsSliderExpanded="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                    ShowUpDownButtons="True"
                                                    Visibility="{Binding DataType, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource DataTypeToVisibilityConverter}, ConverterParameter=Numeric}"/>

                            <!-- String 编辑器 -->
                            <TextBox x:Name="PART_StringTextBox"
                                     Grid.Column="1"
                                     Text="{Binding StringValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource BaseInputStyle}"
                                     TextAlignment="Left"
                                     Margin="8,0,0,0"
                                     Visibility="{Binding DataType, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource DataTypeToVisibilityConverter}, ConverterParameter=String}"/>

                            <!-- Bool 编辑器 -->
                            <CheckBox x:Name="PART_BoolCheckBox"
                                      Grid.Column="1"
                                      IsChecked="{Binding BoolValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"
                                      Visibility="{Binding DataType, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource DataTypeToVisibilityConverter}, ConverterParameter=Bool}"/>

                            <!-- 绑定按钮 -->
                            <Button x:Name="PART_BindingButton"
                                    Grid.Column="2"
                                    Content="⚡"
                                    Width="28" Height="28"
                                    FontSize="14"
                                    Background="{StaticResource BackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    ToolTip="点击绑定到其他节点输出"
                                    Margin="4,0,0,0"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ImageSourceSelector 样式 - 水平布局 -->
    <Style TargetType="{x:Type controls:ImageSourceSelector}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ImageSourceSelector}">
                    <Border Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,6"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 标签 -->
                            <TextBlock Grid.Column="0"
                                       Text="{TemplateBinding Label}"
                                       Style="{StaticResource LabelStyle}"
                                       MinWidth="60"
                                       Margin="0,0,12,0"/>

                            <!-- 选择器按钮 -->
                            <Button x:Name="PART_SelectorButton"
                                    Grid.Column="1"
                                    Height="28"
                                    HorizontalContentAlignment="Left"
                                    VerticalContentAlignment="Center"
                                    Background="White"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    Padding="8,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding SelectedImageSource.DisplayName, RelativeSource={RelativeSource TemplatedParent}}"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource LabelBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedImageSource, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                        <Setter Property="Text" Value="{Binding PlaceholderText, RelativeSource={RelativeSource TemplatedParent}}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource LabelSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1"
                                               Text="▼"
                                               FontSize="10"
                                               Foreground="{StaticResource LabelSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </Button>

                            <!-- 下拉弹出面板 -->
                            <Popup x:Name="PART_Popup"
                                   PlacementTarget="{Binding ElementName=PART_SelectorButton}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   Width="{Binding ActualWidth, ElementName=PART_SelectorButton}"
                                   MaxHeight="300"
                                   AllowsTransparency="True">
                                <Border Background="White"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,2,0,0"
                                        Padding="0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 标题栏 -->
                                        <Border Grid.Row="0"
                                                Background="{StaticResource BackgroundBrush}"
                                                Padding="12,8">
                                            <TextBlock Text="选择图像源"
                                                       FontWeight="Medium"
                                                       FontSize="12"
                                                       Foreground="{StaticResource LabelBrush}"/>
                                        </Border>

                                        <!-- 图像源列表 -->
                                        <ListBox x:Name="PART_ImageSourceList"
                                                 Grid.Row="1"
                                                 ItemsSource="{Binding AvailableImageSources, RelativeSource={RelativeSource TemplatedParent}}"
                                                 BorderThickness="0"
                                                 MaxHeight="250"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="8,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 缩略图 -->
                                                        <Border Grid.Column="0"
                                                                Width="48" Height="36"
                                                                Background="#F5F5F5"
                                                                CornerRadius="2"
                                                                Margin="0,0,12,0">
                                                            <Image Source="{Binding Thumbnail}"
                                                                   Stretch="Uniform"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Thumbnail, Converter={x:Null}}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                        </Border>

                                                        <!-- 信息区 -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontWeight="Medium"
                                                                       FontSize="13"
                                                                       Foreground="{StaticResource LabelBrush}"/>
                                                            <TextBlock Text="{Binding SizeDescription}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource LabelSecondaryBrush}"
                                                                       Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F0F7FF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#E6F7FF"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ParamGroup 样式 -->
    <Style TargetType="{x:Type controls:ParamGroup}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ParamGroup}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="0">
                        <Expander IsExpanded="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                  BorderThickness="0">
                            <Expander.Header>
                                <TextBlock Text="{TemplateBinding Header}"
                                           FontWeight="Medium"
                                           FontSize="13"/>
                            </Expander.Header>
                            <ContentPresenter Margin="12,8,12,12"/>
                        </Expander>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tab样式 -->
    <Style TargetType="TabControl">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid>
                        <Border Name="Border"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="Transparent"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                Margin="0">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="Border" Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False">
                            <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource LabelSecondaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#F5F5F5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NumericUpDown 样式 -->
    <Style TargetType="{x:Type controls:NumericUpDown}">
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NumericUpDown}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 第一行：文本框 + 上下按钮 -->
                        <Border Grid.Row="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 文本框 -->
                                <TextBox x:Name="PART_TextBox"
                                         Grid.Column="0"
                                         BorderThickness="0"
                                         Padding="8,0"
                                         FontSize="{TemplateBinding FontSize}"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         TextAlignment="Right"
                                         IsReadOnly="{TemplateBinding IsReadOnly}"
                                         Background="Transparent"/>

                                <!-- 上下按钮 -->
                                <Border Grid.Column="1"
                                        Background="{StaticResource BackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1,0,1,1"
                                        CornerRadius="0,4,4,0"
                                        Visibility="{TemplateBinding ShowUpDownButtons, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Orientation="Vertical">
                                        <RepeatButton x:Name="PART_IncreaseButton"
                                                      Content="▲"
                                                      Width="18" Height="13"
                                                      FontSize="8"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Padding="0"
                                                      Cursor="Hand"/>
                                        <RepeatButton x:Name="PART_DecreaseButton"
                                                      Content="▼"
                                                      Width="18" Height="13"
                                                      FontSize="8"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Padding="0"
                                                      Cursor="Hand"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- 第二行：滑块（展开时显示） -->
                        <Border x:Name="PART_SliderPanel"
                                Grid.Row="1"
                                Visibility="Collapsed"
                                Margin="0,6,0,0"
                                Padding="0,4">
                            <Slider x:Name="PART_Slider"
                                    Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                    Minimum="{TemplateBinding Minimum}"
                                    Maximum="{TemplateBinding Maximum}"
                                    SmallChange="{TemplateBinding SmallChange}"
                                    LargeChange="{TemplateBinding LargeChange}"
                                    VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}"/>
                        </Trigger>
                        <!-- 滑块展开控制 -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowSlider" Value="True"/>
                                <Condition Property="IsSliderExpanded" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_SliderPanel" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ToggleSwitch 样式 - 简洁专业版 -->
    <Style TargetType="{x:Type controls:ToggleSwitch}">
        <Setter Property="SwitchWidth" Value="42"/>
        <Setter Property="SwitchHeight" Value="22"/>
        <Setter Property="CornerRadius" Value="11"/>
        <Setter Property="OnBackground" Value="#FF7F00"/>
        <Setter Property="OffBackground" Value="#D9D9D9"/>
        <Setter Property="ThumbColor" Value="White"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToggleSwitch}">
                    <Border x:Name="SwitchBorder"
                            Background="{TemplateBinding OffBackground}"
                            BorderBrush="{TemplateBinding OffBackground}"
                            BorderThickness="1"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Width="{TemplateBinding SwitchWidth}"
                            Height="{TemplateBinding SwitchHeight}">
                        <Grid>
                            <!-- 滑块 -->
                            <Border x:Name="ThumbBorder"
                                    Background="{TemplateBinding ThumbColor}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Width="{Binding SwitchHeight, RelativeSource={RelativeSource TemplatedParent}}"
                                    Height="{Binding SwitchHeight, RelativeSource={RelativeSource TemplatedParent}}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="1,0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- 开启状态 -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SwitchBorder" Property="Background" 
                                    Value="{Binding OnBackground, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="SwitchBorder" Property="BorderBrush" 
                                    Value="{Binding OnBackground, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="ThumbBorder" Property="HorizontalAlignment" Value="Right"/>
                        </Trigger>
                        <!-- 禁用状态 -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="SwitchBorder" Property="Opacity" Value="0.5"/>
                        </Trigger>
                        <!-- 深色主题 - 关闭状态 -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsDarkTheme" Value="True"/>
                                <Condition Property="IsChecked" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SwitchBorder" Property="Background" Value="#555555"/>
                            <Setter TargetName="SwitchBorder" Property="BorderBrush" Value="#555555"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- RangeSlider 样式 -->
    <Style TargetType="{x:Type controls:RangeSlider}">
        <Setter Property="Height" Value="22"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RangeSlider}">
                    <!-- 使用 Canvas 支持滑块绝对定位 -->
                    <Canvas x:Name="PART_Canvas"
                            Height="22"
                            VerticalAlignment="Center">
                        
                        <!-- 轨道 -->
                        <Border x:Name="PART_Track"
                                Canvas.Top="9"
                                Height="4"
                                Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                Background="#E0E0E0"
                                CornerRadius="2"/>

                        <!-- 选中范围填充 -->
                        <Border x:Name="PART_RangeFill"
                                Canvas.Top="9"
                                Height="4"
                                Background="{StaticResource PrimaryBrush}"
                                CornerRadius="2"/>

                        <!-- 最小值滑块 -->
                        <Thumb x:Name="PART_MinThumb"
                               Canvas.Top="1"
                               Width="14"
                               Height="20"
                               Background="White"
                               BorderBrush="{StaticResource PrimaryBrush}"
                               BorderThickness="2"
                               Cursor="Hand">
                            <Thumb.Style>
                                <Style TargetType="Thumb">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Thumb.Style>
                        </Thumb>

                        <!-- 最大值滑块 -->
                        <Thumb x:Name="PART_MaxThumb"
                               Canvas.Top="1"
                               Width="14"
                               Height="20"
                               Background="White"
                               BorderBrush="{StaticResource PrimaryBrush}"
                               BorderThickness="2"
                               Cursor="Hand">
                            <Thumb.Style>
                                <Style TargetType="Thumb">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Thumb.Style>
                        </Thumb>
                    </Canvas>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- RangeInputControl 样式 -->
    <Style TargetType="{x:Type controls:RangeInputControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RangeInputControl}">
                    <Border Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,6"
                            Margin="0,0,0,8">
                        <StackPanel>
                            <!-- 第一行：标签 + 数值输入 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 标签 -->
                                <TextBlock Grid.Column="0"
                                           Text="{TemplateBinding Label}"
                                           Style="{StaticResource LabelStyle}"
                                           MinWidth="60"
                                           Margin="0,0,12,0"/>

                                <!-- 最小值输入 -->
                                <controls:NumericUpDown x:Name="PART_MinNumeric"
                                                        Grid.Column="1"
                                                        Width="80"
                                                        Value="{Binding MinValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                        Minimum="{TemplateBinding Minimum}"
                                                        Maximum="{TemplateBinding Maximum}"
                                                        SmallChange="{TemplateBinding SmallChange}"
                                                        LargeChange="{TemplateBinding LargeChange}"
                                                        DecimalPlaces="{TemplateBinding DecimalPlaces}"
                                                        ShowSlider="False"
                                                        ShowUpDownButtons="True"/>

                                <!-- 分隔符 -->
                                <TextBlock Grid.Column="2"
                                           Text="-"
                                           Margin="4,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource LabelSecondaryBrush}"/>

                                <!-- 最大值输入 -->
                                <controls:NumericUpDown x:Name="PART_MaxNumeric"
                                                        Grid.Column="3"
                                                        Width="80"
                                                        Value="{Binding MaxValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                        Minimum="{TemplateBinding Minimum}"
                                                        Maximum="{TemplateBinding Maximum}"
                                                        SmallChange="{TemplateBinding SmallChange}"
                                                        LargeChange="{TemplateBinding LargeChange}"
                                                        DecimalPlaces="{TemplateBinding DecimalPlaces}"
                                                        ShowSlider="False"
                                                        ShowUpDownButtons="True"/>

                                <!-- 单位 -->
                                <TextBlock Grid.Column="4"
                                           Text="{TemplateBinding Unit}"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource LabelSecondaryBrush}"
                                           Visibility="{Binding Unit, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>

                            <!-- 第二行：范围滑块（获得焦点时显示） -->
                            <Border x:Name="PART_SliderPanel"
                                    Visibility="Collapsed"
                                    Margin="0,6,0,0"
                                    Padding="0,4">
                                <controls:RangeSlider x:Name="PART_RangeSlider"
                                                      Minimum="{TemplateBinding Minimum}"
                                                      Maximum="{TemplateBinding Maximum}"
                                                      MinValue="{Binding MinValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                      MaxValue="{Binding MaxValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                      SmallChange="{TemplateBinding SmallChange}"
                                                      LargeChange="{TemplateBinding LargeChange}"
                                                      MinGap="{TemplateBinding MinGap}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- 滑块展开控制 -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowSlider" Value="True"/>
                                <Condition Property="IsSliderExpanded" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_SliderPanel" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
