<UserControl x:Class="SunEyeVision.Plugin.SDK.UI.Previews.AllControlsPreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="2400" d:DesignWidth="493.111"
             Background="#F5F5F5">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 设计时数据源 -->
            <x:Array x:Key="ColorModes" Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                <sys:String>RGB</sys:String>
                <sys:String>HSV</sys:String>
                <sys:String>灰度</sys:String>
            </x:Array>

            <x:Array x:Key="FilterTypes" Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                <sys:String>均值滤波</sys:String>
                <sys:String>高斯滤波</sys:String>
                <sys:String>中值滤波</sys:String>
            </x:Array>

            <x:Array x:Key="ThresholdTypes" Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                <sys:String>二进制阈值</sys:String>
                <sys:String>反二进制阈值</sys:String>
                <sys:String>截断阈值</sys:String>
                <sys:String>自适应阈值</sys:String>
            </x:Array>

            <x:Array x:Key="AlgorithmTypes" Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                <sys:String>快速</sys:String>
                <sys:String>精确</sys:String>
            </x:Array>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <!-- 标题 -->
            <TextBlock Text="SunEyeVision Plugin SDK 控件预览"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       Foreground="#333333"/>

            <!-- ParamComboBox 示例 -->
            <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="ParamComboBox" FontWeight="Medium" FontSize="14" Margin="0,0,0,12"/>

                    <controls:ParamComboBox Label="颜色模式"
                                            SelectedIndex="0"
                                            ItemsSource="{Binding Source={StaticResource ColorModes}}"/>

                    <controls:ParamComboBox Label="滤波类型"
                                            SelectedIndex="1"
                                            ItemsSource="{Binding Source={StaticResource FilterTypes}}"/>
                </StackPanel>
            </Border>

            <!-- ParamTextBox 示例 -->
            <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16" Height="203">
                <StackPanel>
                    <TextBlock Text="ParamTextBox" FontWeight="Medium" FontSize="14" Margin="0,0,0,12"/>

                    <controls:ParamTextBox Label="文件路径"
                                           Text="C:\Images\sample.jpg"/>

                    <controls:ParamTextBox Label="备注信息"
                                           Text="这是一段备注信息"
                                           AcceptsReturn="True"
                                           Height="60"
                                           TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- LabeledControl 示例 -->
            <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="LabeledControl" FontWeight="Medium" FontSize="14" Margin="0,0,0,12"/>

                    <controls:LabeledControl Label="必填字段" Required="True">
                        <TextBox Text="必填内容" Height="28" VerticalContentAlignment="Center"/>
                    </controls:LabeledControl>

                    <controls:LabeledControl Label="可选字段" Required="False">
                        <CheckBox Content="启用功能" IsChecked="True"/>
                    </controls:LabeledControl>
                </StackPanel>
            </Border>

            <!-- BindableParameter 示例 -->
            <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="BindableParameter" FontWeight="Medium" FontSize="14" Margin="0,0,0,12"/>

                    <controls:BindableParameter ParameterName="NumericParameter"
                                                DataType="Double"
                                                Value="75.5"
                                                Minimum="0"
                                                Maximum="100"/>

                    <controls:BindableParameter ParameterName="StringParameter"
                                                DataType="String"
                                                Value="Hello World"/>

                    <controls:BindableParameter ParameterName="BoolParameter"
                                                DataType="Bool"
                                                Value="True"/>
                </StackPanel>
            </Border>

            <!-- NumericUpDown 示例 -->
            <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="NumericUpDown" FontWeight="Medium" FontSize="14" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="宽度: " VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <controls:NumericUpDown Grid.Column="1"
                                                Value="100"
                                                Minimum="1"
                                                Maximum="1000"
                                                SmallChange="1"
                                                ShowUpDownButtons="True"/>
                    </Grid>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="高度: " VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <controls:NumericUpDown Grid.Column="1"
                                                Value="200"
                                                Minimum="1"
                                                Maximum="1000"
                                                SmallChange="1"
                                                ShowUpDownButtons="True"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ParamGroup 示例 -->
            <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="ParamGroup" FontWeight="Medium" FontSize="14" Margin="0,0,0,12"/>

                    <controls:ParamGroup Header="高级设置" IsExpanded="True">
                        <StackPanel>
                            <controls:BindableParameter ParameterName="Precision"
                                                        DataType="Double"
                                                        Value="3"
                                                        Minimum="1"
                                                        Maximum="10"/>
                            <controls:ParamComboBox Label="算法"
                                                    SelectedIndex="0"
                                                    ItemsSource="{Binding Source={StaticResource AlgorithmTypes}}"/>
                        </StackPanel>
                    </controls:ParamGroup>

                    <controls:ParamGroup Header="其他选项" IsExpanded="False">
                        <StackPanel>
                            <CheckBox Content="启用缓存" IsChecked="False"/>
                            <CheckBox Content="自动保存" IsChecked="True"/>
                        </StackPanel>
                    </controls:ParamGroup>
                </StackPanel>
            </Border>

            <!-- ImageSourceSelector 示例 -->
            <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="ImageSourceSelector" FontWeight="Medium" FontSize="14" Margin="0,0,0,12"/>
                    <TextBlock Text="（运行时可选择图像源）" FontSize="11" Foreground="#666" Margin="0,0,0,8"/>

                    <controls:ImageSourceSelector PlaceholderText="点击选择图像源..."/>
                </StackPanel>
            </Border>

            <!-- ColorPicker 示例 -->
            <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="ColorPicker" FontWeight="Medium" FontSize="14" Margin="0,0,0,12"/>
                    <TextBlock Text="（取色器控件：预设颜色 + HSV 选择器）" FontSize="11" Foreground="#666" Margin="0,0,0,8"/>

                    <controls:ColorPicker x:Name="ColorPickerDemo" 
                                        SelectedColor="0xFFFF0000" Height="287" Width="252"/>

                    <!-- 显示当前选中颜色 -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="当前颜色值：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" 
                       Text="{Binding SelectedColor, ElementName=ColorPickerDemo, Mode=OneWay, StringFormat=0x{0:X8}}"
                       VerticalAlignment="Center"
                       FontWeight="Medium"
                       Foreground="#1890FF"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ColorSelector 示例 -->
            <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="ColorSelector" FontWeight="Medium" FontSize="14" Margin="0,0,0,12"/>
                    <TextBlock Text="（颜色选择器：紧凑型，点击弹出取色器）" FontSize="11" Foreground="#666" Margin="0,0,0,8"/>

                    <controls:ColorSelector x:Name="ColorSelectorDemo"
                                         SelectedColor="0xFFFF0000"/>

                    <controls:ColorSelector x:Name="ColorSelectorDemo2"
                                         SelectedColor="0xFF364061"
                                         Margin="0,8,0,0"/>

                    <!-- 显示当前选中颜色 -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="当前颜色值：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" 
                       Text="{Binding SelectedColor, ElementName=ColorSelectorDemo, Mode=OneWay, StringFormat=0x{0:X8}}"
                       VerticalAlignment="Center"
                       FontWeight="Medium"
                       Foreground="#1890FF"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 组合示例 -->
            <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="组合布局示例" FontWeight="Medium" FontSize="14" Margin="0,0,0,12"/>

                    <controls:ParamGroup Header="阈值处理" IsExpanded="True">
                        <StackPanel>
                            <controls:BindableParameter ParameterName="Threshold"
                                                        DataType="Double"
                                                        Value="128"
                                                        Minimum="0"
                                                        Maximum="255"/>

                            <controls:ParamComboBox Label="阈值类型"
                                                    SelectedIndex="0"
                                                    ItemsSource="{Binding Source={StaticResource ThresholdTypes}}"/>

                            <controls:LabeledControl Label="启用OTSU" Required="False">
                                <CheckBox IsChecked="False"/>
                            </controls:LabeledControl>
                        </StackPanel>
                    </controls:ParamGroup>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
