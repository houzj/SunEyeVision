<UserControl x:Class="SunEyeVision.Plugin.SDK.UI.Controls.ImageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    
    <UserControl.Resources>
        <!-- 深色工具栏按钮样式 -->
        <Style x:Key="ToolBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="IconContent"
                                                  HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"
                                                  RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter.RenderTransform>
                                        <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Border>
                            <!-- 底部高亮指示器 -->
                            <Border x:Name="BottomIndicator"
                                    Height="2"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Center"
                                    Width="0"
                                    Background="#1890FF"
                                    CornerRadius="1"
                                    Margin="0,0,0,2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3C3C3C"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1890FF"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#505050"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 工具栏分隔线样式 -->
        <Style x:Key="ToolBarSeparator" TargetType="Border">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Background" Value="#404040"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <!-- 工具栏下拉框样式 -->
        <Style x:Key="ToolBarComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#505050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 - 深色主题 -->
        <Border x:Name="ToolBar" Grid.Row="0" 
                Background="#2D2D2D" 
                Padding="4,2" 
                Height="32"
                BorderBrush="#404040"
                BorderThickness="0,0,0,1">
            <Grid>
                <!-- 左侧：图像源选择 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <ComboBox x:Name="ImageSourceSelector" 
                              Width="160" Margin="0"
                              Style="{StaticResource ToolBarComboBoxStyle}"
                              SelectionChanged="ImageSourceSelector_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" 
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding NodeId}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                
                <!-- 右侧：缩放和全屏控制 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <!-- 放大 - ZoomIn图标 -->
                    <Button Content="&#xE8A3;" 
                            Style="{StaticResource ToolBarButtonStyle}"
                            Click="ZoomIn_Click" ToolTip="放大 (Ctrl++)"/>
                    <!-- 缩小 - ZoomOut图标 -->
                    <Button Content="&#xE71F;" 
                            Style="{StaticResource ToolBarButtonStyle}"
                            Click="ZoomOut_Click" ToolTip="缩小 (Ctrl+-)"/>
                    <!-- 适应窗口 - 使用Unicode比例符号 -->
                    <Button Style="{StaticResource ToolBarButtonStyle}"
                            Click="FitToWindow_Click" ToolTip="适应窗口 (Ctrl+0)">
                        <TextBlock Text="1&#x2236;1" 
                                   FontFamily="Segoe UI"
                                   FontSize="12" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Border Style="{StaticResource ToolBarSeparator}"/>

                    <!-- 全屏 - 全屏图标 -->
                    <Button x:Name="FullscreenButton" 
                            Content="&#xE740;" 
                            Style="{StaticResource ToolBarButtonStyle}"
                            Click="ToggleFullscreen_Click" ToolTip="全屏 (F11)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 图像显示区域 - 使用Canvas实现平移缩放 -->
        <Grid Grid.Row="1">
            <!-- 棋盘格背景层 - 透明度指示 -->
            <Grid x:Name="ChessboardLayer">
                <Grid.Background>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,32,32" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="#FF2D2D2D">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,32,32"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="#FF3C3C3C">
                                    <GeometryDrawing.Geometry>
                                        <GeometryGroup>
                                            <RectangleGeometry Rect="0,0,16,16"/>
                                            <RectangleGeometry Rect="16,16,16,16"/>
                                        </GeometryGroup>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Grid.Background>
            </Grid>

            <Canvas x:Name="MainCanvas"
                    Background="Transparent"
                    ClipToBounds="True"
                    MouseWheel="MainCanvas_MouseWheel"
                    MouseLeftButtonDown="MainCanvas_MouseLeftButtonDown"
                    MouseMove="MainCanvas_MouseMove"
                    MouseLeftButtonUp="MainCanvas_MouseLeftButtonUp"
                    SizeChanged="MainCanvas_SizeChanged">

            <!-- 图像容器 -->
            <Grid x:Name="ImageContainer"
                  Background="Transparent">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ImageScaleTransform"/>
                        <TranslateTransform x:Name="ImageTranslateTransform"/>
                    </TransformGroup>
                </Grid.RenderTransform>

                <Image x:Name="DisplayImage"
                       Stretch="None"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                <!-- 叠加层Canvas - 供外部添加自定义元素 -->
                <Canvas x:Name="OverlayCanvasControl"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
            </Grid>
        </Canvas>
        </Grid>

        <!-- 状态栏 - 深色主题 -->
        <StatusBar x:Name="StatusBar" Grid.Row="2" 
                   Background="#252525" 
                   Padding="8,2"
                   BorderBrush="#404040"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="PositionText" 
                           Text="位置: (0, 0)" 
                           Foreground="#909090"
                           FontSize="11"/>
            </StatusBarItem>
            <Separator Background="#404040"/>
            <StatusBarItem>
                <TextBlock x:Name="ImageSizeText" 
                           Text="图像: -" 
                           Foreground="#909090"
                           FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
