<UserControl x:Class="SunEyeVision.Plugin.SDK.UI.Controls.ROI.ROIInfoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.ROI"
             xmlns:ctrl="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls"
             Width="280"
             MinHeight="200">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SunEyeVision.Plugin.SDK;component/UI/Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- 数值输入框样式 -->
            <Style x:Key="NumericTextBox" TargetType="TextBox">
                <Setter Property="Width" Value="80"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Margin" Value="4,2"/>
                <Setter Property="Padding" Value="4,0"/>
                <Setter Property="BorderBrush" Value="#D0D0D0"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <!-- 标签样式 -->
            <Style x:Key="LabelStyle" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="8,2,4,2"/>
                <Setter Property="Foreground" Value="#555"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <!-- 分组标题样式 -->
            <Style x:Key="GroupHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="#333"/>
                <Setter Property="Margin" Value="8,8,8,4"/>
            </Style>

            <!-- 转换器 -->
            <local:ROITypeToVisibilityConverter x:Key="ROITypeToVisibilityConverter"/>
            <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <!-- 无选中状态 -->
        <Grid Visibility="{Binding HasSelection, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
              VerticalAlignment="Center">
            <TextBlock Text="未选中任何区域"
                       HorizontalAlignment="Center"
                       Foreground="#999"
                       FontSize="14"/>
        </Grid>

        <!-- 有选中状态 -->
        <Grid Visibility="{Binding HasSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,0,8">
                    <!-- 类型筛选器（多选时显示） -->
                    <Grid Visibility="{Binding ShowFilterTypeSelector, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="筛选类型:"
                                   Style="{StaticResource LabelStyle}"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableFilterTypes}"
                                  SelectedItem="{Binding FilterType}"
                                  Margin="4,2"
                                  Height="24"/>
                    </Grid>

                    <!-- 多选提示 -->
                    <TextBlock Visibility="{Binding IsMultiSelect, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="{Binding SelectedCount, StringFormat='已选中 {0} 个区域'}"
                               Style="{StaticResource LabelStyle}"
                               Foreground="#666"
                               Margin="8,0"/>

                    <!-- 基本信息 -->
                    <TextBlock Text="基本信息" Style="{StaticResource GroupHeaderStyle}"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="0,1" Padding="0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 名称 -->
                            <TextBlock Grid.Row="0" Text="名称:" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding CurrentInfo.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource NumericTextBox}"
                                     Width="160"/>

                            <!-- 类型 -->
                            <TextBlock Grid.Row="1" Text="类型:" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding CurrentInfo.Type}"
                                       VerticalAlignment="Center"
                                       Margin="4,2"
                                       Foreground="#333"/>

                            <!-- 位置（非直线类型显示"中心"，直线类型隐藏） -->
                            <TextBlock Grid.Row="2" Text="中心:" Style="{StaticResource LabelStyle}"
                                       Visibility="{Binding CurrentInfo.Type, Converter={StaticResource ROITypeToVisibilityConverter}, ConverterParameter=NotLine}"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal"
                                        Visibility="{Binding CurrentInfo.Type, Converter={StaticResource ROITypeToVisibilityConverter}, ConverterParameter=NotLine}">
                                <ctrl:NumericUpDown Value="{Binding CurrentInfo.PositionX, UpdateSourceTrigger=PropertyChanged}"
                                                    Minimum="0" Maximum="9999"
                                                    SmallChange="1" LargeChange="10"
                                                    DecimalPlaces="3"
                                                    Width="100" Height="24" Margin="4,2"/>
                                <TextBlock Text="," VerticalAlignment="Center" Margin="2,0"/>
                                <ctrl:NumericUpDown Value="{Binding CurrentInfo.PositionY, UpdateSourceTrigger=PropertyChanged}"
                                                    Minimum="0" Maximum="9999"
                                                    SmallChange="1" LargeChange="10"
                                                    DecimalPlaces="3"
                                                    Width="100" Height="24" Margin="2,2"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 矩形/旋转矩形信息 -->
                    <TextBlock Text="矩形尺寸"
                               Style="{StaticResource GroupHeaderStyle}"
                               Visibility="{Binding CurrentInfo.Type, Converter={StaticResource ROITypeToVisibilityConverter}, ConverterParameter=Rectangle}"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="0,1" Padding="0,4"
                            Visibility="{Binding CurrentInfo.Type, Converter={StaticResource ROITypeToVisibilityConverter}, ConverterParameter=Rectangle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 宽度 -->
                            <TextBlock Grid.Row="0" Text="宽度:" Style="{StaticResource LabelStyle}"/>
                            <ctrl:NumericUpDown Grid.Row="0" Grid.Column="1"
                                                Value="{Binding CurrentInfo.Width, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="1" Maximum="9999"
                                                SmallChange="1" LargeChange="10"
                                                DecimalPlaces="3"
                                                IsEnabled="{Binding CanEditSize}"
                                                Width="100" Height="24" Margin="4,2" HorizontalAlignment="Left"/>

                            <!-- 高度 -->
                            <TextBlock Grid.Row="1" Text="高度:" Style="{StaticResource LabelStyle}"/>
                            <ctrl:NumericUpDown Grid.Row="1" Grid.Column="1"
                                                Value="{Binding CurrentInfo.Height, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="1" Maximum="9999"
                                                SmallChange="1" LargeChange="10"
                                                DecimalPlaces="3"
                                                IsEnabled="{Binding CanEditSize}"
                                                Width="100" Height="24" Margin="4,2" HorizontalAlignment="Left"/>

                            <!-- 旋转角度（仅旋转矩形） -->
                            <TextBlock Grid.Row="2" Text="角度:"
                                       Style="{StaticResource LabelStyle}"
                                       Visibility="{Binding CurrentInfo.Type, Converter={StaticResource ROITypeToVisibilityConverter}, ConverterParameter=RotatedRectangle}"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal"
                                        Visibility="{Binding CurrentInfo.Type, Converter={StaticResource ROITypeToVisibilityConverter}, ConverterParameter=RotatedRectangle}">
                                <ctrl:NumericUpDown Value="{Binding CurrentInfo.Rotation, UpdateSourceTrigger=PropertyChanged}"
                                                    Minimum="-180" Maximum="180"
                                                    SmallChange="1" LargeChange="15"
                                                    DecimalPlaces="1"
                                                    IsEnabled="{Binding CanEditSize}"
                                                    Width="100" Height="24" Margin="4,2"/>
                                <TextBlock Text="°" VerticalAlignment="Center" Margin="2,0,8,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 圆形信息 -->
                    <TextBlock Text="圆形尺寸"
                               Style="{StaticResource GroupHeaderStyle}"
                               Visibility="{Binding CurrentInfo.Type, Converter={StaticResource ROITypeToVisibilityConverter}, ConverterParameter=Circle}"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="0,1" Padding="0,4"
                            Visibility="{Binding CurrentInfo.Type, Converter={StaticResource ROITypeToVisibilityConverter}, ConverterParameter=Circle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 半径 -->
                            <TextBlock Text="半径:" Style="{StaticResource LabelStyle}"/>
                            <ctrl:NumericUpDown Grid.Column="1"
                                                Value="{Binding CurrentInfo.Radius, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="1" Maximum="9999"
                                                SmallChange="1" LargeChange="10"
                                                DecimalPlaces="3"
                                                IsEnabled="{Binding CanEditSize}"
                                                Width="100" Height="24" Margin="4,2"/>
                        </Grid>
                    </Border>

                    <!-- 直线信息 -->
                    <TextBlock Text="直线端点"
                               Style="{StaticResource GroupHeaderStyle}"
                               Visibility="{Binding CurrentInfo.Type, Converter={StaticResource ROITypeToVisibilityConverter}, ConverterParameter=Line}"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="0,1" Padding="0,4"
                            Visibility="{Binding CurrentInfo.Type, Converter={StaticResource ROITypeToVisibilityConverter}, ConverterParameter=Line}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 起点 -->
                            <TextBlock Grid.Row="0" Text="起点:" Style="{StaticResource LabelStyle}"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                <ctrl:NumericUpDown Value="{Binding CurrentInfo.StartPointX, UpdateSourceTrigger=PropertyChanged}"
                                                    Minimum="0" Maximum="9999"
                                                    SmallChange="1" LargeChange="10"
                                                    DecimalPlaces="3"
                                                    Width="100" Height="24" Margin="4,2"/>
                                <TextBlock Text="," VerticalAlignment="Center" Margin="2,0"/>
                                <ctrl:NumericUpDown Value="{Binding CurrentInfo.StartPointY, UpdateSourceTrigger=PropertyChanged}"
                                                    Minimum="0" Maximum="9999"
                                                    SmallChange="1" LargeChange="10"
                                                    DecimalPlaces="3"
                                                    Width="100" Height="24" Margin="2,2"/>
                            </StackPanel>

                            <!-- 终点 -->
                            <TextBlock Grid.Row="1" Text="终点:" Style="{StaticResource LabelStyle}"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <ctrl:NumericUpDown Value="{Binding CurrentInfo.EndPointX, UpdateSourceTrigger=PropertyChanged}"
                                                    Minimum="0" Maximum="9999"
                                                    SmallChange="1" LargeChange="10"
                                                    DecimalPlaces="3"
                                                    IsEnabled="{Binding CanEditSize}"
                                                    Width="100" Height="24" Margin="4,2"/>
                                <TextBlock Text="," VerticalAlignment="Center" Margin="2,0"/>
                                <ctrl:NumericUpDown Value="{Binding CurrentInfo.EndPointY, UpdateSourceTrigger=PropertyChanged}"
                                                    Minimum="0" Maximum="9999"
                                                    SmallChange="1" LargeChange="10"
                                                    DecimalPlaces="3"
                                                    IsEnabled="{Binding CanEditSize}"
                                                    Width="100" Height="24" Margin="2,2"/>
                            </StackPanel>

                            <!-- 长度 -->
                            <TextBlock Grid.Row="2" Text="长度:" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding CurrentInfo.Length, StringFormat=F1}"
                                       VerticalAlignment="Center"
                                       Margin="4,2"
                                       Foreground="#333"/>

                            <!-- 角度 -->
                            <TextBlock Grid.Row="3" Text="角度:" Style="{StaticResource LabelStyle}"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding CurrentInfo.LineAngle, StringFormat=F1}"
                                           VerticalAlignment="Center"
                                           Margin="4,2"
                                           Foreground="#333"/>
                                <TextBlock Text="°" VerticalAlignment="Center" Margin="0,2"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 批量应用按钮（多选时显示） -->
                    <Button Content="应用到所有同类型区域"
                            Command="{Binding ApplyToAllCommand}"
                            Visibility="{Binding IsMultiSelect, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="8,12,8,0"
                            Height="28"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>

                    <!-- 显示设置 -->
                    <TextBlock Text="显示设置" Style="{StaticResource GroupHeaderStyle}" Margin="8,16,8,4"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="0,1" Padding="0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 标签字号 -->
                            <TextBlock Grid.Row="0" Text="字号:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      x:Name="FontSizeComboBox"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding EditorSettings.LabelFontSize, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=local:ROIInfoPanel}}"
                                      Margin="4,2" Height="24" Width="80" HorizontalAlignment="Left">
                                <ComboBoxItem Content="10" Tag="10"/>
                                <ComboBoxItem Content="11" Tag="11"/>
                                <ComboBoxItem Content="12" Tag="12" IsSelected="True"/>
                                <ComboBoxItem Content="14" Tag="14"/>
                                <ComboBoxItem Content="16" Tag="16"/>
                                <ComboBoxItem Content="18" Tag="18"/>
                            </ComboBox>

                            <!-- 线宽 -->
                            <TextBlock Grid.Row="1" Text="线宽:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      x:Name="StrokeThicknessComboBox"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding EditorSettings.DefaultStrokeThickness, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=local:ROIInfoPanel}}"
                                      Margin="4,2" Height="24" Width="80" HorizontalAlignment="Left">
                                <ComboBoxItem Content="1" Tag="1"/>
                                <ComboBoxItem Content="1.5" Tag="1.5"/>
                                <ComboBoxItem Content="2" Tag="2" IsSelected="True"/>
                                <ComboBoxItem Content="2.5" Tag="2.5"/>
                                <ComboBoxItem Content="3" Tag="3"/>
                                <ComboBoxItem Content="4" Tag="4"/>
                            </ComboBox>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
