<UserControl x:Class="SunEyeVision.Plugin.SDK.UI.Controls.Region.Views.RegionSubscribePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Views">
    <Grid>
        <StackPanel Margin="8">
            <TextBlock Text="区域订阅面板" FontWeight="Bold" Margin="0,0,0,8"/>
            
            <!-- 节点选择器 -->
            <GroupBox Header="源节点" Margin="0,0,0,8">
                <StackPanel>
                    <Button Content="选择节点..."
                            Command="{Binding OpenPopupCommand}"
                            Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SelectionDisplayPath, Mode=OneWay}"
                              FontSize="11"
                              Foreground="Gray"/>
                </StackPanel>
            </GroupBox>

            <!-- 输出端口选择 -->
            <GroupBox Header="输出端口" Margin="0,0,0,8">
                <ComboBox ItemsSource="{Binding FilteredNodes}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                         DisplayMemberPath="Name"/>
            </GroupBox>

            <TextBlock Text="绑定其他节点输出的区域" 
                      FontSize="11" 
                      Foreground="Gray" 
                      Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
