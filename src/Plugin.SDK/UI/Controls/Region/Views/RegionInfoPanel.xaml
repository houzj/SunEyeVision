<UserControl x:Class="SunEyeVision.Plugin.SDK.UI.Controls.Region.Views.RegionInfoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Views"
             xmlns:models="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Models"
             xmlns:converters="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Converters"
             xmlns:uiConverters="clr-namespace:SunEyeVision.Plugin.SDK.UI.Converters"
             Width="280">
    <!--
    方案2：修复绑定路径
    DataContext 应绑定到 RegionEditorViewModel，而不是 SelectedRegion
    这样内部的绑定路径才能正确解析
    -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:ShapeTypeToVisibilityConverter x:Key="ShapeTypeToVisibilityConverter"/>
        <uiConverters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <uiConverters:UIntToBrushConverter x:Key="UIntToBrushConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">
            <!-- 无选中项提示 -->
            <TextBlock Text="未选中任何区域"
                       FontStyle="Italic"
                       Foreground="Gray"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"
                       Visibility="{Binding HasSelection, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

            <!-- 区域信息 -->
            <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                
                <!-- 基本信息 -->
                <GroupBox Header="基本信息" Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" 
                                     Text="{Binding SelectedRegion.Name, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                     IsEnabled="{Binding CanEdit}"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="模式:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding SelectedRegionMode, FallbackValue='未知'}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="形状:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding SelectedRegionShapeType, FallbackValue='未知'}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- 绘制模式参数 -->
                <GroupBox Header="绘制参数" 
                          Margin="0,0,0,8"
                          Visibility="{Binding IsDrawingMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Margin="4" IsEnabled="{Binding CanEdit}">
                        <!-- 通用位置参数 -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="1" 
                                     Text="{Binding EditingShape.CenterX, UpdateSourceTrigger=PropertyChanged, StringFormat=F1, TargetNullValue=''}"/>
                            <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                            <TextBox Grid.Column="3" 
                                     Text="{Binding EditingShape.CenterY, UpdateSourceTrigger=PropertyChanged, StringFormat=F1, TargetNullValue=''}"/>
                        </Grid>

                        <!-- 矩形参数 -->
                        <Grid Margin="0,4" Visibility="{Binding EditingShape.ShapeType, Converter={StaticResource ShapeTypeToVisibilityConverter}, ConverterParameter='Rectangle,RotatedRectangle', FallbackValue=Collapsed}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="宽:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="1" 
                                     Text="{Binding EditingShape.Width, UpdateSourceTrigger=PropertyChanged, StringFormat=F1, TargetNullValue=''}"/>
                            <TextBlock Grid.Column="2" Text="高:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                            <TextBox Grid.Column="3" 
                                     Text="{Binding EditingShape.Height, UpdateSourceTrigger=PropertyChanged, StringFormat=F1, TargetNullValue=''}"/>
                        </Grid>

                        <!-- 旋转角度 -->
                        <Grid Margin="0,4" Visibility="{Binding EditingShape.ShapeType, Converter={StaticResource ShapeTypeToVisibilityConverter}, ConverterParameter=RotatedRectangle, FallbackValue=Collapsed}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="角度:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Slider Grid.Column="1" 
                                    Value="{Binding EditingShape.Angle, UpdateSourceTrigger=PropertyChanged, FallbackValue=0}"
                                    Minimum="-180" Maximum="180"
                                    TickFrequency="15"
                                    TickPlacement="BottomRight"/>
                            <TextBlock Grid.Column="2" 
                                       Text="{Binding EditingShape.Angle, StringFormat={}{0:F1}°, FallbackValue='0°'}"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"
                                       Width="50"/>
                        </Grid>

                        <!-- 圆形半径 -->
                        <Grid Margin="0,4" Visibility="{Binding EditingShape.ShapeType, Converter={StaticResource ShapeTypeToVisibilityConverter}, ConverterParameter=Circle, FallbackValue=Collapsed}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="半径:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Slider Grid.Column="1" 
                                    Value="{Binding EditingShape.Radius, UpdateSourceTrigger=PropertyChanged, FallbackValue=0}"
                                    Minimum="1" Maximum="1000"
                                    TickFrequency="50"
                                    TickPlacement="BottomRight"/>
                            <TextBox Grid.Column="2" 
                                     Text="{Binding EditingShape.Radius, UpdateSourceTrigger=PropertyChanged, StringFormat=F1, TargetNullValue=''}"
                                     Width="60"/>
                        </Grid>

                        <!-- 直线参数 -->
                        <Grid Margin="0,4" Visibility="{Binding EditingShape.ShapeType, Converter={StaticResource ShapeTypeToVisibilityConverter}, ConverterParameter=Line, FallbackValue=Collapsed}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="起点X:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="1" 
                                     Text="{Binding EditingShape.StartX, UpdateSourceTrigger=PropertyChanged, StringFormat=F1, TargetNullValue=''}"/>
                            <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                            <TextBox Grid.Column="3" 
                                     Text="{Binding EditingShape.StartY, UpdateSourceTrigger=PropertyChanged, StringFormat=F1, TargetNullValue=''}"/>
                        </Grid>
                        <Grid Margin="0,4" Visibility="{Binding EditingShape.ShapeType, Converter={StaticResource ShapeTypeToVisibilityConverter}, ConverterParameter=Line, FallbackValue=Collapsed}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="终点X:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="1" 
                                     Text="{Binding EditingShape.EndX, UpdateSourceTrigger=PropertyChanged, StringFormat=F1, TargetNullValue=''}"/>
                            <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                            <TextBox Grid.Column="3" 
                                     Text="{Binding EditingShape.EndY, UpdateSourceTrigger=PropertyChanged, StringFormat=F1, TargetNullValue=''}"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- 订阅模式参数 -->
                <GroupBox Header="订阅参数" 
                          Margin="0,0,0,8"
                          Visibility="{Binding IsSubscribeMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Margin="4">
                        <TextBlock Text="每个参数可独立绑定到其他节点输出：" 
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>
                        
                        <!-- 参数绑定列表（动态生成） -->
                        <ItemsControl ItemsSource="{Binding ParameterBindings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding Key}" 
                                                   VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" 
                                                  DisplayMemberPath="Value"
                                                  IsEnabled="{Binding DataContext.CanEdit, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>

                <!-- 显示设置 -->
                <GroupBox Header="显示设置" Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="颜色:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            
                            <!-- 颜色选择按钮 -->
                            <Button x:Name="SelectColorButton"
                                    Grid.Column="1" 
                                    IsEnabled="{Binding CanEdit}"
                                    HorizontalContentAlignment="Left"
                                    Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 颜色预览 -->
                                    <Border x:Name="ColorPreview"
                                            Grid.Column="0"
                                            Width="24" Height="24"
                                            CornerRadius="4"
                                            Margin="0,0,8,0"
                                            Background="{Binding SelectedRegion.DisplayColor, Converter={StaticResource UIntToBrushConverter}, FallbackValue=Red}"/>
                                    <!-- 文本 -->
                                    <TextBlock Grid.Column="1" 
                                               Text="选择颜色"
                                               VerticalAlignment="Center"
                                               Foreground="Gray"/>
                                </Grid>
                            </Button>
                            
                            <!-- 颜色选择器弹窗 -->
                            <Popup x:Name="ColorPickerPopup"
                                   PlacementTarget="{Binding ElementName=SelectColorButton}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="White"
                                        BorderBrush="#D9D9D9"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="0"
                                        Margin="0,2,0,0">
                                    <controls:ColorPicker 
                                        xmlns:controls="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls"
                                        SelectedColor="{Binding SelectedRegion.DisplayColor, Mode=TwoWay}"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="透明度:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Slider Grid.Column="1" 
                                    Value="{Binding SelectedRegion.DisplayOpacity, UpdateSourceTrigger=PropertyChanged, FallbackValue=0.3}"
                                    Minimum="0" Maximum="1"
                                    TickFrequency="0.1"
                                    IsEnabled="{Binding CanEdit}"/>
                        </Grid>
                        <CheckBox Content="可见" 
                                  IsChecked="{Binding SelectedRegion.IsVisible, FallbackValue=True}"
                                  IsEnabled="{Binding CanEdit}"
                                  Margin="0,4"/>
                        <CheckBox Content="可编辑" 
                                  IsChecked="{Binding SelectedRegion.IsEditable, FallbackValue=True}"
                                  IsEnabled="{Binding CanEdit}"
                                  Margin="0,4"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
