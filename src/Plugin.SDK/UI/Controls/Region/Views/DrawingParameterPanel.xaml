<UserControl x:Class="SunEyeVision.Plugin.SDK.UI.Controls.Region.Views.DrawingParameterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Views">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <StackPanel Margin="8">
            <TextBlock Text="绘制参数面板" FontWeight="Bold" Margin="0,0,0,8"/>
            
            <!-- 形状参数编辑区 -->
            <Grid DataContext="{Binding EditingShape}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 中心坐标 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="中心X:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" 
                         Text="{Binding CenterX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="中心Y:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" 
                         Text="{Binding CenterY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4"/>

                <!-- 宽高 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="宽度:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <TextBox Grid.Row="2" Grid.Column="1" 
                         Text="{Binding Width, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="高度:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <TextBox Grid.Row="3" Grid.Column="1" 
                         Text="{Binding Height, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4"/>

                <!-- 角度（仅旋转矩形显示） -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="角度:" VerticalAlignment="Center" Margin="0,0,8,4"
                          Visibility="{Binding ShowAngle, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <TextBox Grid.Row="4" Grid.Column="1" 
                         Text="{Binding Angle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4"
                         Visibility="{Binding ShowAngle, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>

            <TextBlock Text="在主界面图像上绘制区域" 
                      FontSize="11" 
                      Foreground="Gray" 
                      Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
