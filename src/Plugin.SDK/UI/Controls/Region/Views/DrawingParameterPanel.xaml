<UserControl x:Class="SunEyeVision.Plugin.SDK.UI.Controls.Region.Views.DrawingParameterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Views"
             xmlns:models="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Models"
             xmlns:conv="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Converters"
             xmlns:ctrl="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:ShapeTypeToVisibilityConverter x:Key="ShapeTypeToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        
        <!-- 标签样式 -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,2,4,2"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <!-- 分组标题样式 -->
        <Style x:Key="GroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="8,8,8,4"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="8">
                <!-- 提示信息 -->
                <TextBlock Text="绘制参数"
                           Style="{StaticResource GroupHeaderStyle}"/>

                <!-- 通用位置参数（所有形状显示） -->
                <Border BorderBrush="#E0E0E0" BorderThickness="0,1" Padding="0,4" Margin="0,0,0,8"
                        Visibility="{Binding SelectedShapeType, Converter={StaticResource ShapeTypeToVisibilityConverter}, ConverterParameter='Rectangle,Circle,RotatedRectangle', FallbackValue=Collapsed}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="中心X:" Style="{StaticResource LabelStyle}"/>
                        <ctrl:NumericUpDown Grid.Column="1"
                                            Value="{Binding Parameters.CenterX, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                            Minimum="0" Maximum="9999"
                                            SmallChange="1" LargeChange="10"
                                            DecimalPlaces="3"
                                            Width="100" Margin="4,2" HorizontalAlignment="Left"/>
                        <TextBlock Grid.Column="2" Text="Y:" Style="{StaticResource LabelStyle}" Margin="8,2,4,2"/>
                        <ctrl:NumericUpDown Grid.Column="3"
                                            Value="{Binding Parameters.CenterY, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                            Minimum="0" Maximum="9999"
                                            SmallChange="1" LargeChange="10"
                                            DecimalPlaces="3"
                                            Width="100" Margin="4,2" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>

                <!-- 矩形参数 -->
                <Border BorderBrush="#E0E0E0" BorderThickness="0,1" Padding="0,4" Margin="0,0,0,8"
                        Visibility="{Binding SelectedShapeType, Converter={StaticResource ShapeTypeToVisibilityConverter}, ConverterParameter='Rectangle', FallbackValue=Collapsed}">
                    <StackPanel>
                        <TextBlock Text="矩形尺寸 - 矩形工具"
                                   FontSize="12"
                                   Foreground="#666"
                                   Margin="8,4"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="宽度:" Style="{StaticResource LabelStyle}"/>
                            <ctrl:NumericUpDown Grid.Column="1"
                                                Value="{Binding Parameters.Width, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                Minimum="1" Maximum="9999"
                                                SmallChange="1" LargeChange="10"
                                                DecimalPlaces="3"
                                                Width="100" Margin="4,2" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="高度:" Style="{StaticResource LabelStyle}" Margin="8,2,4,2"/>
                            <ctrl:NumericUpDown Grid.Column="3"
                                                Value="{Binding Parameters.Height, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                Minimum="1" Maximum="9999"
                                                SmallChange="1" LargeChange="10"
                                                DecimalPlaces="3"
                                                Width="100" Margin="4,2" HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 圆形参数 -->
                <Border BorderBrush="#E0E0E0" BorderThickness="0,1" Padding="0,4" Margin="0,0,0,8"
                        Visibility="{Binding SelectedShapeType, Converter={StaticResource ShapeTypeToVisibilityConverter}, ConverterParameter='Circle', FallbackValue=Collapsed}">
                    <StackPanel>
                        <TextBlock Text="圆形尺寸 - 圆形工具"
                                   FontSize="12"
                                   Foreground="#666"
                                   Margin="8,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="半径:" Style="{StaticResource LabelStyle}"/>
                            <ctrl:NumericUpDown Grid.Column="1"
                                                Value="{Binding Parameters.Radius, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                Minimum="1" Maximum="9999"
                                                SmallChange="1" LargeChange="10"
                                                DecimalPlaces="3"
                                                Width="100" Margin="4,2" HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 旋转矩形参数 -->
                <Border BorderBrush="#E0E0E0" BorderThickness="0,1" Padding="0,4" Margin="0,0,0,8"
                        Visibility="{Binding SelectedShapeType, Converter={StaticResource ShapeTypeToVisibilityConverter}, ConverterParameter='RotatedRectangle', FallbackValue=Collapsed}">
                    <StackPanel>
                        <TextBlock Text="旋转矩形尺寸 - 旋转矩形工具"
                                   FontSize="12"
                                   Foreground="#666"
                                   Margin="8,4"/>

                        <!-- 宽高 -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="宽度:" Style="{StaticResource LabelStyle}"/>
                            <ctrl:NumericUpDown Grid.Column="1"
                                                Value="{Binding Parameters.Width, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                Minimum="1" Maximum="9999"
                                                SmallChange="1" LargeChange="10"
                                                DecimalPlaces="3"
                                                Width="100" Margin="4,2" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="高度:" Style="{StaticResource LabelStyle}" Margin="8,2,4,2"/>
                            <ctrl:NumericUpDown Grid.Column="3"
                                                Value="{Binding Parameters.Height, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                Minimum="1" Maximum="9999"
                                                SmallChange="1" LargeChange="10"
                                                DecimalPlaces="3"
                                                Width="100" Margin="4,2" HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- 旋转角度 -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="角度:" Style="{StaticResource LabelStyle}"/>
                            <Slider Grid.Column="1"
                                    Value="{Binding Parameters.Angle, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                    Minimum="-180" Maximum="180"
                                    TickFrequency="15"
                                    TickPlacement="BottomRight"
                                    Margin="4,2"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Parameters.Angle, StringFormat={}{0:F1}°}"
                                       VerticalAlignment="Center"
                                       Margin="4,2"
                                       Width="50"
                                       Foreground="#333"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 直线参数 -->
                <Border BorderBrush="#E0E0E0" BorderThickness="0,1" Padding="0,4" Margin="0,0,0,8"
                        Visibility="{Binding SelectedShapeType, Converter={StaticResource ShapeTypeToVisibilityConverter}, ConverterParameter='Line', FallbackValue=Collapsed}">
                    <StackPanel>
                        <TextBlock Text="直线端点 - 直线工具"
                                   FontSize="12"
                                   Foreground="#666"
                                   Margin="8,4"/>

                        <!-- 起点 -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="起点:" Style="{StaticResource LabelStyle}"/>
                            <ctrl:NumericUpDown Grid.Column="1"
                                                Value="{Binding Parameters.StartX, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                Minimum="0" Maximum="9999"
                                                SmallChange="1" LargeChange="10"
                                                DecimalPlaces="3"
                                                Width="100" Margin="4,2" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="Y:" Style="{StaticResource LabelStyle}" Margin="8,2,4,2"/>
                            <ctrl:NumericUpDown Grid.Column="3"
                                                Value="{Binding Parameters.StartY, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                Minimum="0" Maximum="9999"
                                                SmallChange="1" LargeChange="10"
                                                DecimalPlaces="3"
                                                Width="100" Margin="4,2" HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- 终点 -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="终点:" Style="{StaticResource LabelStyle}"/>
                            <ctrl:NumericUpDown Grid.Column="1"
                                                Value="{Binding Parameters.EndX, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                Minimum="0" Maximum="9999"
                                                SmallChange="1" LargeChange="10"
                                                DecimalPlaces="3"
                                                Width="100" Margin="4,2" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="Y:" Style="{StaticResource LabelStyle}" Margin="8,2,4,2"/>
                            <ctrl:NumericUpDown Grid.Column="3"
                                                Value="{Binding Parameters.EndY, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                Minimum="0" Maximum="9999"
                                                SmallChange="1" LargeChange="10"
                                                DecimalPlaces="3"
                                                Width="100" Margin="4,2" HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- 长度信息 -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="长度:" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding PreviewLength, StringFormat=F1}"
                                       VerticalAlignment="Center"
                                       Margin="4,2"
                                       Foreground="#333"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
