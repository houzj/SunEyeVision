<UserControl x:Class="SunEyeVision.Plugin.SDK.UI.Controls.Region.Views.RegionEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Views"
             xmlns:models="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Models"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- 形状按钮样式 -->
        <Style x:Key="ShapeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#C0C0C0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E8F4FC"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#2196F3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#CCE4F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 形状图标画笔 -->
        <SolidColorBrush x:Key="ShapeIconBrush" Color="#555"/>
        <SolidColorBrush x:Key="ShapeIconActiveBrush" Color="#1976D2"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 主内容区域 -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">
                <!-- 输入类型 -->
                <GroupBox Header="输入类型" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="绘制"
                                     GroupName="InputType"
                                     IsChecked="{Binding IsDrawingMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,16,0"
                                     ToolTip="手动绘制区域形状"/>
                        <RadioButton Content="订阅"
                                     GroupName="InputType"
                                     IsChecked="{Binding IsSubscribeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="订阅其他节点输出的区域"/>
                    </StackPanel>
                </GroupBox>

                <!-- 形状选择（绘制模式和按参数订阅模式显示） -->
                <GroupBox Header="形状" Margin="0,0,0,8"
                          Visibility="{Binding ShowShapeTypeSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <UniformGrid Columns="5" HorizontalAlignment="Center">
                        <!-- 选择按钮 - 退出绘制模式，进入选择/编辑模式 -->
                        <Button Style="{StaticResource ShapeButtonStyle}"
                                ToolTip="选择/编辑模式 (V)&#x0a;点击选中区域进行编辑&#x0a;可缩放平移图像"
                                Click="OnSelectButtonClick"
                                x:Name="SelectButton">
                            <Grid>
                                <!-- 箭头光标图标 -->
                                <Path Width="18" Height="18"
                                      Stroke="{StaticResource ShapeIconBrush}"
                                      StrokeThickness="1.5"
                                      Fill="{StaticResource ShapeIconBrush}"
                                      Data="M2,2 L2,14 L6,10 L9,16 L12,14 L9,8 L14,8 Z"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <!-- 矩形 -->
                        <Button Style="{StaticResource ShapeButtonStyle}"
                                ToolTip="矩形 (R)"
                                Click="OnRectangleButtonClick"
                                x:Name="RectangleButton">
                            <Grid>
                                <Rectangle Width="22" Height="22"
                                           Stroke="{StaticResource ShapeIconBrush}"
                                           StrokeThickness="2"
                                           Fill="Transparent"/>
                            </Grid>
                        </Button>

                        <!-- 圆形 -->
                        <Button Style="{StaticResource ShapeButtonStyle}"
                                ToolTip="圆形 (C)"
                                Click="OnCircleButtonClick"
                                x:Name="CircleButton">
                            <Grid>
                                <Ellipse Width="22" Height="22"
                                         Stroke="{StaticResource ShapeIconBrush}"
                                         StrokeThickness="2"
                                         Fill="Transparent"/>
                            </Grid>
                        </Button>

                        <!-- 旋转矩形 -->
                        <Button Style="{StaticResource ShapeButtonStyle}"
                                ToolTip="旋转矩形 (O)"
                                Click="OnRotatedRectangleButtonClick"
                                x:Name="RotatedRectangleButton">
                            <Grid>
                                <Rectangle Width="18" Height="18"
                                           Stroke="{StaticResource ShapeIconBrush}"
                                           StrokeThickness="2"
                                           Fill="Transparent"
                                           RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <RotateTransform Angle="45"/>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>
                        </Button>

                        <!-- 直线 -->
                        <Button Style="{StaticResource ShapeButtonStyle}"
                                ToolTip="直线 (L)"
                                Click="OnLineButtonClick"
                                x:Name="LineButton">
                            <Grid>
                                <Line X1="4" Y1="22" X2="22" Y2="4"
                                      Stroke="{StaticResource ShapeIconBrush}"
                                      StrokeThickness="2"/>
                            </Grid>
                        </Button>
                    </UniformGrid>
                </GroupBox>

                <!-- 输入方式（仅订阅模式显示） -->
                <GroupBox Header="输入方式" Margin="0,0,0,8"
                          Visibility="{Binding IsSubscribeMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="按区域"
                                     IsChecked="{Binding IsSubscribeByRegion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,16,0"
                                     ToolTip="直接绑定其他节点输出的区域"/>
                        <RadioButton Content="按参数"
                                     IsChecked="{Binding IsSubscribeByParameter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="每个参数可单独绑定其他节点输出"/>
                    </StackPanel>
                </GroupBox>

                <!-- 参数面板 - 绘制模式 -->
                <!-- 当有选中区域时才显示 -->
                <Expander Header="绘制参数"
                          Visibility="{Binding HasParametersVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                          IsExpanded="True"
                          Margin="0,0,0,8">
                    <local:DrawingParameterPanel DataContext="{Binding}"/>
                </Expander>

                <!-- 参数面板 - 订阅-按区域 -->
                <Expander Header="区域订阅"
                          Visibility="{Binding IsSubscribeByRegionMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                          IsExpanded="True"
                          Margin="0,0,0,8">
                    <local:RegionSubscribePanel DataContext="{Binding NodeSelector}"/>
                </Expander>

                <!-- 参数面板 - 订阅-按参数 -->
                <Expander Header="参数订阅"
                          Visibility="{Binding IsSubscribeByParameterMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                          IsExpanded="True"
                          Margin="0,0,0,8">
                    <local:ParameterPanel DataContext="{Binding ParameterPanel}"/>
                </Expander>

                <!-- 选中区域详细信息 -->
                <GroupBox Header="选中区域" Margin="0,0,0,8"
                          Visibility="Collapsed">
                    <local:RegionInfoPanel DataContext="{Binding SelectedRegion}"/>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部提示栏 -->
        <Border Grid.Row="1"
                Background="#F5F5F5"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 当前模式指示器 -->
                <Border Grid.Column="0"
                        Background="#E3F2FD"
                        CornerRadius="3"
                        Padding="6,2"
                        Margin="0,0,8,0">
                    <TextBlock Text="{Binding CurrentToolMode}"
                               FontSize="10"
                               Foreground="#1976D2"
                               FontWeight="Medium"/>
                </Border>

                <!-- 状态消息 -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="#666"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
