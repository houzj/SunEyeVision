<Popup x:Class="SunEyeVision.Plugin.SDK.UI.Controls.Region.Views.NodeSelectorPopup"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:converters="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Converters"
       Placement="Bottom"
       StaysOpen="False"
       AllowsTransparency="True"
       PopupAnimation="Fade"
       Width="350"
       MaxHeight="500">
    <Popup.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- 树状项样式 -->
        <Style x:Key="TreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="IsExpanded" Value="{Binding IsExpanded}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected}"/>
            <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_MouseDoubleClick"/>
            <EventSetter Event="KeyDown" Handler="TreeViewItem_KeyDown"/>
        </Style>
    </Popup.Resources>

    <Border Background="White"
            BorderBrush="#D0D0D0"
            BorderThickness="1"
            CornerRadius="4"
            Effect="{DynamicResource MaterialDesignShadowDepth1}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0"
                    Background="#F5F5F5"
                    Padding="12,8"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,0,1"
                    CornerRadius="4,4,0,0">
                <Grid>
                    <TextBlock Text="选择数据源"
                               FontWeight="Bold"
                               FontSize="13"
                               VerticalAlignment="Center"/>

                    <TextBlock Text="{Binding TargetDataType, StringFormat='目标类型: {0}'}"
                               FontSize="10"
                               Foreground="#888888"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 搜索框 -->
            <Border Grid.Row="1"
                    Background="White"
                    Padding="12,8"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,0,1">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6"
                         FontSize="12"
                         VerticalContentAlignment="Center"
                         BorderBrush="#D0D0D0"
                         BorderThickness="1">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text.Length, RelativeSource={RelativeSource Self}}" Value="0">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="搜索节点..."
                                                               Foreground="#AAAAAA"
                                                               FontSize="12"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Border>

            <!-- 树状结构 -->
            <TreeView Grid.Row="2"
                      ItemsSource="{Binding FilteredNodes}"
                      ItemContainerStyle="{StaticResource TreeItemStyle}"
                      BorderThickness="0"
                      Background="Transparent"
                      Padding="8,4"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <Grid Margin="4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 节点信息 -->
                            <StackPanel Grid.Column="0" Orientation="Vertical">
                                <!-- 节点名称 -->
                                <TextBlock Text="{Binding NodeName}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#333333"/>

                                <!-- 输出名称和路径 -->
                                <TextBlock FontSize="10" Foreground="#666666">
                                    <Run Text="{Binding OutputName}"/>
                                    <Run Text="{Binding PropertyPath, StringFormat='.{0}'}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- 类型匹配标识 -->
                            <Border Grid.Column="1"
                                    Background="#E8F5E9"
                                    BorderBrush="#4CAF50"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="6,2"
                                    Margin="4,0,0,0"
                                    Visibility="{Binding IsTypeMatched, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="✓"
                                           FontSize="11"
                                           Foreground="#4CAF50"
                                           FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>

                <TreeView.Style>
                    <Style TargetType="TreeView">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FilteredNodes.Count}" Value="0">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <TextBlock Text="没有找到匹配的节点"
                                                       FontSize="12"
                                                       Foreground="#888888"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,20"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.Style>
            </TreeView>

            <!-- 底部按钮栏 -->
            <Border Grid.Row="3"
                    Background="#FAFAFA"
                    Padding="12,8"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,4,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 选中项预览 -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding SelectionDisplayPath}"
                               FontSize="10"
                               Foreground="#666666"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,12,0"
                               Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- 清除按钮 -->
                    <Button Grid.Column="1"
                            Content="清除"
                            Command="{Binding ClearSelectionCommand}"
                            Padding="12,6"
                            Margin="0,0,8,0"
                            Background="Transparent"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            Cursor="Hand"/>

                    <!-- 确认按钮 -->
                    <Button Grid.Column="2"
                            Content="确认"
                            Command="{Binding SelectCommand}"
                            Padding="12,6"
                            Background="#2196F3"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Popup>
