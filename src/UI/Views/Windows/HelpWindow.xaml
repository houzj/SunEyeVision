<Window x:Class="SunEyeVision.UI.Views.Windows.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="太阳眼视觉 - 用户手册" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        Loaded="Window_Loaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/AppResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <!-- 右侧内容 -->
        <Border Padding="40">
            <ScrollViewer x:Name="ContentScroll" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 欢迎页面 -->
                    <TextBlock x:Name="HelpTitle" Text="欢迎使用 SunEyeVision" FontSize="24" FontWeight="Bold" Foreground="#0066CC" Margin="0,0,0,20"/>
                    <TextBlock x:Name="HelpContent" FontSize="14" Foreground="#333333" TextWrapping="Wrap" Margin="0,0,0,20">
                        <Run Text="SunEyeVision 是一款专业的机器视觉平台，提供强大的图像处理和工作流设计功能。本手册将帮助您快速上手并掌握各项功能。"/>
                        <LineBreak/><LineBreak/>
                        <Run Text="主要特性：" FontWeight="Bold"/>
                        <LineBreak/>
                        <Run Text="• 直观的可视化工作流编辑器"/>
                        <LineBreak/>
                        <Run Text="• 丰富的图像处理算法库"/>
                        <LineBreak/>
                        <Run Text="• 灵活的插件系统"/>
                        <LineBreak/>
                        <Run Text="• 支持多种相机和设备"/>
                        <LineBreak/>
                        <Run Text="• 高性能的图像处理引擎"/>
                        <LineBreak/><LineBreak/>
                        <Run Text="从左侧目录选择您想了解的主题。"/>
                    </TextBlock>

                    <!-- 查看完整文档按钮 -->
                    <Button x:Name="OpenFullDocsButton" Content="📄 查看完整帮助文档 (在浏览器中打开)" 
                            Click="OpenFullDocsButton_Click"
                            Padding="15,10" Margin="0,0,0,20"
                            FontSize="14" Background="#0066CC" Foreground="White"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0055AA"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#004488"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 快捷键列表 -->
                    <Border Background="#F0F8FF" BorderBrush="#0066CC" BorderThickness="1" Padding="15" CornerRadius="5" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="常用快捷键" FontSize="16" FontWeight="Bold" Foreground="#0066CC" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="新建" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Ctrl+N" VerticalAlignment="Center" Margin="0,5" Foreground="#0066CC" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="打开" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Ctrl+O" VerticalAlignment="Center" Margin="0,5" Foreground="#0066CC" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="保存" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Ctrl+S" VerticalAlignment="Center" Margin="0,5" Foreground="#0066CC" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="运行" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="F5" VerticalAlignment="Center" Margin="0,5" Foreground="#0066CC" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="停止" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="Shift+F5" VerticalAlignment="Center" Margin="0,5" Foreground="#0066CC" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="单步执行" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="F10" VerticalAlignment="Center" Margin="0,5" Foreground="#0066CC" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="撤销" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="Ctrl+Z" VerticalAlignment="Center" Margin="0,5" Foreground="#0066CC" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="重做" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="Ctrl+Y" VerticalAlignment="Center" Margin="0,5" Foreground="#0066CC" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="删除" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="Del" VerticalAlignment="Center" Margin="0,5" Foreground="#0066CC" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="9" Grid.Column="0" Text="帮助" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBlock Grid.Row="9" Grid.Column="1" Text="F1" VerticalAlignment="Center" Margin="0,5" Foreground="#0066CC" FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 联系方式 -->
                    <Border Background="#FFF8F0" BorderBrush="#FF9900" BorderThickness="1" Padding="15" CornerRadius="5" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="需要帮助？" FontSize="16" FontWeight="Bold" Foreground="#FF9900" Margin="0,0,0,10"/>
                            <TextBlock FontSize="13" TextWrapping="Wrap" Foreground="#333333">
                                <Run Text="如果您在使用过程中遇到问题或有任何建议，欢迎联系我们："/>
                                <LineBreak/><LineBreak/>
                                <Run Text="官方网站：https://www.suneyevision.com" FontWeight="SemiBold"/>
                                <LineBreak/>
                                <Run Text="技术支持：support@suneyevision.com" FontWeight="SemiBold"/>
                                <LineBreak/>
                                <Run Text="QQ群：123456789" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
