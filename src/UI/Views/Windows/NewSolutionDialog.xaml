<Window x:Class="SunEyeVision.UI.Views.Windows.NewSolutionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="新建解决方案"
        Width="450"
        Height="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="新建解决方案" FontSize="20" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,20"/>

        <!-- 解决方案名称 -->
        <TextBlock Grid.Row="1" Text="解决方案名称" FontSize="13" FontWeight="Medium" Foreground="#424242" Margin="0,0,0,8"/>
        <TextBox Grid.Row="2"
                 Name="SolutionNameTextBox"
                 FontSize="13"
                 Padding="8,6"
                 Background="White"
                 BorderBrush="#E0E0E0"
                 BorderThickness="1"
                 Margin="0,0,0,15"
                 TextChanged="OnSolutionNameTextChanged"/>

        <!-- 描述 -->
        <TextBlock Grid.Row="3" Text="描述（可选）" FontSize="13" FontWeight="Medium" Foreground="#424242" Margin="0,0,0,8"/>
        <TextBox Grid.Row="4"
                 Name="DescriptionTextBox"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Height="80"
                 FontSize="13"
                 Padding="8,6"
                 Background="White"
                 BorderBrush="#E0E0E0"
                 BorderThickness="1"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,15"/>

        <!-- 存储路径 -->
        <TextBlock Grid.Row="5" Text="存储路径" FontSize="13" FontWeight="Medium" Foreground="#424242" Margin="0,0,0,8"/>
        <Grid Grid.Row="6" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Name="SolutionPathTextBox"
                     FontSize="13"
                     Padding="8,6"
                     Background="White"
                     BorderBrush="#E0E0E0"
                     BorderThickness="1"
                     IsReadOnly="True"
                     TextWrapping="Wrap"/>

            <Button Grid.Column="1"
                    Content="浏览..."
                    Width="80"
                    Height="36"
                    Margin="8,0,0,0"
                    Padding="0"
                    Click="OnBrowseButtonClick"
                    FontSize="13"
                    Cursor="Hand"
                    Background="#2196F3"
                    Foreground="White"
                    BorderThickness="0"/>
        </Grid>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消"
                    Width="100"
                    Height="36"
                    Margin="0,0,8,0"
                    Padding="0"
                    FontSize="13"
                    Click="OnCancelButtonClick"
                    Cursor="Hand"
                    Background="#9E9E9E"
                    Foreground="White"
                    BorderThickness="0"/>
            <Button Name="CreateButton"
                    Content="创建"
                    Width="100"
                    Height="36"
                    Margin="0,0,0,0"
                    Padding="0"
                    FontSize="13"
                    Click="OnCreateButtonClick"
                    IsEnabled="False"
                    Cursor="Hand"
                    Background="#2196F3"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
