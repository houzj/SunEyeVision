<Window x:Class="SunEyeVision.UI.Views.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="关于 太阳眼视觉" Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFFFF">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/AppResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo和标题 -->
        <Border Grid.Row="0" Background="#E8F4F8" CornerRadius="10" Padding="20" Margin="0,0,0,20">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="👁️" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="太阳眼视觉" FontSize="32" FontWeight="Bold" Foreground="#0066CC" HorizontalAlignment="Center"/>
                <TextBlock Text="SunEye Vision" FontSize="16" Foreground="#666666" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- 详细信息 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="版本：" FontSize="13" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="v1.0.0.0" FontSize="13" Foreground="#0066CC" VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="发布日期：" FontSize="13" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="2026年2月" FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="运行平台：" FontSize="13" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Windows 10/11" FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text=".NET版本：" FontSize="13" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="9.0" FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
            </Grid>

            <Separator Margin="0,15"/>

            <TextBlock Text="专业的机器视觉平台" FontSize="14" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center" Margin="0,10"/>
            <TextBlock Text="提供强大的图像处理和工作流设计功能" FontSize="12" Foreground="#666666" HorizontalAlignment="Center" TextWrapping="Wrap"/>

            <Border Background="#F0F8FF" BorderBrush="#0066CC" BorderThickness="1" Padding="10" CornerRadius="5" Margin="0,15">
                <StackPanel>
                    <TextBlock Text="主要特性：" FontSize="12" FontWeight="Bold" Foreground="#0066CC"/>
                    <TextBlock Text="• 可视化工作流编辑器" FontSize="11" Foreground="#333333"/>
                    <TextBlock Text="• 丰富的图像处理算法" FontSize="11" Foreground="#333333"/>
                    <TextBlock Text="• 灵活的插件系统" FontSize="11" Foreground="#333333"/>
                    <TextBlock Text="• 多设备支持" FontSize="11" Foreground="#333333"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 按钮和链接 -->
        <StackPanel Grid.Row="2">
            <Button Content="检查更新" Click="CheckUpdate_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,5"/>
            <Button Content="用户手册" Click="HelpManual_Click" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,5"/>
            <Button Content="关闭" Click="CloseButton_Click" Style="{StaticResource PrimaryButton}" Padding="10,6" Margin="0,15,0,0"/>

            <TextBlock FontSize="11" Foreground="#999999" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Run Text="© 2026 SunEye Vision. All rights reserved."/>
                <LineBreak/>
                <Hyperlink Click="Website_Click" Foreground="#0066CC">
                    <Run Text="www.suneyevision.com" Foreground="#0066CC"/>
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
