<Window x:Class="SunEyeVision.UI.Views.Windows.AddCameraDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SunEyeVision.UI.Views.Windows"
        xmlns:camera="clr-namespace:SunEyeVision.Core.Services.CameraDiscovery;assembly=SunEyeVision.Core"
        mc:Ignorable="d"
        Title="添加相机"
        Width="700"
        Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F5F5">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 类型选择 -->
        <GroupBox Grid.Row="0" Header="选择类型" Margin="0,0,0,12" Padding="12">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="GigE" Margin="0,0,16,0" 
                           GroupName="CameraType"
                           IsChecked="{Binding SelectedType, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=GigE}"
                           FontSize="14"/>
                <RadioButton Content="USB" Margin="0,0,16,0"
                           GroupName="CameraType"
                           IsChecked="{Binding SelectedType, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=USB}"
                           FontSize="14"/>
                <RadioButton Content="IP"
                           GroupName="CameraType"
                           IsChecked="{Binding SelectedType, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=IP}"
                           FontSize="14"/>
            </StackPanel>
        </GroupBox>
        
        <!-- 搜索按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="🔍 搜索相机"
                    Command="{Binding SearchCommand}"
                    Width="120" Height="32" Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="⏸ 停止"
                    Command="{Binding StopCommand}"
                    Width="80" Height="32"
                    Style="{StaticResource SecondaryButtonStyle}"/>
            <TextBlock Text="{Binding SearchStatus}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       FontSize="13"
                       Foreground="#757575"/>
        </StackPanel>
        
        <!-- 相机列表 -->
        <GroupBox Grid.Row="2" Header="发现的相机" Margin="0,0,0,12" Padding="12">
            <ListBox ItemsSource="{Binding DiscoveredCameras}"
                     SelectedItem="{Binding SelectedCamera}"
                     Height="200"
                     BorderThickness="1"
                     BorderBrush="#E0E0E0"
                     Background="White">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected}" Margin="4">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="14" Foreground="#333333"/>
                                <TextBlock FontSize="12" Foreground="#757575" Margin="0,2,0,0">
                                    <Run Text="IP: "/>
                                    <Run Text="{Binding IpAddress}"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="#757575" Margin="0,2,0,0">
                                    <Run Text="制造商: "/>
                                    <Run Text="{Binding Manufacturer}"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="#757575" Margin="0,2,0,0">
                                    <Run Text="型号: "/>
                                    <Run Text="{Binding Model}"/>
                                </TextBlock>
                            </StackPanel>
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
        
        <!-- 相机名称 -->
        <GroupBox Grid.Row="3" Header="相机名称" Margin="0,0,0,12" Padding="12">
            <StackPanel>
                <TextBox Text="{Binding CameraName, UpdateSourceTrigger=PropertyChanged}" 
                         Height="32" Padding="8" 
                         FontSize="14"
                         BorderThickness="1"
                         BorderBrush="#E0E0E0"/>
                <TextBlock FontSize="12" Foreground="#999999" Margin="0,4,0,0">
                    <Run Text="（自动生成: "/>
                    <Run Text="{Binding SelectedCamera.Manufacturer, FallbackValue='未知'}"/>
                    <Run Text="-"/>
                    <Run Text="{Binding SelectedCamera.Model, FallbackValue='未知'}"/>
                    <Run Text="-001）"/>
                </TextBlock>
            </StackPanel>
        </GroupBox>
        
        <!-- 连接信息（可选） -->
        <GroupBox Grid.Row="4" Header="连接信息（可选）" Margin="0,0,0,12" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="用户名:" VerticalAlignment="Center" Margin="0,0,8,4" FontSize="13" Foreground="#333333"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Username}" Height="32" Margin="0,0,16,4" 
                         Padding="8" FontSize="14" BorderThickness="1" BorderBrush="#E0E0E0"/>
                
                <TextBlock Grid.Row="0" Grid.Column="2" Text="密码:" VerticalAlignment="Center" Margin="0,0,8,4" FontSize="13" Foreground="#333333"/>
                <PasswordBox Grid.Row="0" Grid.Column="3" Height="32" Margin="0,0,0,4" 
                           Padding="8" FontSize="14" BorderThickness="1" BorderBrush="#E0E0E0"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="端口:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13" Foreground="#333333"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port}" Height="32" Margin="0,0,0,0" 
                         Padding="8" FontSize="14" BorderThickness="1" BorderBrush="#E0E0E0"/>
            </Grid>
        </GroupBox>
        
        <!-- 厂商 SDK 选项 -->
        <CheckBox Grid.Row="5" Content="使用厂商 SDK 增强功能（需要额外配置）" 
                  IsChecked="{Binding UseVendorSdk}" 
                  Margin="0,0,0,12"
                  FontSize="13" Foreground="#333333"/>
        
        <!-- 底部按钮 -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定"
                    Command="{Binding ConfirmCommand}"
                    Width="80" Height="32" Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="取消"
                    Command="{Binding CancelCommand}"
                    Width="80" Height="32"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
