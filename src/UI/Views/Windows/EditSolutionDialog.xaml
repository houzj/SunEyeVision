<Window x:Class="SunEyeVision.UI.Views.Windows.EditSolutionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="编辑解决方案"
        Width="450"
        Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="编辑解决方案" FontSize="20" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,20"/>

        <!-- 解决方案名称 -->
        <TextBlock Grid.Row="1" Text="解决方案名称" FontSize="13" FontWeight="Medium" Foreground="#424242" Margin="0,0,0,8"/>
        <TextBox Grid.Row="2"
                 Name="SolutionNameTextBox"
                 FontSize="13"
                 Padding="8,6"
                 Background="White"
                 BorderBrush="#E0E0E0"
                 BorderThickness="1"
                 Margin="0,0,0,15"
                 TextChanged="OnSolutionNameTextChanged"/>

        <!-- 描述 -->
        <TextBlock Grid.Row="3" Text="描述（可选）" FontSize="13" FontWeight="Medium" Foreground="#424242" Margin="0,0,0,8"/>
        <TextBox Grid.Row="4"
                 Name="DescriptionTextBox"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Height="80"
                 FontSize="13"
                 Padding="8,6"
                 Background="White"
                 BorderBrush="#E0E0E0"
                 BorderThickness="1"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,15"/>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消"
                    Width="100"
                    Height="36"
                    Margin="0,0,8,0"
                    Padding="0"
                    FontSize="13"
                    Click="OnCancelButtonClick"
                    Cursor="Hand"
                    Background="#9E9E9E"
                    Foreground="White"
                    BorderThickness="0"/>
            <Button Name="SaveButton"
                    Content="保存"
                    Width="100"
                    Height="36"
                    Margin="0,0,0,0"
                    Padding="0"
                    FontSize="13"
                    Click="OnSaveButtonClick"
                    IsEnabled="False"
                    Cursor="Hand"
                    Background="#2196F3"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
