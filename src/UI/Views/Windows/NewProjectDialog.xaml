<Window x:Class="SunEyeVision.UI.Views.Windows.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="新建项目"
        Width="450"
        SizeToContent="Height"
        MaxHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 项目名称 -->
        <TextBlock Grid.Row="0" Text="项目名称:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="1"
                 Name="ProjectNameTextBox"
                 Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,15"/>

        <!-- 项目路径 -->
        <TextBlock Grid.Row="2" Text="项目路径:" Margin="0,0,0,5"/>
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding ProjectPath, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"/>

            <Button Grid.Column="1"
                    Content="浏览..."
                    Name="BrowseButton"
                    Width="80"
                    Margin="5,0,0,0"
                    Click="BrowseButton_Click"/>
        </Grid>

        <!-- 预期路径 -->
        <TextBlock Grid.Row="4" Text="预期路径:" Margin="0,0,0,5" Foreground="Gray" FontSize="11"/>
        <TextBlock Grid.Row="5"
                 Text="{Binding ExpectedProjectPath}"
                 Foreground="DarkGray"
                 FontSize="11"
                 TextWrapping="Wrap"
                 Margin="0,0,0,15"/>

        <!-- 描述 -->
        <TextBlock Grid.Row="6" Text="描述:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="7"
                 Name="DescriptionTextBox"
                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 Height="80"
                 Margin="0,0,0,15"/>

        <!-- 按钮 -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="取消"
                    Width="80"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="确定"
                    Name="OkButton"
                    Width="80"
                    Height="30"
                    Click="OkButton_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
