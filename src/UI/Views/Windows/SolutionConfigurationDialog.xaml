<Window x:Class="SunEyeVision.UI.Views.Windows.SolutionConfigurationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="太阳眼视觉 - 解决方案配置"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 主要内容：项目列表 + 配方列表 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：项目列表 -->
            <GroupBox Grid.Column="0" Header="📁 项目列表">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 工具栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="+ 新建"
                                Command="{Binding NewProjectCommand}"
                                Width="80"
                                Margin="0,0,5,0"/>
                        <Button Content="打开"
                                Command="{Binding OpenProjectCommand}"
                                Width="80"
                                Margin="0,0,5,0"/>
                        <Button Content="另存为"
                                Command="{Binding SaveProjectAsCommand}"
                                Width="80"
                                Margin="0,0,5,0"/>
                        <Button Content="删除"
                                Command="{Binding DeleteProjectCommand}"
                                Width="80"/>
                    </StackPanel>

                    <!-- 项目列表 -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Projects}"
                             SelectedItem="{Binding SelectedProject}"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               FontSize="14"/>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="12"
                                               Foreground="Gray"/>
                                    <TextBlock Text="{Binding ModifiedTime, StringFormat='修改: {0:yyyy-MM-dd}'}"
                                               FontSize="10"
                                               Foreground="DarkGray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>

            <!-- 右侧：配方列表 -->
            <GroupBox Grid.Column="2" Header="📋 配方列表">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 工具栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="+ 添加"
                                Command="{Binding AddRecipeCommand}"
                                Width="80"
                                Margin="0,0,5,0"/>
                        <Button Content="复制"
                                Command="{Binding DuplicateRecipeCommand}"
                                Width="80"
                                Margin="0,0,5,0"/>
                        <Button Content="另存为"
                                Command="{Binding SaveRecipeAsCommand}"
                                Width="80"
                                Margin="0,0,5,0"/>
                        <Button Content="删除"
                                Command="{Binding DeleteRecipeCommand}"
                                Width="80"/>
                    </StackPanel>

                    <!-- 配方列表 -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Recipes}"
                             SelectedItem="{Binding SelectedRecipe}"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               FontSize="14"/>
                                    <TextBlock Text="{Binding Device.DeviceName, FallbackValue='未配置设备'}"
                                               FontSize="12"
                                               Foreground="Gray"/>
                                    <TextBlock Text="{Binding ModifiedTime, StringFormat='修改: {0:yyyy-MM-dd}'}"
                                               FontSize="10"
                                               Foreground="DarkGray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 详情信息：项目详情 + 配方详情 -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 项目详情 -->
            <GroupBox Grid.Column="0" Header="项目详情">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 项目名称（可修改） -->
                    <TextBlock Grid.Row="0" Text="项目名称:" VerticalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="1"
                             Text="{Binding SelectedProject.Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             IsEnabled="{Binding HasSelectedProject}"/>

                    <!-- 描述（可修改） -->
                    <TextBlock Grid.Row="2" Text="描述:" VerticalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="3"
                             Text="{Binding SelectedProject.Description, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Height="60"
                             Margin="0,0,0,10"
                             IsEnabled="{Binding HasSelectedProject}"/>

                    <!-- 存储路径（只读） -->
                    <TextBlock Grid.Row="4" Text="存储路径:" VerticalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Grid.Row="5" Text="{Binding ProjectStoragePath}"
                               TextWrapping="Wrap"
                               Foreground="Gray"
                               Margin="0,0,0,10"/>

                    <!-- 其他信息（只读） -->
                    <TextBlock Grid.Row="6" Text="{Binding ProjectInfo}"
                               TextWrapping="Wrap"
                               Foreground="Gray"/>
                </Grid>
            </GroupBox>

            <!-- 配方详情 -->
            <GroupBox Grid.Column="2" Header="配方详情">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 配方名称（可修改） -->
                    <TextBlock Grid.Row="0" Text="配方名称:" VerticalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="1"
                             Text="{Binding SelectedRecipe.Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             IsEnabled="{Binding HasSelectedRecipe}"/>

                    <!-- 描述（可修改） -->
                    <TextBlock Grid.Row="2" Text="描述:" VerticalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="3"
                             Text="{Binding SelectedRecipe.Description, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Height="60"
                             Margin="0,0,0,10"
                             IsEnabled="{Binding HasSelectedRecipe}"/>

                    <!-- 存储路径（只读） -->
                    <TextBlock Grid.Row="4" Text="存储路径:" VerticalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Grid.Row="5" Text="{Binding RecipeStoragePath}"
                               TextWrapping="Wrap"
                               Foreground="Gray"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 底部：跳过选项 + 按钮 -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 跳过选项 -->
            <CheckBox Grid.Column="0"
                      Content="启动时跳过配置界面"
                      IsChecked="{Binding SkipStartupConfig}"
                      VerticalAlignment="Center"
                      Margin="10,0"/>

            <!-- 按钮组 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="跳过配置"
                        Command="{Binding SkipCommand}"
                        Width="100"
                        Height="30"
                        Margin="5,0"/>
                <Button Content="删除项目"
                        Command="{Binding DeleteProjectCommand}"
                        Width="100"
                        Height="30"
                        Margin="5,0"/>
                <Button Content="启动"
                        Command="{Binding LaunchCommand}"
                        Width="100"
                        Height="30"
                        Margin="5,0"
                        FontWeight="Bold"
                        Background="Green"
                        Foreground="White"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
