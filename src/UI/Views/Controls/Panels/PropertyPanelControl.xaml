<UserControl x:Class="SunEyeVision.UI.Views.Controls.Panels.PropertyPanelControl"
             x:Name="PropertyPanelRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SunEyeVision.UI.Models"
             xmlns:converters="clr-namespace:SunEyeVision.UI.Converters.Visibility"
             xmlns:logging="clr-namespace:SunEyeVision.Plugin.SDK.Logging;assembly=SunEyeVision.Plugin.SDK"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">
    
    <UserControl.Resources>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>

        <!-- 右键菜单项样式 - 与选中行样式一致 -->
        <Style TargetType="MenuItem" x:Key="ContextMenuMenuItemStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4,8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <!-- 鼠标悬停 -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
                <!-- 选中状态 - 深蓝色背景 + 白色文字 -->
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 右键菜单容器样式 -->
        <Style TargetType="ContextMenu" x:Key="LogContextMenuStyle">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="0"
            VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 属性面板标题 -->
            <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="8,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚙️" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="属性面板" Margin="6,0,0,0" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 属性内容 -->
            <TabControl Grid.Row="1" Background="#FFFFFF" BorderThickness="0" SelectionChanged="TabControl_SelectionChanged">
                <!-- 工具参数标签页 -->
                <TabItem Header="🔧 工具参数">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="4">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding PropertyGroups, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Header="{Binding Name}" IsExpanded="{Binding IsExpanded}" Margin="0,4" BorderBrush="#E0E0E0" BorderThickness="1">
                                            <ItemsControl ItemsSource="{Binding Parameters}" Margin="0,4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" 
                                                                       Text="{Binding Label}" 
                                                                       VerticalAlignment="Center" 
                                                                       FontSize="11" 
                                                                       Foreground="#666666"/>
                                                            <ContentPresenter Grid.Column="1" 
                                                                          Content="{Binding Value}" 
                                                                          VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 无选中节点时的提示 -->
                            <TextBlock x:Name="NoSelectionText"
                                       Text="请选择一个节点以查看其属性"
                                       Foreground="#999999" 
                                       FontSize="12" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       Margin="20">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PropertyGroups.Count, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PropertyGroups.Count, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- 日志标签页 - 高性能虚拟化渲染 -->
                <TabItem Header="📋 日志">
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 日志工具栏 -->
                        <Border Grid.Row="0" Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 日志级别过滤器 -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                                    <CheckBox Content="ℹ" IsChecked="{Binding ShowInfo, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" 
                                              ToolTip="信息" Margin="2,0" Foreground="#2196F3" FontWeight="Bold"/>
                                    <CheckBox Content="✓" IsChecked="{Binding ShowSuccess, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" 
                                              ToolTip="成功" Margin="2,0" Foreground="#4CAF50" FontWeight="Bold"/>
                                    <CheckBox Content="⚠" IsChecked="{Binding ShowWarning, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" 
                                              ToolTip="警告" Margin="2,0" Foreground="#FF9800" FontWeight="Bold"/>
                                    <CheckBox Content="✖" IsChecked="{Binding ShowError, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" 
                                              ToolTip="错误" Margin="2,0" Foreground="#F44336" FontWeight="Bold"/>
                                </StackPanel>

                                <Separator Grid.Column="1" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>

                                <!-- 搜索框 -->
                                <TextBox Grid.Column="2" 
                                         Text="{Binding SearchText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Width="120" 
                                         VerticalContentAlignment="Center"
                                         FontSize="11"
                                         Margin="0,0,8,0">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Tag" Value="搜索日志..."/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="🔍 搜索..." Foreground="#999" FontSize="11" Margin="4,0"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <!-- 操作按钮 -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                    <Button x:Name="TestBtn"
                                            Content="🧪 测试"
                                            FontSize="10"
                                            Padding="6,2"
                                            Margin="2,0"
                                            ToolTip="测试按钮绑定"/>
                                    <Button x:Name="TestClearBtn"
                                            Content="🧪 测试清空"
                                            FontSize="10"
                                            Padding="6,2"
                                            Margin="2,0"
                                            ToolTip="测试直接清空方法"/>
                                    <Button x:Name="CopyBtn"
                                            Content="📋 复制选中"
                                            FontSize="10"
                                            Padding="6,2"
                                            Margin="2,0"
                                            ToolTip="复制选中的日志"/>
                                    <Button x:Name="CopyAllBtn"
                                            Content="📋 复制全部"
                                            FontSize="10"
                                            Padding="6,2"
                                            Margin="2,0"
                                            ToolTip="复制所有日志"/>
                                    <Button x:Name="ClearLogBtn"
                                            Content="🗑️ 清空"
                                            FontSize="10"
                                            Padding="6,2"
                                            Margin="2,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 日志 DataGrid - 虚拟化渲染 -->
                        <DataGrid x:Name="LogDataGrid"
                                  Grid.Row="1"
                                  Tag="{Binding RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  ItemsSource="{Binding LogEntriesView, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F0F0F0"
                                  VerticalGridLinesBrush="Transparent"
                                  BorderThickness="0"
                                  Background="#FAFAFA"
                                  AlternatingRowBackground="#FFFFFF"
                                  RowBackground="#FAFAFA"
                                  RowHeaderWidth="0"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  FontFamily="Consolas, Courier New, monospace"
                                  FontSize="11"
                                  Loaded="LogDataGrid_Loaded"
                                  ScrollViewer.ScrollChanged="LogDataGrid_ScrollChanged">
                            <DataGrid.Columns>
                                <!-- 时间列 -->
                                <DataGridTextColumn Header="时间"
                                                    Binding="{Binding FormattedTime}"
                                                    Width="85"
                                                    FontSize="10">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                            <Setter Property="Foreground" Value="#888"/>
                                            <Style.Triggers>
                                                <!-- 选中时使用白色文字 -->
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- 级别列 - 矢量图标 -->
                                <DataGridTemplateColumn Header="级别" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="22" Height="22"
                                                    CornerRadius="11"
                                                    Background="{Binding LevelIconBackground}"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center">
                                                <Path Width="14" Height="14"
                                                      Data="{Binding LevelIconPath}"
                                                      Fill="{Binding LevelIconFill}"
                                                      Stretch="Uniform"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      RenderOptions.EdgeMode="Aliased"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 信息列 - 显示格式化消息（包含来源前缀） -->
                                <DataGridTextColumn Header="信息"
                                                    Binding="{Binding DisplayMessage}"
                                                    Width="*"
                                                    FontSize="11">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                            <Setter Property="TextWrapping" Value="NoWrap"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Style.Triggers>
                                                <!-- 选中时使用白色文字 -->
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>

                            <!-- 行样式 -->
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Height" Value="Auto"/>
                                    <Setter Property="MinHeight" Value="26"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Style.Triggers>
                                        <!-- 鼠标悬停 - 仅未选中时 -->
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter Property="Background" Value="#F5F5F5"/>
                                        </MultiTrigger>
                                        <!-- 错误日志背景 - 仅未选中时 -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Level}" Value="{x:Static logging:LogLevel.Error}"/>
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#FFF5F5"/>
                                        </MultiDataTrigger>
                                        <!-- 警告日志背景 - 仅未选中时 -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Level}" Value="{x:Static logging:LogLevel.Warning}"/>
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#FFF8E5"/>
                                        </MultiDataTrigger>
                                        <!-- 成功日志背景 - 仅未选中时 -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Level}" Value="{x:Static logging:LogLevel.Success}"/>
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#F5FFF5"/>
                                        </MultiDataTrigger>
                                        <!-- 选中状态 - 始终使用深蓝色高亮，无论是否活动 -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1976D2"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <!-- 单元格样式 - 确保选中时文字清晰可见 -->
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Style.Triggers>
                                        <!-- 选中时始终使用白色文字，确保在深蓝色背景上清晰可见 -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>

                            <!-- 上下文菜单 -->
                            <DataGrid.ContextMenu>
                                <ContextMenu Style="{StaticResource LogContextMenuStyle}">
                                    <MenuItem Header="📋 复制选中行" Click="CopySelectedLogsFromDataGrid_Click" Style="{StaticResource ContextMenuMenuItemStyle}"/>
                                    <MenuItem Header="📋 复制消息" Click="CopyMessage_Click" Style="{StaticResource ContextMenuMenuItemStyle}"/>
                                    <Separator/>
                                    <MenuItem Header="🗑️ 清空日志" Click="ClearLogs_Click" Style="{StaticResource ContextMenuMenuItemStyle}"/>
                                    <Separator/>
                                    <MenuItem Header="🔍 全选" Click="SelectAll_Click" Style="{StaticResource ContextMenuMenuItemStyle}"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>

                        <!-- 状态栏 -->
                        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="8,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           FontSize="10"
                                           Foreground="#666">
                                    <Run Text="已记录: "/>
                                    <Run Text="{Binding TotalEnqueued, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}" FontWeight="Bold"/>
                                </TextBlock>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalCount, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='显示: {0}', Mode=OneWay}"
                                           FontSize="10"
                                           Foreground="#888"
                                           Margin="8,0,0,0"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding ErrorCount, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='错误: {0}', Mode=OneWay}"
                                           FontSize="10"
                                           Foreground="#CC0000"
                                           HorizontalAlignment="Center"
                                           Visibility="{Binding ErrorCount, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource IntToVisibilityConverter}}"/>

                                <TextBlock Grid.Column="3"
                                           Text="{Binding WarningCount, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='警告: {0}', Mode=OneWay}"
                                           FontSize="10"
                                           Foreground="#CC7700"
                                           HorizontalAlignment="Center"
                                           Margin="8,0"
                                           Visibility="{Binding WarningCount, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource IntToVisibilityConverter}}"/>

                                <TextBlock Grid.Column="4"
                                           FontSize="10"
                                           Foreground="#666">
                                    <Run Text="✅ 零阻塞"/>
                                    <Run Text=" | "/>
                                    <Run Text="⚡ 批量更新"/>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
