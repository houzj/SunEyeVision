<UserControl x:Class="SunEyeVision.UI.Views.Controls.Panels.PropertyPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <Border Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="0"
            VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 属性面板标题 -->
            <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="8,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚙️" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="属性面板" Margin="6,0,0,0" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 属性内容 -->
            <TabControl Grid.Row="1" Background="#FFFFFF" BorderThickness="0" SelectionChanged="TabControl_SelectionChanged">
                <!-- 工具参数标签页 -->
                <TabItem Header="🔧 工具参数">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="4">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding PropertyGroups, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Header="{Binding Name}" IsExpanded="{Binding IsExpanded}" Margin="0,4" BorderBrush="#E0E0E0" BorderThickness="1">
                                            <ItemsControl ItemsSource="{Binding Parameters}" Margin="0,4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" 
                                                                       Text="{Binding Label}" 
                                                                       VerticalAlignment="Center" 
                                                                       FontSize="11" 
                                                                       Foreground="#666666"/>
                                                            <ContentPresenter Grid.Column="1" 
                                                                          Content="{Binding Value}" 
                                                                          VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 无选中节点时的提示 -->
                            <TextBlock x:Name="NoSelectionText"
                                       Text="请选择一个节点以查看其属性"
                                       Foreground="#999999" 
                                       FontSize="12" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       Margin="20">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PropertyGroups.Count, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PropertyGroups.Count, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- 信息标签页 -->
                <TabItem Header="📖 信息">
                    <Grid Margin="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      x:Name="LogScrollViewer">
                            <TextBox x:Name="LogTextBox"
                                     IsReadOnly="True"
                                     Background="#F8F8F8"
                                     BorderThickness="0"
                                     FontFamily="Consolas, Courier New, monospace"
                                     FontSize="10"
                                     Padding="8"
                                     TextWrapping="Wrap"
                                     Text="{Binding LogText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     VerticalAlignment="Stretch"
                                     MinHeight="200"
                                     Loaded="LogTextBox_Loaded"
                                     TextChanged="LogTextBox_TextChanged"
                                     Tag="{Binding ClearLogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <TextBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="🗑️ 清空日志"
                                                  Command="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="📋 复制"
                                                  Command="Copy"/>
                                        <MenuItem Header="🔍 全选"
                                                  Command="SelectAll"/>
                                    </ContextMenu>
                                </TextBox.ContextMenu>
                            </TextBox>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
