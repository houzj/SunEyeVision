<UserControl x:Class="SunEyeVision.UI.Views.Controls.Panels.LogPanelControl"
             x:Name="LogPanelRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:logging="clr-namespace:SunEyeVision.Plugin.SDK.Logging;assembly=SunEyeVision.Plugin.SDK"
             xmlns:converters="clr-namespace:SunEyeVision.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="600"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>

        <!-- 右键菜单项样式 - 与选中行样式一致 -->
        <Style TargetType="MenuItem" x:Key="ContextMenuMenuItemStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4,8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <!-- 鼠标悬停 -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
                <!-- 选中状态 - 深蓝色背景 + 白色文字 -->
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 右键菜单容器样式 -->
        <Style TargetType="ContextMenu" x:Key="LogContextMenuStyle">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <!-- DataGrid 行样式 -->
        <Style TargetType="DataGridRow" x:Key="LogDataRowStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="2"/>
            <Style.Triggers>
                <!-- 鼠标悬停效果 -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
                <!-- 选中效果 - 深蓝色背景 -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid 单元格样式 -->
        <Style TargetType="DataGridCell" x:Key="LogDataCellStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <!-- 选中时继承行的背景色 -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid 文本块样式（用于 DataGridTextColumn.ElementStyle） -->
        <Style TargetType="TextBlock" x:Key="LogDataTextBlockStyle">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,2"/>
        </Style>

        <!-- DataGrid 样式 -->
        <Style TargetType="DataGrid" x:Key="LogDataGridStyle">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEEEEE"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="AlternatingRowBackground" Value="Transparent"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="RowStyle" Value="{StaticResource LogDataRowStyle}"/>
            <Setter Property="CellStyle" Value="{StaticResource LogDataCellStyle}"/>
            <Setter Property="SelectionMode" Value="Extended"/>
        </Style>

        <!-- 过滤按钮样式 -->
        <Style TargetType="ToggleButton" x:Key="LogFilterToggleButtonStyle">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- 鼠标悬停 -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
                <!-- 选中状态 -->
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="0"
            VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部工具栏 -->
            <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="6,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：过滤按钮 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <ToggleButton Content="信息"
                                      IsChecked="{Binding ShowInfo, Mode=TwoWay}"
                                      Style="{StaticResource LogFilterToggleButtonStyle}"/>
                        <ToggleButton Content="成功"
                                      IsChecked="{Binding ShowSuccess, Mode=TwoWay}"
                                      Style="{StaticResource LogFilterToggleButtonStyle}"/>
                        <ToggleButton Content="警告"
                                      IsChecked="{Binding ShowWarning, Mode=TwoWay}"
                                      Style="{StaticResource LogFilterToggleButtonStyle}"/>
                        <ToggleButton Content="错误"
                                      IsChecked="{Binding ShowError, Mode=TwoWay}"
                                      Style="{StaticResource LogFilterToggleButtonStyle}"/>
                    </StackPanel>

                    <!-- 中间：搜索框 -->
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             Padding="6,3"
                             FontSize="11"
                             Margin="8,0,8,0"
                             VerticalAlignment="Center"
                             BorderBrush="#DDDDDD"
                             BorderThickness="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                    VerticalAlignment="Center"/>
                                                    <TextBlock Text="搜索日志..."
                                                               Foreground="#AAAAAA"
                                                               FontSize="11"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- 右侧：操作按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <CheckBox Content="自动滚动"
                                     IsChecked="{Binding AutoScroll, Mode=TwoWay}"
                                     FontSize="11"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center"/>
                        <Button Content="清空"
                                Command="{Binding ClearCommand}"
                                Padding="8,3"
                                FontSize="11"
                                Margin="0,0,4,0"
                                Background="#FFFFFF"
                                BorderBrush="#DDDDDD"
                                BorderThickness="1"
                                Cursor="Hand"/>
                        <Button Content="复制全部"
                                Command="{Binding CopyAllCommand}"
                                Padding="8,3"
                                FontSize="11"
                                Background="#FFFFFF"
                                BorderBrush="#DDDDDD"
                                BorderThickness="1"
                                Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 日志列表 - 使用 DataGrid 替代 ListBox，性能更好 -->
            <DataGrid Grid.Row="1"
                      x:Name="LogDataGrid"
                      ItemsSource="{Binding LogEntriesView, Mode=OneWay}"
                      Style="{StaticResource LogDataGridStyle}"
                      SelectedItem="{Binding SelectedLogEntry, Mode=TwoWay}">
                <DataGrid.Columns>
                    <!-- 时间列 -->
                    <DataGridTextColumn Header="时间"
                                          Binding="{Binding FormattedTime}"
                                          Width="Auto"
                                          MinWidth="90"
                                          IsReadOnly="True"
                                          ElementStyle="{StaticResource LogDataTextBlockStyle}"/>
                    <!-- 级别列 -->
                    <DataGridTextColumn Header="级别"
                                          Binding="{Binding Level}"
                                          Width="Auto"
                                          MinWidth="50"
                                          IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource LogDataTextBlockStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Level}" Value="{x:Static logging:LogLevel.Info}">
                                        <Setter Property="Foreground" Value="#2196F3"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="{x:Static logging:LogLevel.Success}">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="{x:Static logging:LogLevel.Warning}">
                                        <Setter Property="Foreground" Value="#FF9800"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="{x:Static logging:LogLevel.Error}">
                                        <Setter Property="Foreground" Value="#F44336"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <!-- 来源列 -->
                    <DataGridTextColumn Header="来源"
                                          Binding="{Binding Source}"
                                          Width="Auto"
                                          MinWidth="80"
                                          IsReadOnly="True"
                                          ElementStyle="{StaticResource LogDataTextBlockStyle}"/>
                    <!-- 消息列 -->
                    <DataGridTextColumn Header="消息"
                                          Binding="{Binding DisplayMessage}"
                                          Width="*"
                                          MinWidth="200"
                                          IsReadOnly="True"
                                          ElementStyle="{StaticResource LogDataTextBlockStyle}"/>
                </DataGrid.Columns>

                <!-- 右键菜单 -->
                <DataGrid.ContextMenu>
                    <ContextMenu Style="{StaticResource LogContextMenuStyle}">
                        <MenuItem Header="复制选中"
                                      Click="CopySelected_Click"
                                      Style="{StaticResource ContextMenuMenuItemStyle}"/>
                        <MenuItem Header="复制全部"
                                      Command="{Binding CopyAllCommand}"
                                      Style="{StaticResource ContextMenuMenuItemStyle}"/>
                        <Separator/>
                        <MenuItem Header="清空日志"
                                      Click="ClearLogs_Click"
                                      Style="{StaticResource ContextMenuMenuItemStyle}"/>
                        <MenuItem Header="全选"
                                      Click="SelectAll_Click"
                                      Style="{StaticResource ContextMenuMenuItemStyle}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>

            <!-- 底部状态栏 -->
            <Border Grid.Row="2"
                    Background="#FAFAFA"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0"
                    Padding="8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               FontSize="10"
                               Foreground="#666">
                        <Run Text="已记录: "/>
                        <Run Text="{Binding TotalEnqueued, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>

                    <TextBlock Grid.Column="1"
                               Text="{Binding TotalCount, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='显示: {0}', Mode=OneWay}"
                               FontSize="10"
                               Foreground="#888"
                               Margin="8,0,0,0"/>

                    <TextBlock Grid.Column="2"
                               Text="{Binding ErrorCount, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='错误: {0}', Mode=OneWay}"
                               FontSize="10"
                               Foreground="#CC0000"
                               HorizontalAlignment="Center"
                               Visibility="{Binding ErrorCount, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource IntToVisibilityConverter}}"/>

                    <TextBlock Grid.Column="3"
                               Text="{Binding WarningCount, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='警告: {0}', Mode=OneWay}"
                               FontSize="10"
                               Foreground="#CC7700"
                               HorizontalAlignment="Center"
                               Margin="8,0"
                               Visibility="{Binding WarningCount, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource IntToVisibilityConverter}}"/>

                    <TextBlock Grid.Column="4"
                               FontSize="10"
                               Foreground="#666">
                        <Run Text="✅ 零阻塞"/>
                        <Run Text=" | "/>
                        <Run Text="⚡ 批量更新"/>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
