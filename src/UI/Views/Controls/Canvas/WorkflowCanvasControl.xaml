<UserControl x:Class="SunEyeVision.UI.Views.Controls.Canvas.WorkflowCanvasControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:SunEyeVision.UI.Converters"
             xmlns:convertersPath="clr-namespace:SunEyeVision.UI.Converters.Path"
             xmlns:convertersNode="clr-namespace:SunEyeVision.UI.Converters.Node"
             xmlns:convertersVisibility="clr-namespace:SunEyeVision.UI.Converters.Visibility"
             xmlns:convertersUI="clr-namespace:SunEyeVision.UI.Converters.UI"
             xmlns:controls="clr-namespace:SunEyeVision.UI.Views.Controls"
             xmlns:common="clr-namespace:SunEyeVision.UI.Views.Controls.Common"
             xmlns:rendering="clr-namespace:SunEyeVision.UI.Services.Rendering"
             xmlns:helpers="clr-namespace:SunEyeVision.UI.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000">

    <UserControl.Resources>
        <convertersPath:SmartPathConverter x:Key="SmartPathConverter"/>
        <convertersPath:SmartPathMultiConverter x:Key="SmartPathMultiConverter"/>
        <convertersUI:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <convertersPath:PointOffsetConverter x:Key="PointOffsetConverter"/>
        <converters:PointCenterToOffsetConverter x:Key="PointCenterToOffsetConverter"/>

        <!-- 使用缓存的节点转换器（性能优化） -->
        <rendering:CachedNodeBackgroundConverter x:Key="NodeBackgroundColorConverter"/>
        <rendering:CachedNodeBorderConverter x:Key="NodeBorderColorConverter"/>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter"/>

        <!-- 箭头标记 - 尖端指向右侧（度的方向），方便旋转 -->
        <!-- 箭头长度与 BezierPathCalculator.ArrowLength 保持一致（15px） -->
        <PathGeometry x:Key="ArrowGeometry">
            <PathFigure StartPoint="0,0">
                <LineSegment Point="-15,-8" />
                <LineSegment Point="-15,8" />
                <LineSegment Point="0,0" />
            </PathFigure>
        </PathGeometry>

        <!-- 箭头填充颜色 -->
        <SolidColorBrush x:Key="ArrowBrush" Color="#666666"/>

        <!-- 节点背景样式（保留用于转换器） -->
        <SolidColorBrush x:Key="NodeBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="NodeHeaderBackground" Color="#0066CC"/>
        <SolidColorBrush x:Key="NodeFooterBackground" Color="#F0F8FF"/>
        <SolidColorBrush x:Key="NodeTextForeground" Color="#0066CC"/>
        <SolidColorBrush x:Key="NodeTimeForeground" Color="#666666"/>
        <SolidColorBrush x:Key="NodeBorderBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="NodeBorderBrushSelected" Color="#0066CC"/>
    </UserControl.Resources>

    <!-- 主容器 -->
    <Grid x:Name="MainGrid">
        <!-- 原有的 WorkflowCanvas -->
        <Canvas x:Name="WorkflowCanvas"
                ClipToBounds="True"
                AllowDrop="True"
                DragEnter="WorkflowCanvas_DragEnter"
                DragOver="WorkflowCanvas_DragOver"
                DragLeave="WorkflowCanvas_DragLeave"
                Drop="WorkflowCanvas_Drop"
                PreviewMouseLeftButtonDown="WorkflowCanvas_PreviewMouseLeftButtonDown"
                PreviewMouseMove="WorkflowCanvas_PreviewMouseMove"
                PreviewMouseLeftButtonUp="WorkflowCanvas_PreviewMouseLeftButtonUp">

        <!-- 网格背景 -->
        <Canvas.Background>
                    <DrawingBrush ViewportUnits="Absolute" Viewport="0,0,20,20" TileMode="Tile">
                <DrawingBrush.Drawing>
                    <GeometryDrawing Brush="Transparent">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#E0E0E0" Thickness="0.15"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,1" EndPoint="1,1"/>
                                <LineGeometry StartPoint="1,0" EndPoint="1,1"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Canvas.Background>

        <!-- 连接线 - 使用智能直角折线 -->
        <ItemsControl ItemsSource="{Binding WorkflowConnections}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style>
                    <Setter Property="Canvas.ZIndex" Value="1000"/>
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Canvas>
                        <!-- 连接线 - 仅视觉显示层，不参与命中测试 -->
                        <Path Loaded="Path_Loaded"
                              IsHitTestVisible="False">
                            <Path.Data>
                                <MultiBinding Converter="{StaticResource SmartPathMultiConverter}">
                                    <Binding Path="."/>
                                    <Binding Path="PathUpdateCounter"/>
                                </MultiBinding>
                            </Path.Data>
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Stroke" Value="{Binding StatusColor}"/>
                                    <Setter Property="StrokeThickness" Value="2"/>
                                    <Setter Property="StrokeLineJoin" Value="Round"/>
                                    <Setter Property="Effect" Value="{x:Null}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHovered}" Value="True">
                                            <Setter Property="Stroke" Value="#0066CC"/>
                                            <Setter Property="StrokeThickness" Value="2.5"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#0066CC" BlurRadius="4" ShadowDepth="0" Opacity="0.6"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Stroke" Value="#FF6600"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#FF6600" BlurRadius="4" ShadowDepth="0" Opacity="0.8"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>

                        <!-- 透明宽命中线 - 始终透明，仅负责点击选中交互 -->
                        <Path Stroke="Transparent" StrokeThickness="14" Fill="Transparent"
                              Cursor="Hand"
                              MouseEnter="ConnectionHitArea_MouseEnter"
                              MouseLeave="ConnectionHitArea_MouseLeave"
                              MouseLeftButtonDown="ConnectionHitArea_MouseLeftButtonDown">
                            <Path.Data>
                                <MultiBinding Converter="{StaticResource SmartPathMultiConverter}">
                                    <Binding Path="."/>
                                    <Binding Path="PathUpdateCounter"/>
                                </MultiBinding>
                            </Path.Data>
                        </Path>

                        <!-- 连接线拐点（中间点）标记 -->
                        <ItemsControl ItemsSource="{Binding PathPoints, Mode=OneWay}"
                                      Visibility="{Binding ShowPathPoints, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Canvas>
                                        <Ellipse Width="8" Height="8"
                                                 Fill="#FF6600"
                                                 Stroke="#FFFFFF"
                                                 StrokeThickness="1"
                                                 Opacity="0.7"
                                                 Canvas.Left="{Binding X, Converter={StaticResource PointOffsetConverter}, ConverterParameter=-4}"
                                                 Canvas.Top="{Binding Y, Converter={StaticResource PointOffsetConverter}, ConverterParameter=-4}"/>
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 箭头 -->
                        <Path Data="{StaticResource ArrowGeometry}"
                              Fill="{Binding StatusColor}"
                              Canvas.Left="{Binding ArrowX}"
                              Canvas.Top="{Binding ArrowY}"
                              RenderTransformOrigin="0,0"
                              Loaded="ArrowPath_Loaded"
                              x:Name="ArrowPath">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Transmitting">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                       From="1" To="0.3" Duration="0:0:0.5"
                                                                       AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Canvas>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 节点 -->
        <ItemsControl ItemsSource="{Binding WorkflowNodes}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style>
        <!-- Position表示HitArea中心点，Canvas.Left/Top需要左上角坐标 -->
        <!-- 左上角 = 中心点 - (HitAreaWidth/2, HitAreaHeight/2) -->
        <Setter Property="Canvas.Left" Value="{Binding Position.X, Converter={StaticResource PointCenterToOffsetConverter}, ConverterParameter=-90, Mode=OneWay}"/>
        <Setter Property="Canvas.Top" Value="{Binding Position.Y, Converter={StaticResource PointCenterToOffsetConverter}, ConverterParameter=-30, Mode=OneWay}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- HitArea Border: 用于命中测试，Position表示其中心点 -->
                    <Border Width="{DynamicResource HitAreaWidth}" Height="{DynamicResource HitAreaHeight}"
                            Background="Transparent"
                            Tag="{Binding}"
                            x:Name="HitAreaBorder">
                        <Grid>
                            <!-- NodeBorder: 视觉显示元素，居中于HitArea -->
                            <Border Width="{DynamicResource NodeWidth}" Height="{DynamicResource NodeHeight}"
                                    CornerRadius="{DynamicResource NodeCornerRadius}"
                                    BorderThickness="0"
                                    BorderBrush="Transparent"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MouseLeftButtonDown="Node_MouseLeftButtonDown"
                                    MouseLeftButtonUp="Node_MouseLeftButtonUp"
                                    MouseMove="Node_MouseMove"
                                    Tag="{Binding}"
                                    x:Name="NodeBorder">
                                <Border.Background>
                                    <Binding Converter="{StaticResource NodeBackgroundColorConverter}"/>
                                </Border.Background>
                                <Grid>
                                    <!-- 虚线选中装饰层：与 Border 同尺寸，仅选中时可见 -->
                                    <Rectangle RadiusX="{DynamicResource NodeCornerRadiusDouble}" RadiusY="{DynamicResource NodeCornerRadiusDouble}"
                                               Stroke="{DynamicResource NodeSelectedDashBrush}" StrokeThickness="1.5"
                                               StrokeDashArray="6,3"
                                               Fill="Transparent"
                                               IsHitTestVisible="False"
                                               Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <!-- 节点内容 -->
                            <Grid Margin="{DynamicResource NodeContentMargin}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 节点类型图标 -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Icon}"
                                           Style="{DynamicResource NodeIconStyle}"/>

                                <!-- 全局序号 -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding GlobalIndex, StringFormat='{}{0}'}"
                                           Style="{DynamicResource NodeGlobalIndexStyle}"
                                           Margin="0,0,8,0"
                                           Visibility="Visible"/>

                                <!-- 节点显示名称 -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DispName}"
                                           Style="{DynamicResource NodeTextStyle}"/>
                            </Grid>

                            <!-- 连接点 - 上 -->
                            <Ellipse Name="TopPortEllipse"
                                     Style="{DynamicResource PortEllipseHighlightedStyle}"
                                     helpers:PortHighlighterHelper.IsHighlighted="False"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Top"
                                     Margin="0,-10,0,0"
                                     MouseLeftButtonDown="Port_MouseLeftButtonDown"
                                     MouseLeftButtonUp="Port_MouseLeftButtonUp"
                                     MouseMove="Port_MouseMove"
                                     MouseEnter="Port_MouseEnter"
                                     MouseLeave="Port_MouseLeave"
                                     Tag="TopPort"
                                     Visibility="Collapsed"/>

                            <!-- 连接点 - 下 -->
                            <Ellipse Name="BottomPortEllipse"
                                     Style="{DynamicResource PortEllipseHighlightedStyle}"
                                     helpers:PortHighlighterHelper.IsHighlighted="False"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,-10"
                                     MouseLeftButtonDown="Port_MouseLeftButtonDown"
                                     MouseLeftButtonUp="Port_MouseLeftButtonUp"
                                     MouseMove="Port_MouseMove"
                                     MouseEnter="Port_MouseEnter"
                                     MouseLeave="Port_MouseLeave"
                                     Tag="BottomPort"
                                     Visibility="Collapsed"/>

                            <!-- 连接点 - 左 -->
                            <Ellipse Name="LeftPortEllipse"
                                     Style="{DynamicResource PortEllipseHighlightedStyle}"
                                     helpers:PortHighlighterHelper.IsHighlighted="False"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="-10,0,0,0"
                                     MouseLeftButtonDown="Port_MouseLeftButtonDown"
                                     MouseLeftButtonUp="Port_MouseLeftButtonUp"
                                     MouseMove="Port_MouseMove"
                                     MouseEnter="Port_MouseEnter"
                                     MouseLeave="Port_MouseLeave"
                                     Tag="LeftPort"
                                     Visibility="Collapsed"/>

                            <!-- 连接点 - 右 -->
                            <Ellipse Name="RightPortEllipse"
                                     Style="{DynamicResource PortEllipseHighlightedStyle}"
                                     helpers:PortHighlighterHelper.IsHighlighted="False"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Margin="0,0,-10,0"
                                     MouseLeftButtonDown="Port_MouseLeftButtonDown"
                                     MouseLeftButtonUp="Port_MouseLeftButtonUp"
                                     MouseMove="Port_MouseMove"
                                     MouseEnter="Port_MouseEnter"
                                     MouseLeave="Port_MouseLeave"
                                     Tag="RightPort"
                                     Visibility="Collapsed"/>
                        </Grid>

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Effect" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <!-- 选中状态：橙色发光，虚线描边由内部 Rectangle 负责 -->
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#FF6600" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- 悬停状态：轻柔阴影提升，不改变边框 -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 拖拽连接时的临时连接线 -->
        <Path x:Name="TempConnectionLine"
              Style="{DynamicResource TempConnectionLineStyle}"
              Visibility="Collapsed">
            <Path.Data>
                <PathGeometry x:Name="TempConnectionGeometry" />
            </Path.Data>
        </Path>

        <!-- 框选控件 -->
        <common:SelectionBox x:Name="SelectionBox" Canvas.ZIndex="9999"/>

        <!-- 最大外接矩形（用于调试） -->
        <Border x:Name="BoundingRectangle"
                 BorderBrush="#FF0000"
                 BorderThickness="3"
                 Background="Red"
                 CornerRadius="2"
                 Opacity="0.5"
                 Canvas.ZIndex="500"
                 Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="#FF0000" BlurRadius="8" ShadowDepth="3" Opacity="0.8"/>
            </Border.Effect>
        </Border>
    </Canvas>
    </Grid>
</UserControl>
