<UserControl x:Class="SunEyeVision.UI.Views.Camera.CameraDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SunEyeVision.UI.Views.Camera"
             xmlns:converters="clr-namespace:SunEyeVision.UI.Converters.UI"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="400">
    
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        
        <!-- TabControl 样式 -->
        <Style x:Key="DetailTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        
        <Style x:Key="DetailTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Margin="0,0,8,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite"
                                            ContentSource="Header"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#2196F3"/>
                                <Setter Property="Foreground" Value="#2196F3"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#757575"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <!-- 未选中相机时的提示 -->
        <TextBlock Text="请选择相机查看详情"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#999999"
                   FontSize="14"
                   Visibility="{Binding IsCameraSelected, Converter={StaticResource InverseBoolToVisibilityConverter}, FallbackValue=Visible}"/>
        
        <!-- 相机详情 TabControl -->
        <TabControl x:Name="DetailTabControl"
                    Style="{StaticResource DetailTabControlStyle}"
                    Visibility="{Binding IsCameraSelected, Converter={StaticResource BoolToVisibilityConverter}}">
            
            <!-- Tab1：基本信息 -->
            <TabItem Header="基本信息" Style="{StaticResource DetailTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        
                        <!-- 基本信息 -->
                        <GroupBox Header="基本信息" Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" 
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="0" Grid.Column="1" 
                                         Text="{Binding SelectedCamera.Name}"
                                         IsReadOnly="True" Background="#F5F5F5"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="制造商:" 
                                           VerticalAlignment="Center" Margin="0,8,8,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" 
                                         Text="{Binding SelectedCamera.Manufacturer}"
                                         Margin="0,8,0,0"
                                         IsReadOnly="True" Background="#F5F5F5"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="型号:" 
                                           VerticalAlignment="Center" Margin="0,8,8,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" 
                                         Text="{Binding SelectedCamera.Model}"
                                         Margin="0,8,0,0"
                                         IsReadOnly="True" Background="#F5F5F5"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="描述:" 
                                           VerticalAlignment="Center" Margin="0,8,8,0"/>
                                <TextBox Grid.Row="3" Grid.Column="1" 
                                         Text="{Binding SelectedCamera.Description}"
                                         Margin="0,8,0,0" Height="60" TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         IsReadOnly="True" Background="#F5F5F5"/>
                            </Grid>
                        </GroupBox>
                        
                        <!-- 连接信息 -->
                        <GroupBox Header="连接信息" Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="IP:" 
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="0" Grid.Column="1" 
                                         Text="{Binding SelectedCamera.IpAddress}"
                                         IsReadOnly="True" Background="#F5F5F5"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="端口:" 
                                           VerticalAlignment="Center" Margin="0,8,8,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" 
                                         Text="{Binding SelectedCamera.Port}"
                                         Margin="0,8,0,0"
                                         IsReadOnly="True" Background="#F5F5F5"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="用户名:" 
                                           VerticalAlignment="Center" Margin="0,8,8,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" 
                                         Text="{Binding SelectedCamera.Username}"
                                         Margin="0,8,0,0"
                                         IsReadOnly="True" Background="#F5F5F5"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="密码:" 
                                           VerticalAlignment="Center" Margin="0,8,8,0"/>
                                <PasswordBox Grid.Row="3" Grid.Column="1" 
                                             Margin="0,8,0,0"
                                             IsEnabled="False" Background="#F5F5F5"/>
                            </Grid>
                        </GroupBox>
                        
                        <!-- 连接状态 -->
                        <GroupBox Header="连接状态">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="状态:" 
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding SelectedCamera.StatusText}"
                                               Foreground="#4CAF50"
                                               FontWeight="Medium"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="延迟:" 
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1">
                                        <Run Text="{Binding SelectedCamera.Latency, FallbackValue=0}"/>
                                        <Run Text=" ms"/>
                                    </TextBlock>
                                </Grid>
                                
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="帧率:" 
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1">
                                        <Run Text="{Binding SelectedCamera.FrameRate, FallbackValue=0}"/>
                                        <Run Text=" fps"/>
                                    </TextBlock>
                                </Grid>
                                
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="🔗连接" Width="80" Height="32" Margin="0,0,8,0"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding ConnectCommand}"/>
                                    <Button Content="⏸断开" Width="80" Height="32" Margin="0,0,8,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding DisconnectCommand}"/>
                                    <Button Content="👁️预览" Width="80" Height="32"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding PreviewCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Tab2：参数设置 -->
            <TabItem Header="参数设置" Style="{StaticResource DetailTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        
                        <!-- 动态加载厂商参数 -->
                        <ContentControl Content="{Binding ManufacturerParamsViewModel}">
                            <ContentControl.ContentTemplateSelector>
                                <local:ManufacturerTemplateSelector>
                                    <local:ManufacturerTemplateSelector.HikvisionTemplate>
                                        <DataTemplate>
                                            <local:HikvisionParamsView/>
                                        </DataTemplate>
                                    </local:ManufacturerTemplateSelector.HikvisionTemplate>
                                    
                                    <local:ManufacturerTemplateSelector.DahuaTemplate>
                                        <DataTemplate>
                                            <local:DahuaParamsView/>
                                        </DataTemplate>
                                    </local:ManufacturerTemplateSelector.DahuaTemplate>
                                    
                                    <local:ManufacturerTemplateSelector.GenericTemplate>
                                        <DataTemplate>
                                            <local:GenericParamsView/>
                                        </DataTemplate>
                                    </local:ManufacturerTemplateSelector.GenericTemplate>
                                </local:ManufacturerTemplateSelector>
                            </ContentControl.ContentTemplateSelector>
                        </ContentControl>
                        
                        <!-- 底部按钮 -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0"
                                    HorizontalAlignment="Right">
                            <Button Content="💾保存参数" Width="100" Height="32" Margin="0,0,8,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding SaveParamsCommand}"/>
                            <Button Content="↺恢复默认" Width="100" Height="32"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ResetParamsCommand}"/>
                        </StackPanel>
                        
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
        </TabControl>
    </Grid>
</UserControl>
