<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:SunEyeVision.UI.ViewModels"
                    xmlns:controls="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls;assembly=SunEyeVision.Plugin.SDK">

    <!-- 通用参数模板 - 复用SDK控件 -->
    <DataTemplate x:Key="GenericParamsTemplate" DataType="{x:Type vm:GenericParamsViewModel}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="8">

                <!-- 图像设置 -->
                <controls:ParamGroup Header="图像设置" Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <controls:ParamComboBox Label="曝光模式" 
                                             ItemsSource="{Binding ExposureModes}" 
                                             SelectedItem="{Binding ExposureMode}"/>
                        
                        <controls:ParamTextBox Label="曝光时间" Text="{Binding ExposureTime}"/>
                        
                        <controls:ParamTextBox Label="增益" Text="{Binding Gain}"/>
                    </StackPanel>
                </controls:ParamGroup>

                <!-- 智能检测 -->
                <controls:ParamGroup Header="智能检测" Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <controls:ToggleSwitch IsChecked="{Binding EnableMotionDetection}" 
                                              OnText="启用" OffText="关闭"
                                              Margin="0,4"/>
                        <controls:ToggleSwitch IsChecked="{Binding EnableBorderDetection}" 
                                              OnText="启用" OffText="关闭"
                                              Margin="0,4"/>
                        <controls:ToggleSwitch IsChecked="{Binding EnableRegionIntrusion}" 
                                              OnText="启用" OffText="关闭"
                                              Margin="0,4"/>
                    </StackPanel>
                </controls:ParamGroup>

                <!-- 宽动态 -->
                <controls:ParamGroup Header="宽动态" Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <controls:ParamComboBox Label="启用状态" 
                                             ItemsSource="{Binding WideDynamicOptions}" 
                                             SelectedItem="{Binding WideDynamic}"/>
                        
                        <StackPanel Margin="0,4,0,12">
                            <TextBlock Text="强度等级:" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                            <Slider Minimum="0" Maximum="100" 
                                    Value="{Binding WideDynamicLevel}"
                                    Margin="0,0,0,6"/>
                        </StackPanel>
                    </StackPanel>
                </controls:ParamGroup>

                <!-- 视频编码 -->
                <controls:ParamGroup Header="视频编码" Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <controls:ParamComboBox Label="编码格式" 
                                             ItemsSource="{Binding CompressionTypes}" 
                                             SelectedItem="{Binding CompressionType}"/>
                        
                        <controls:ParamTextBox Label="码率" Text="{Binding Bitrate}"/>
                        
                        <controls:ParamTextBox Label="I帧间隔" Text="{Binding IframeInterval}"/>
                    </StackPanel>
                </controls:ParamGroup>

            </StackPanel>
        </ScrollViewer>
    </DataTemplate>
</ResourceDictionary>
