<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ======================================== -->
    <!-- 连接线尺寸参数 -->
    <!-- ======================================== -->
    
    <!-- 连接线粗细 -->
    <sys:Double x:Key="ConnectionDefaultThickness">2</sys:Double>
    <sys:Double x:Key="ConnectionHoverThickness">3</sys:Double>
    <sys:Double x:Key="ConnectionSelectedThickness">3</sys:Double>
    
    <!-- 箭头尺寸 -->
    <sys:Double x:Key="ArrowSize">10</sys:Double>
    <sys:Double x:Key="ArrowWidth">8</sys:Double>
    
    <!-- 预览线粗细 -->
    <sys:Double x:Key="PreviewLineThickness">1</sys:Double>

    <!-- 临时连接线粗细（拖拽连接时） -->
    <sys:Double x:Key="TempConnectionLineThickness">2</sys:Double>

    <!-- ======================================== -->
    <!-- 连接线颜色参数 -->
    <!-- ======================================== -->
    
    <!-- ======================================== -->
    <!-- 预览线颜色参数 -->
    <!-- ======================================== -->

    <!-- 预览线颜色（拖拽连接时的临时线） -->
    <Color x:Key="TempConnectionLineColor">#FF6600</Color>

    <!-- 旧预览线颜色（用于其他场景） -->
    <Color x:Key="PreviewLineColor">#999999</Color>
    <Color x:Key="PreviewLineDashColor">#666666</Color>

    <!-- ======================================== -->
    <!-- 连接线笔刷资源 -->
    <!-- ======================================== -->
    
    <!-- 预览线笔刷 -->
    <SolidColorBrush x:Key="PreviewLineBrush" Color="{DynamicResource PreviewLineColor}"/>
    <SolidColorBrush x:Key="PreviewLineDashBrush" Color="{DynamicResource PreviewLineDashColor}"/>

    <!-- 临时连接线笔刷（拖拽连接时） -->
    <SolidColorBrush x:Key="TempConnectionLineBrush" Color="{DynamicResource TempConnectionLineColor}"/>

    <!-- ======================================== -->
    <!-- 连接线样式 -->
    <!-- ======================================== -->
    
    <!-- 连接线基础样式 -->
    <Style x:Key="ConnectionLineStyle" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource ConnectionNormalBrush}"/>
        <Setter Property="StrokeThickness" Value="{DynamicResource ConnectionDefaultThickness}"/>
        <Setter Property="Fill" Value="Transparent"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>
    
    <!-- 预览线样式 -->
    <Style x:Key="PreviewLineStyle" TargetType="Line">
        <Setter Property="Stroke" Value="{DynamicResource PreviewLineBrush}"/>
        <Setter Property="StrokeThickness" Value="{DynamicResource PreviewLineThickness}"/>
        <Setter Property="StrokeDashArray" Value="4,2"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>

    <!-- ======================================== -->
    <!-- 临时连接线样式（Path类型 - 拖拽连接时） -->
    <!-- ======================================== -->

    <Style x:Key="TempConnectionLineStyle" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource TempConnectionLineBrush}"/>
        <Setter Property="StrokeThickness" Value="{DynamicResource TempConnectionLineThickness}"/>
        <Setter Property="StrokeDashArray" Value="5,5"/>
        <Setter Property="StrokeLineJoin" Value="Round"/>
        <Setter Property="Fill" Value="Transparent"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Canvas.ZIndex" Value="-1"/>
    </Style>

</ResourceDictionary>
