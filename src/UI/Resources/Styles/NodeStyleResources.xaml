<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ======================================== -->
    <!-- 尺寸参数 -->
    <!-- ======================================== -->
    
    <!-- 节点尺寸 -->
    <sys:Double x:Key="NodeWidth">160</sys:Double>
    <sys:Double x:Key="NodeHeight">40</sys:Double>
    <sys:Double x:Key="HitAreaWidth">180</sys:Double>
    <sys:Double x:Key="HitAreaHeight">60</sys:Double>
    
    <!-- 端口尺寸 -->
    <sys:Double x:Key="PortSize">10</sys:Double>
    <sys:Double x:Key="PortHoverSize">12</sys:Double>
    <sys:Double x:Key="PortHitAreaWidth">20</sys:Double>
    <sys:Double x:Key="PortHitAreaHeight">20</sys:Double>
    <sys:Double x:Key="PortHoverHitAreaWidth">24</sys:Double>
    <sys:Double x:Key="PortHoverHitAreaHeight">24</sys:Double>
    
    <!-- 端口外边距 -->
    <sys:Double x:Key="PortMargin">10</sys:Double>
    
    <!-- 圆角半径 - double类型（用于Rectangle.RadiusX/Y） -->
    <sys:Double x:Key="NodeCornerRadiusDouble">20</sys:Double>
    
    <!-- 圆角半径 - CornerRadius类型（用于Border.CornerRadius） -->
    <CornerRadius x:Key="NodeCornerRadius">20</CornerRadius>
    
    <!-- 内容边距 -->
    <Thickness x:Key="NodeContentMargin">12,0,12,0</Thickness>
    
    <!-- 字体大小 -->
    <sys:Double x:Key="NodeFontSize">13</sys:Double>
    <sys:Double x:Key="NodeIconFontSize">18</sys:Double>
    
    <!-- ======================================== -->
    <!-- 颜色参数 -->
    <!-- ======================================== -->
    
    <!-- 端口颜色 -->
    <Color x:Key="PortNormalColor">#0066CC</Color>
    <Color x:Key="PortHoverColor">#FF6600</Color>
    <Color x:Key="PortStrokeColor">#FFFFFF</Color>
    
    <!-- 节点颜色 -->
    <Color x:Key="NodeDefaultBackground">#FFFFFF</Color>
    <Color x:Key="NodeSelectedBackground">#FFF5E6</Color>
    <Color x:Key="NodeBorderColor">#CCCCCC</Color>
    <Color x:Key="NodeSelectedBorderColor">#FF6600</Color>
    <Color x:Key="NodeSelectedDashColor">#FF6600</Color>
    
    <!-- 文本颜色 -->
    <Color x:Key="NodeTextForeground">#333333</Color>
    <Color x:Key="NodeGlobalIndexColor">#FF9500</Color>
    
    <!-- 连接线颜色 -->
    <Color x:Key="ConnectionNormalColor">#666666</Color>
    <Color x:Key="ConnectionHoverColor">#0066CC</Color>
    <Color x:Key="ConnectionSelectedColor">#FF6600</Color>
    
    <!-- ======================================== -->
    <!-- 笔刷资源 -->
    <!-- ======================================== -->
    
    <!-- 端口笔刷 -->
    <SolidColorBrush x:Key="PortNormalBrush" Color="{DynamicResource PortNormalColor}"/>
    <SolidColorBrush x:Key="PortHoverBrush" Color="{DynamicResource PortHoverColor}"/>
    <SolidColorBrush x:Key="PortStrokeBrush" Color="{DynamicResource PortStrokeColor}"/>
    
    <!-- 节点笔刷 -->
    <SolidColorBrush x:Key="NodeDefaultBackgroundBrush" Color="{DynamicResource NodeDefaultBackground}"/>
    <SolidColorBrush x:Key="NodeSelectedBackgroundBrush" Color="{DynamicResource NodeSelectedBackground}"/>
    <SolidColorBrush x:Key="NodeBorderBrush" Color="{DynamicResource NodeBorderColor}"/>
    <SolidColorBrush x:Key="NodeSelectedBorderBrush" Color="{DynamicResource NodeSelectedBorderColor}"/>
    <SolidColorBrush x:Key="NodeSelectedDashBrush" Color="{DynamicResource NodeSelectedDashColor}"/>
    
    <!-- 文本笔刷 -->
    <SolidColorBrush x:Key="NodeTextForegroundBrush" Color="{DynamicResource NodeTextForeground}"/>
    <SolidColorBrush x:Key="NodeGlobalIndexBrush" Color="{DynamicResource NodeGlobalIndexColor}"/>
    
    <!-- 连接线笔刷 -->
    <SolidColorBrush x:Key="ConnectionNormalBrush" Color="{DynamicResource ConnectionNormalColor}"/>
    <SolidColorBrush x:Key="ConnectionHoverBrush" Color="{DynamicResource ConnectionHoverColor}"/>
    <SolidColorBrush x:Key="ConnectionSelectedBrush" Color="{DynamicResource ConnectionSelectedColor}"/>
    
    <!-- ======================================== -->
    <!-- 端口样式 -->
    <!-- ======================================== -->
    
    <Style x:Key="PortEllipseStyle" TargetType="Ellipse">
        <Setter Property="Fill" Value="{DynamicResource PortNormalBrush}"/>
        <Setter Property="Stroke" Value="{DynamicResource PortStrokeBrush}"/>
        <Setter Property="StrokeThickness" Value="2"/>
        <Setter Property="Width" Value="{DynamicResource PortHitAreaWidth}"/>
        <Setter Property="Height" Value="{DynamicResource PortHitAreaHeight}"/>
        <Setter Property="Cursor" Value="Cross"/>
        <Setter Property="Panel.ZIndex" Value="10"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Fill" Value="{DynamicResource PortHoverBrush}"/>
                <Setter Property="Width" Value="{DynamicResource PortHoverHitAreaWidth}"/>
                <Setter Property="Height" Value="{DynamicResource PortHoverHitAreaHeight}"/>
                <Setter Property="StrokeThickness" Value="3"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- ======================================== -->
    <!-- 节点样式 -->
    <!-- ======================================== -->
    
    <!-- 节点边框样式 -->
    <Style x:Key="NodeBorderStyle" TargetType="Border">
        <Setter Property="Effect" Value="{x:Null}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Background" Value="{DynamicResource NodeDefaultBackgroundBrush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#FF6600" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- 选中装饰虚线样式 -->
    <Style x:Key="NodeSelectedDecorationStyle" TargetType="Rectangle">
        <Setter Property="Stroke" Value="{DynamicResource NodeSelectedDashBrush}"/>
        <Setter Property="StrokeThickness" Value="1.5"/>
        <Setter Property="StrokeDashArray" Value="6,3"/>
        <Setter Property="Fill" Value="Transparent"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Visibility" Value="Collapsed"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
    <!-- 文本样式 -->
    <Style x:Key="NodeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource NodeFontSize}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource NodeTextForegroundBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>
    
    <Style x:Key="NodeGlobalIndexStyle" TargetType="TextBlock" BasedOn="{StaticResource NodeTextStyle}">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource NodeGlobalIndexBrush}"/>
    </Style>
    
    <!-- 图标样式 -->
    <Style x:Key="NodeIconStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource NodeIconFontSize}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>
    
</ResourceDictionary>
