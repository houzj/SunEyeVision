<UserControl x:Class="SunEyeVision.UI.Controls.ParameterItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SunEyeVision.UI.Controls"
             xmlns:vm="clr-namespace:SunEyeVision.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="300"
             d:DataContext="{d:DesignInstance Type=vm:ParameterItemViewModel}">

    <UserControl.Resources>
        <!-- 绑定类型图标样式 -->
        <Style x:Key="BindingTypeIconStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsConstantBinding}" Value="True">
                    <Setter Property="Text" Value="📌"/>
                    <Setter Property="Foreground" Value="Gray"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsDynamicBinding}" Value="True">
                    <Setter Property="Text" Value="🔗"/>
                    <Setter Property="Foreground" Value="Blue"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 输入控件样式 -->
        <Style x:Key="ParameterInputStyle" TargetType="Control">
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" SharedSizeGroup="ParameterName"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto" SharedSizeGroup="BindingButton"/>
        </Grid.ColumnDefinitions>

        <!-- 参数名称 -->
        <TextBlock Grid.Column="0"
                   Text="{Binding DisplayName}"
                   ToolTip="{Binding Description}"
                   VerticalAlignment="Center"
                   Margin="5,0"
                   FontWeight="Medium"/>

        <!-- 参数值输入区域 -->
        <ContentControl Grid.Column="1" Content="{Binding}">
            <ContentControl.ContentTemplate>
                <DataTemplate>
                    <!-- 使用Grid作为唯一根元素 -->
                    <Grid>
                        <!-- 数值类型 -->
                        <Grid x:Name="NumericEditor" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding MinValue}" Visibility="{Binding MinValue, Converter={StaticResource NullToCollapsedConverter}}"
                                       VerticalAlignment="Center" FontSize="10" Foreground="Gray"/>
                            <Slider Grid.Column="1"
                                    Value="{Binding ConstantValue}"
                                    Minimum="{Binding MinValue}"
                                    Maximum="{Binding MaxValue}"
                                    IsEnabled="{Binding IsConstantBinding}"
                                    Style="{StaticResource ParameterInputStyle}"/>
                            <TextBlock Grid.Column="2" Text="{Binding MaxValue}" Visibility="{Binding MaxValue, Converter={StaticResource NullToCollapsedConverter}}"
                                       VerticalAlignment="Center" FontSize="10" Foreground="Gray"/>
                        </Grid>

                        <!-- 布尔类型 -->
                        <CheckBox x:Name="BoolEditor" Visibility="Collapsed"
                                  IsChecked="{Binding ConstantValue}"
                                  IsEnabled="{Binding IsConstantBinding}"
                                  VerticalAlignment="Center"/>

                        <!-- 枚举类型 -->
                        <ComboBox x:Name="EnumEditor" Visibility="Collapsed"
                                  ItemsSource="{Binding Options}"
                                  SelectedItem="{Binding ConstantValue}"
                                  IsEnabled="{Binding IsConstantBinding}"
                                  Style="{StaticResource ParameterInputStyle}"/>

                        <!-- 字符串类型 -->
                        <TextBox x:Name="StringEditor" Visibility="Collapsed"
                                 Text="{Binding ConstantValue, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsConstantBinding}"
                                 Style="{StaticResource ParameterInputStyle}"/>

                        <!-- 动态绑定显示 -->
                        <TextBlock x:Name="DynamicBindingDisplay" Visibility="Collapsed"
                                   Text="{Binding BindingDescription}"
                                   Foreground="Blue"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   Margin="5,0"/>
                    </Grid>

                    <!-- 类型选择器 -->
                    <DataTemplate.Triggers>
                        <!-- 数值类型 -->
                        <DataTrigger Binding="{Binding IsNumericType}" Value="True">
                            <Setter TargetName="NumericEditor" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <!-- 布尔类型 -->
                        <DataTrigger Binding="{Binding IsBoolType}" Value="True">
                            <Setter TargetName="BoolEditor" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <!-- 枚举类型 -->
                        <DataTrigger Binding="{Binding IsEnumType}" Value="True">
                            <Setter TargetName="EnumEditor" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <!-- 字符串类型 -->
                        <DataTrigger Binding="{Binding IsStringType}" Value="True">
                            <Setter TargetName="StringEditor" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <!-- 动态绑定模式 -->
                        <DataTrigger Binding="{Binding IsDynamicBinding}" Value="True">
                            <Setter TargetName="NumericEditor" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="BoolEditor" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="EnumEditor" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="StringEditor" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="DynamicBindingDisplay" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <!-- 绑定配置按钮 + Popup -->
        <Grid Grid.Column="2">
            <ToggleButton x:Name="BindingButton"
                          Content="⚙"
                          Width="24" Height="24"
                          Margin="2,0"
                          IsEnabled="{Binding SupportsBinding}"
                          IsChecked="{Binding IsBindingPopupOpen, Mode=TwoWay}"
                          ToolTip="配置数据绑定"/>

            <Popup x:Name="BindingPopup"
                   PlacementTarget="{Binding ElementName=BindingButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   IsOpen="{Binding IsBindingPopupOpen, Mode=TwoWay}"
                   MinWidth="200">
                <Border Background="White" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4"
                        Padding="10">
                    <StackPanel>
                        <!-- 绑定类型选择 -->
                        <TextBlock Text="绑定类型" FontWeight="Medium" Margin="0,0,0,5"/>
                        <RadioButton Content="常量值"
                                     IsChecked="{Binding IsConstantBinding, Mode=TwoWay}"
                                     GroupName="BindingType" Margin="5,2"/>
                        <RadioButton Content="动态绑定"
                                     IsChecked="{Binding IsDynamicBinding, Mode=TwoWay}"
                                     GroupName="BindingType" Margin="5,2"/>

                        <!-- 常量值配置 -->
                        <StackPanel Visibility="{Binding IsConstantBinding, Converter={StaticResource BoolToVisibleConverter}}">
                            <TextBlock Text="值:" Margin="0,10,0,2"/>
                            <TextBox Text="{Binding ConstantValue, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="3"/>
                        </StackPanel>

                        <!-- 动态绑定配置 -->
                        <StackPanel Visibility="{Binding IsDynamicBinding, Converter={StaticResource BoolToVisibleConverter}}">
                            <TextBlock Text="源节点:" Margin="0,10,0,2"/>
                            <ComboBox ItemsSource="{Binding AvailableSourceNodes}"
                                      SelectedItem="{Binding SelectedSourceNode}"
                                      DisplayMemberPath="NodeName"
                                      Padding="3"/>

                            <TextBlock Text="源属性:" Margin="0,5,0,2"/>
                            <ComboBox ItemsSource="{Binding AvailableSourceProperties}"
                                      SelectedItem="{Binding SourceProperty}"
                                      Padding="3"/>

                            <!-- 绑定预览 -->
                            <Border Background="#F0F0F0" Margin="0,10,0,0" Padding="5" CornerRadius="3">
                                <TextBlock Text="{Binding BindingDescription}"
                                           FontSize="11"
                                           Foreground="Gray"/>
                            </Border>
                        </StackPanel>

                        <!-- 操作按钮 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="确定" Width="60" Margin="5,0"
                                    Click="OnConfirmBinding"/>
                            <Button Content="取消" Width="60"
                                    Click="OnCancelBinding"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</UserControl>
