<Application x:Class="SunEyeVision.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SunEyeVision.UI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 应用资源 -->
                <ResourceDictionary Source="Views/Resources/AppResources.xaml"/>
                <!-- 节点样式资源 -->
                <ResourceDictionary Source="Resources/Styles/NodeStyleResources.xaml"/>
                <!-- 连接线样式资源 -->
                <ResourceDictionary Source="Resources/Styles/ConnectionStyleResources.xaml"/>
                <!-- Canvas样式资源 -->
                <ResourceDictionary Source="Resources/Styles/CanvasStyleResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
