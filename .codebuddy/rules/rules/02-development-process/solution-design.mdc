# 验证1：确认类存在
search_content pattern="class [类名]" directory="src/"

# 验证2：确认方法存在
search_content pattern="public.*void [方法名]" directory="src/"

# 验证3：确认使用方式
grep -r "[使用模式]" src/ --include="*.cs" | head -5
```

