<ui:BaseToolDebugWindow x:Class="SunEyeVision.Tool.TemplateMatching.Views.TemplateMatchingToolDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SunEyeVision.Plugin.SDK.UI;assembly=SunEyeVision.Plugin.SDK"
        xmlns:controls="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls;assembly=SunEyeVision.Plugin.SDK"
        Title="模板匹配工具调试" Height="500" Width="400">
    
    <ui:BaseToolDebugWindow.Tabs>
        <!-- Tab1: 基本参数 -->
        <TabItem Header="基本参数" IsSelected="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                <StackPanel>
                    <controls:LabeledControl Label="输入图像">
                        <controls:ImageSourceSelector 
                            x:Name="ImageSourceSelector"
                            PlaceholderText="选择图像源..."/>
                    </controls:LabeledControl>
                    
                    <TextBlock Text="匹配参数设置" FontSize="13" FontWeight="Medium" 
                               Margin="0,16,0,8" Foreground="#333333"/>
                    
                    <controls:ParamComboBox x:Name="MethodCombo"
                                            Label="匹配方法"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        
        <!-- Tab2: 运行参数 -->
        <TabItem Header="运行参数">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                <StackPanel>
                    <controls:LabeledControl Label="匹配阈值">
                        <controls:BindableParameter 
                            x:Name="ThresholdParam"
                            DataType="Double"
                            DoubleMinimum="0"
                            DoubleMaximum="1"
                            SmallChange="0.05"
                            LargeChange="0.1"
                            ShowSlider="True"
                            DecimalPlaces="2"/>
                    </controls:LabeledControl>
                    
                    <controls:LabeledControl Label="最大匹配数">
                        <controls:BindableParameter 
                            x:Name="MaxMatchesParam"
                            DataType="Int"
                            IntMinimum="1"
                            IntMaximum="100"
                            ShowSlider="True"/>
                    </controls:LabeledControl>
                    
                    <controls:LabeledControl Label="多尺度匹配">
                        <CheckBox x:Name="MultiScaleCheckBox" 
                                  VerticalAlignment="Center"/>
                    </controls:LabeledControl>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </ui:BaseToolDebugWindow.Tabs>
    
</ui:BaseToolDebugWindow>
