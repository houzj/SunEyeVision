<UserControl x:Class="SunEyeVision.Tool.ColorConvert.Views.ColorConvertToolDebugControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls;assembly=SunEyeVision.Plugin.SDK"
        Background="White">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#1890FF" Padding="12,8">
            <TextBlock Text="颜色空间转换工具调试"
                      Foreground="White"
                      FontSize="16"
                      FontWeight="Bold"
                      VerticalAlignment="Center"
                      Margin="12,0,0,0"/>
        </Border>

        <!-- Tab区域 -->
        <TabControl Grid.Row="1" BorderThickness="0">
            <TabItem Header="参数配置" IsSelected="True">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <controls:LabeledControl Label="输入图像">
                            <controls:ImageSourceSelector 
                                x:Name="ImageSourceSelector"
                                PlaceholderText="选择图像源..."/>
                        </controls:LabeledControl>
                        
                        <TextBlock Text="颜色空间设置" 
                                   FontSize="13" FontWeight="Medium" 
                                   Margin="0,16,0,8" Foreground="#333333"/>
                        
                        <controls:ParamComboBox x:Name="SourceColorSpaceCombo"
                                                Label="源颜色空间"/>
                        
                        <controls:ParamComboBox x:Name="TargetColorSpaceCombo"
                                                Label="目标颜色空间"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
    
</UserControl>
