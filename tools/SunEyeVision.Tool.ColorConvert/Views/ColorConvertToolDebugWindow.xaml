<ui:BaseToolDebugWindow x:Class="SunEyeVision.Tool.ColorConvert.Views.ColorConvertToolDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SunEyeVision.Plugin.SDK.UI;assembly=SunEyeVision.Plugin.SDK"
        xmlns:controls="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls;assembly=SunEyeVision.Plugin.SDK"
        Title="颜色空间转换工具调试" Height="400" Width="400">
    
    <ui:BaseToolDebugWindow.Tabs>
        <TabItem Header="参数配置" IsSelected="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                <StackPanel>
                    <controls:LabeledControl Label="输入图像">
                        <controls:ImageSourceSelector 
                            x:Name="ImageSourceSelector"
                            PlaceholderText="选择图像源..."/>
                    </controls:LabeledControl>
                    
                    <TextBlock Text="颜色空间设置" 
                               FontSize="13" FontWeight="Medium" 
                               Margin="0,16,0,8" Foreground="#333333"/>
                    
                    <controls:ParamComboBox x:Name="SourceColorSpaceCombo"
                                            Label="源颜色空间"/>
                    
                    <controls:ParamComboBox x:Name="TargetColorSpaceCombo"
                                            Label="目标颜色空间"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </ui:BaseToolDebugWindow.Tabs>
    
</ui:BaseToolDebugWindow>
