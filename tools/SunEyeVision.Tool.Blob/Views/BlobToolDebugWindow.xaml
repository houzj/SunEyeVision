<Window x:Class="SunEyeVision.Tool.Blob.Views.BlobToolDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Blob工具调试窗口"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl>
            <TabItem Header="配置">
                <Grid Background="#F5F5F5" Margin="10">
                    <StackPanel Orientation="Vertical">
                        <CheckBox Content="显示Blob" 
                                  IsChecked="{Binding ShowBlobs}"
                                  Margin="10"/>
                        <CheckBox Content="显示标签" 
                                  IsChecked="{Binding ShowLabels}"
                                  Margin="10"/>
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <TextBlock Text="最小面积:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="▼" 
                                        Command="{Binding DecrementMinAreaCommand}"
                                        Width="24" Height="24" Margin="5"/>
                                <TextBox Text="{Binding MinArea}" 
                                         Width="60" 
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"/>
                                <Button Content="▲" 
                                        Command="{Binding IncrementMinAreaCommand}"
                                        Width="24" Height="24" Margin="5"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Content="设置样式" 
                                Command="{Binding OpenStyleSettingsCommand}"
                                Width="100" 
                                Height="30"
                                Margin="10"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <TabItem Header="结果">
                <Grid Background="#F5F5F5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 配置栏 -->
                    <Border Grid.Row="0" 
                            Background="White" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="0,0,0,1"
                            Padding="10">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="显示Blob" 
                                      IsChecked="{Binding ShowBlobs}"
                                      Margin="0,0,10,0"/>
                            <CheckBox Content="显示标签" 
                                      IsChecked="{Binding ShowLabels}"
                                      Margin="0,0,10,0"/>
                            <TextBlock Text="最小面积:" 
                                       VerticalAlignment="Center" 
                                       Margin="20,0,5,0"/>
                            <TextBox Text="{Binding MinArea}" 
                                     Width="60" 
                                     TextAlignment="Center"
                                     VerticalContentAlignment="Center"/>
                            <Button Content="设置" 
                                    Command="{Binding OpenStyleSettingsCommand}"
                                    Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- 结果显示区域 -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 缩略图 -->
                        <Border Grid.Column="0"
                                Width="200"
                                Margin="10"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Image Source="{Binding ThumbnailImage}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>
                        
                        <!-- 结果列表 -->
                        <Border Grid.Column="1"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="4"
                                Background="White"
                                Margin="10,10,10,10">
                            <DataGrid ItemsSource="{Binding BlobResults}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      GridLinesVisibility="None"
                                      HeadersVisibility="Column"
                                      Background="#F5F5F5"
                                      RowBackground="White"
                                      AlternatingRowBackground="#FAFAFA"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Binding="{Binding IsVisible}" Width="40"/>
                                    <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="60"/>
                                    <DataGridTextColumn Header="面积" Binding="{Binding Area}" Width="80"/>
                                    <DataGridTextColumn Header="中心X" Binding="{Binding CenterX}" Width="80"/>
                                    <DataGridTextColumn Header="中心Y" Binding="{Binding CenterY}" Width="80"/>
                                    <DataGridTextColumn Header="宽度" Binding="{Binding Width}" Width="80"/>
                                    <DataGridTextColumn Header="高度" Binding="{Binding Height}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
