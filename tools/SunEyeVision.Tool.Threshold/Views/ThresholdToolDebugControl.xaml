<controls:ToolDebugControlBase x:Class="SunEyeVision.Tool.Threshold.Views.ThresholdToolDebugControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls;assembly=SunEyeVision.Plugin.SDK"
        xmlns:commands="clr-namespace:SunEyeVision.Plugin.SDK.Commands;assembly=SunEyeVision.Plugin.SDK"
        xmlns:region="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Views;assembly=SunEyeVision.Plugin.SDK"
        xmlns:converters="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Converters;assembly=SunEyeVision.Plugin.SDK"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:SunEyeVision.Tool.Threshold"
        xmlns:localConverters="clr-namespace:SunEyeVision.Tool.Threshold.Converters"
        mc:Ignorable="d"
        d:DesignHeight="550" d:DesignWidth="400"
        DataContext="{Binding Parameters, RelativeSource={RelativeSource Self}}">

    <controls:ToolDebugControlBase.Resources>
        <ResourceDictionary>
            <!-- ★ 显式加载 SDK 层的资源字典（设计时支持） -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/SunEyeVision.Plugin.SDK;component/UI/Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 其他资源 -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <localConverters:ThresholdTypeConverter x:Key="ThresholdTypeConverter"/>
        </ResourceDictionary>
    </controls:ToolDebugControlBase.Resources>

    <!-- 主布局：标题栏 + TabControl + 按钮栏 -->
  <Grid>
    <!-- TabControl -->
    <TabControl  Margin="5,0,5,0">
      <!-- Tab1: 基本参数 -->
      <TabItem Header="基本参数" IsSelected="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
          <StackPanel>
            <controls:LabeledControl Label="输入图像" ContentHorizontalAlignment="Center" ContentVerticalAlignment="Center" LabelVerticalAlignment="Center" >
              <controls:ImageSourceSelector
                                x:Name="imageSourceSelector"
                                PlaceholderText="请选择输入图像源"
                                Width="250"
                                AvailableDataSources="{Binding AvailableDataSources, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type controls:ToolDebugControlBase}}}"
                                SelectedDataSource="{Binding Parameters.ImageSource, Mode=TwoWay}"/>
            </controls:LabeledControl>

            <TextBlock Text="ROI区域"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Margin="0 16 0 4"
                                   Foreground="#333333"/>
            <region:RegionEditorControl x:Name="regionEditor" VerticalContentAlignment="Stretch"/>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Tab2: 运行参数 -->
      <TabItem Header="运行参数">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
          <StackPanel>
            <controls:LabeledControl Label="阈值" >
              <controls:ConfigSetting
                                x:Name="thresholdParam"
                                ParameterName="Threshold"
                                DataType="{x:Type sys:Int32}"
                                Value="{Binding Threshold.Value, Mode=TwoWay}"
                                Minimum="0"
                                Maximum="255"
                                SmallChange="1"
                                LargeChange="10"
                                ShowSlider="True" Width="250"
                                AvailableDataSources="{Binding AvailableDataSources, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type controls:ToolDebugControlBase}}}"/>
            </controls:LabeledControl>

            <controls:LabeledControl Label="最大值">
              <controls:ConfigSetting
                                x:Name="maxValueParam"
                                ParameterName="MaxValue"
                                DataType="{x:Type sys:Int32}"
                                Value="{Binding MaxValue.Value, Mode=TwoWay}"
                                Minimum="0"
                                Maximum="255"
                                SmallChange="1"
                                LargeChange="10"
                                ShowSlider="True" Width="250"
                                AvailableDataSources="{Binding AvailableDataSources, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type controls:ToolDebugControlBase}}}"/>
            </controls:LabeledControl>
            <controls:LabeledControl Label="选择阈值类型" >
              <ComboBox x:Name="thresholdTypeComboBox"
                      Height="32"
                      VerticalContentAlignment="Center" Width="250"
                      SelectedItem="{Binding Type.Value, Mode=TwoWay, Converter={StaticResource ThresholdTypeConverter}}">
                <ComboBoxItem Content="Binary"/>
                <ComboBoxItem Content="BinaryInv"/>
                <ComboBoxItem Content="Trunc"/>
                <ComboBoxItem Content="ToZero"/>
                <ComboBoxItem Content="ToZeroInv"/>
              </ComboBox>
            </controls:LabeledControl>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Tab3: 结果显示 -->
      <TabItem Header="结果显示">
        <Grid Background="#F5F5F5">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <ScrollViewer Grid.Row="0" Padding="3">
            <StackPanel>
              <!-- 结果判断分组 -->
              <Expander Header="结果判断"
                                      IsExpanded="True"
                                      BorderBrush="#E0E0E0"
                                      BorderThickness="1"
                                      Margin="0,0,0,8"
                                      Background="White">
                <StackPanel Margin="16,8">
                  <!-- 输出为空判断 -->
                  <controls:LabeledControl Label="输出为空判断" ContentHorizontalAlignment="Left">
                    <controls:ToggleSwitch IsChecked="{Binding ResultConfig.IsEmptyCheckEnabled, Mode=TwoWay}"/>
                  </controls:LabeledControl>

                  <!-- 白色像素比例判断 -->
                  <controls:LabeledControl Label="白色像素比例" ContentHorizontalAlignment="Left" Margin="0,2,0,0">
                    <controls:ToggleSwitch IsChecked="{Binding ResultConfig.IsWhitePixelRatioCheckEnabled, Mode=TwoWay}"/>
                  </controls:LabeledControl>
                  <controls:LabeledControl Label="白色像素比例 (%):"  Margin="0,2,0,0" ContentHorizontalAlignment="Left"
                                           Visibility="{Binding ResultConfig.IsWhitePixelRatioCheckEnabled,
                    Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:RangeInputControl
                                            Unit="%"
                                            Minimum="0"
                                            Maximum="100"
                                            MinValue="{Binding ResultConfig.WhitePixelRatioMin, Mode=TwoWay}"
                                            MaxValue="{Binding ResultConfig.WhitePixelRatioMax, Mode=TwoWay}"
                                            DecimalPlaces="1"
                      SmallChange="1"
                      NumericWidth="120"

                                             />
                  </controls:LabeledControl>

                  <!-- 输出均值判断 -->
                  <controls:LabeledControl Label="输出均值判断" ContentHorizontalAlignment="Left" Margin="0,2,0,0">
                    <controls:ToggleSwitch IsChecked="{Binding ResultConfig.IsMeanCheckEnabled, Mode=TwoWay}"/>
                  </controls:LabeledControl>
                  <controls:LabeledControl Label="输出均值范围:" Margin="0,2,0,0"
                                                            Visibility="{Binding ResultConfig.IsMeanCheckEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:RangeInputControl
                                            Unit=""
                                            Minimum="0"
                                            Maximum="255"
                                            MinValue="{Binding ResultConfig.MeanMin, Mode=TwoWay}"
                                            MaxValue="{Binding ResultConfig.MeanMax, Mode=TwoWay}"
                                            DecimalPlaces="1"  NumericWidth="120" Margin="0,2,0,0"/>
                  </controls:LabeledControl>

                  <!-- 输出面积判断 -->
                  <controls:LabeledControl Label="输出面积判断" ContentHorizontalAlignment="Left" Margin="0,2,0,0">
                    <controls:ToggleSwitch IsChecked="{Binding ResultConfig.IsAreaCheckEnabled, Mode=TwoWay}"/>
                  </controls:LabeledControl>
                  <controls:LabeledControl Label="输出面积范围 (px²):" Margin="0,2,0,0"
                                                            Visibility="{Binding ResultConfig.IsAreaCheckEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:RangeInputControl
                                            Unit="px²"
                                            Minimum="0"
                                            Maximum="1000000"
                                            MinValue="{Binding ResultConfig.AreaMin, Mode=TwoWay}"
                                            MaxValue="{Binding ResultConfig.AreaMax, Mode=TwoWay}"
                                            DecimalPlaces="0"  NumericWidth="120"/>
                  </controls:LabeledControl>

                  <!-- 质心X判断 -->
                  <controls:LabeledControl Label="质心X判断" ContentHorizontalAlignment="Left" Margin="0,2,0,0">
                    <controls:ToggleSwitch IsChecked="{Binding ResultConfig.IsCentroidXCheckEnabled, Mode=TwoWay}"/>
                  </controls:LabeledControl>
                  <controls:LabeledControl Label="质心X坐标范围:" Margin="0,2,0,0"
                                                            Visibility="{Binding ResultConfig.IsCentroidXCheckEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:RangeInputControl
                                            Unit=""
                                            Minimum="0"
                                            Maximum="10000"
                                            MinValue="{Binding ResultConfig.CentroidXMin, Mode=TwoWay}"
                                            MaxValue="{Binding ResultConfig.CentroidXMax, Mode=TwoWay}"
                                            DecimalPlaces="1"  NumericWidth="120"/>
                  </controls:LabeledControl>

                  <!-- 质心Y判断 -->
                  <controls:LabeledControl Label="质心Y判断" ContentHorizontalAlignment="Left" Margin="0,2,0,0">
                    <controls:ToggleSwitch IsChecked="{Binding ResultConfig.IsCentroidYCheckEnabled, Mode=TwoWay}"/>
                  </controls:LabeledControl>
                  <controls:LabeledControl Label="质心Y坐标范围:" Margin="0,2,0,0"
                                                            Visibility="{Binding ResultConfig.IsCentroidYCheckEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:RangeInputControl
                                            Unit=""
                                            Minimum="0"
                                            Maximum="10000"
                                            MinValue="{Binding ResultConfig.CentroidYMin, Mode=TwoWay}"
                                            MaxValue="{Binding ResultConfig.CentroidYMax, Mode=TwoWay}"
                                            DecimalPlaces="1"  NumericWidth="120"/>
                  </controls:LabeledControl>
                </StackPanel>
              </Expander>

              <!-- 图像显示分组 -->
              <Expander Header="图像显示"
                                      IsExpanded="True"
                                      BorderBrush="#E0E0E0"
                                      BorderThickness="1"
                                      Margin="0,0,0,8"
                                      Background="White">
                <StackPanel Margin="16,8">
                  <!-- 输出图像 -->
                  <controls:LabeledControl Label="输出图像" ContentHorizontalAlignment="Left">
                    <controls:DispItemColorControl
                        Config="{Binding DisplayConfig.OutputImage, Mode=TwoWay}"
                        ContentHorizontalAlignment="Left"/>
                  </controls:LabeledControl>

                  <!-- 阈值分界线 -->
                  <controls:LabeledControl Label="阈值分界线" ContentHorizontalAlignment="Left" Margin="0,8,0,0">
                    <controls:DispItemColorControl
                        Config="{Binding DisplayConfig.ThresholdLine, Mode=TwoWay}"
                        ContentHorizontalAlignment="Left"/>
                  </controls:LabeledControl>

                  <!-- ROI区域 -->
                  <controls:LabeledControl Label="ROI区域" ContentHorizontalAlignment="Left" Margin="0,8,0,0">
                    <controls:DispItemColorControl
                        Config="{Binding DisplayConfig.Region, Mode=TwoWay}"
                        ContentHorizontalAlignment="Left"/>
                  </controls:LabeledControl>

                  <!-- 直方图 -->
                  <controls:LabeledControl Label="直方图" ContentHorizontalAlignment="Left" Margin="0,8,0,0">
                    <controls:DispItemColorControl
                        Config="{Binding DisplayConfig.Histogram, Mode=TwoWay}"
                        ContentHorizontalAlignment="Left"/>
                  </controls:LabeledControl>
                </StackPanel>
              </Expander>

              <!-- 文本显示分组 -->
              <Expander Header="文本显示"
                                      IsExpanded="True"
                                      BorderBrush="#E0E0E0"
                                      BorderThickness="1"
                                      Background="White">


                <StackPanel Margin="16,8">
                  <controls:LabeledControl Label="内容" Margin="0,0,0,8">
                    <TextBox Grid.Column="1" Grid.Row="0" Width="250"
                                             Text="{Binding TextConfig.Content, Mode=TwoWay}"
                                             HorizontalAlignment="Left"
                                             Height="32"
                                             VerticalContentAlignment="Center"/>
                  </controls:LabeledControl>

                  <!-- OK颜色 -->
                  <controls:LabeledControl Label="OK颜色" Margin="0,0,0,8">
                    <controls:ColorSelector HorizontalAlignment="Left" Width="250" SelectedColor="{Binding TextConfig.OkColor, Mode=TwoWay}"/>
                  </controls:LabeledControl>

                  <!-- NG颜色 -->
                  <controls:LabeledControl Label="NG颜色" Margin="0,0,0,8">
                    <controls:ColorSelector Width="250" HorizontalAlignment="Left" SelectedColor="{Binding TextConfig.NgColor, Mode=TwoWay}"/>
                  </controls:LabeledControl>
                  <controls:LabeledControl Label="字号" Margin="0,0,0,8">
                    <controls:NumericUpDown Value="{Binding TextConfig.FontSize, Mode=TwoWay}"
                                                Minimum="0"
                                                Maximum="1"
                                                DecimalPlaces="2"
                                                HorizontalAlignment="Left"
                                                Width="250"/>
                  </controls:LabeledControl>

                  <controls:LabeledControl Label="透明度" Margin="0,0,0,8">
                    <controls:NumericUpDown Value="{Binding TextConfig.Opacity, Mode=TwoWay}"
                                             Minimum="8"
                                             Maximum="72"
                                             DecimalPlaces="1"
                                             HorizontalAlignment="Left"
                                             Width="250"/>
                  </controls:LabeledControl>

                  <controls:LabeledControl Label="位置X" Margin="0,0,0,8">
                    <controls:ConfigSetting Grid.Column="1" Grid.Row="3"
                                                            ParameterName="TextConfig.PositionX"
                                                            DataType="{x:Type sys:Double}"
                                                            Value="{Binding TextConfig.PositionX, Mode=TwoWay}"
                                                            Minimum="8"
                                                            Maximum="72"
                                                            DecimalPlaces="1"
                                                            HorizontalAlignment="Left"
                                                            Width="250"
                                                            AvailableDataSources="{Binding AvailableDataSources, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type controls:ToolDebugControlBase}}}"/>
                  </controls:LabeledControl>
                  <controls:LabeledControl Label="位置Y" Margin="0,0,0,8">
                    <controls:ConfigSetting Grid.Column="1" Grid.Row="3"
                                                            ParameterName="TextConfig.PositionY"
                                                            DataType="{x:Type sys:Double}"
                                                            Value="{Binding TextConfig.PositionY, Mode=TwoWay}"
                                                            Minimum="8"
                                                            Maximum="72"
                                                            DecimalPlaces="1"
                                                            HorizontalAlignment="Left"
                                                            Width="250"
                                                            AvailableDataSources="{Binding AvailableDataSources, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type controls:ToolDebugControlBase}}}"/>

                  </controls:LabeledControl>
                </StackPanel>
              </Expander>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</controls:ToolDebugControlBase>
