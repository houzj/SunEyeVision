<Window x:Class="SunEyeVision.Tool.RegionEditor.Views.RegionEditorToolDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:region="clr-namespace:SunEyeVision.Plugin.SDK.UI.Controls.Region.Views;assembly=SunEyeVision.Plugin.SDK"
        Title="区域编辑器" Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,6">
            <TextBlock x:Name="txtTitle" FontSize="16" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
        </Border>

        <!-- Tab区域 -->
        <TabControl Grid.Row="1" x:Name="MainTabControl" Margin="0" BorderThickness="0">
            <!-- 图像Tab -->
            <TabItem Header="图像">
                <StackPanel Orientation="Horizontal" Margin="12,8" VerticalAlignment="Top">
                    <Button Content="打开图像" Padding="16,6" FontSize="13"
                            Background="#1890FF" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="OpenImage_Click"/>
                    <TextBlock x:Name="CurrentImageFileName" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="#666666" FontSize="12"/>
                </StackPanel>
            </TabItem>

            <!-- 区域编辑Tab -->
            <TabItem Header="区域编辑">
                <region:RegionEditorControl x:Name="RegionEditor" Margin="0"/>
            </TabItem>

            <!-- 参数Tab -->
            <TabItem Header="参数">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <!-- 显示选项 -->
                        <GroupBox Header="显示选项" Margin="0,0,0,12">
                            <StackPanel>
                                <CheckBox x:Name="RealtimePreviewCheck" Content="启用实时预览" IsChecked="True" Margin="0,4"
                                          Checked="RealtimePreviewCheck_Changed" Unchecked="RealtimePreviewCheck_Changed"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- 默认颜色 -->
                        <GroupBox Header="默认颜色" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="颜色: " VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="ColorComboBox" Width="120" SelectedIndex="0"
                                          SelectionChanged="ColorComboBox_SelectionChanged">
                                    <ComboBoxItem Content="红色" Tag="#FFFF0000"/>
                                    <ComboBoxItem Content="绿色" Tag="#FF00FF00"/>
                                    <ComboBoxItem Content="蓝色" Tag="#FF0000FF"/>
                                    <ComboBoxItem Content="黄色" Tag="#FFFFFF00"/>
                                    <ComboBoxItem Content="青色" Tag="#FF00FFFF"/>
                                    <ComboBoxItem Content="紫色" Tag="#FFFF00FF"/>
                                </ComboBox>
                            </StackPanel>
                        </GroupBox>

                        <!-- 快速添加区域 -->
                        <GroupBox Header="快速添加" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="绘制模式区域" FontWeight="Bold" Margin="0,0,0,8"/>
                                <WrapPanel>
                                    <Button Content="矩形" Padding="12,4" Margin="0,0,4,4" Click="AddRectangle_Click"/>
                                    <Button Content="圆形" Padding="12,4" Margin="0,0,4,4" Click="AddCircle_Click"/>
                                    <Button Content="旋转矩形" Padding="12,4" Margin="0,0,4,4" Click="AddRotatedRect_Click"/>
                                    <Button Content="直线" Padding="12,4" Margin="0,0,4,4" Click="AddLine_Click"/>
                                </WrapPanel>
                                
                                <TextBlock Text="订阅模式区域" FontWeight="Bold" Margin="0,12,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="节点ID: " VerticalAlignment="Center"/>
                                    <TextBox x:Name="NodeIdTextBox" Width="100" Margin="4,0"/>
                                    <TextBlock Text="输出名: " VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBox x:Name="OutputNameTextBox" Width="100" Margin="4,0"/>
                                    <Button Content="添加订阅" Padding="12,4" Margin="8,0,0,0" Click="AddSubscribed_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 结果Tab -->
            <TabItem Header="结果">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <GroupBox Header="区域统计" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock x:Name="RegionCountText" Text="区域数量: 0" Margin="0,4"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="区域列表" Margin="0,0,0,12">
                            <ListBox x:Name="RegionListBox" Height="200"/>
                        </GroupBox>

                        <GroupBox Header="解析结果" Margin="0,0,0,12">
                            <ListBox x:Name="ResolvedListBox" Height="150"/>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="运行" Padding="24,8" FontSize="13" FontWeight="Bold"
                        Background="#1890FF" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,8,0" Click="RunButton_Click"/>
                <Button Content="重置" Padding="24,8" FontSize="13"
                        Background="#F5F5F5" Foreground="#666666"
                        BorderBrush="#D9D9D9" BorderThickness="1"
                        Cursor="Hand" Click="ResetButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
